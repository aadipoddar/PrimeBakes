					}
				</div>
			}
			else if (Type == AggregateType.Count)
			{
				<div>
					@if (CustomColor is not null)
					{
						<strong class="@CustomColor">Total Items: @aggregate.Count</strong>
					}
					else
					{
						<strong>Total Items: @aggregate.Count</strong>
					}
				</div>
			}
		}
	</GroupFooterTemplate>
	<GroupCaptionTemplate>
		@{
			var aggregate = (context as AggregateTemplateContext);
			@if (Type == AggregateType.Sum)
			{
				<div>
					@if (CustomColor is not null)
