<SfDialog @ref="_dialog" Width="480px" IsModal="true" ShowCloseIcon="true" @bind-Visible="IsVisible">
	<DialogEvents Closed="HandleDialogClose" />

	@if (IsVisible)
	{
		<MudBlazor.MudHotkey Key=JsKey.Escape OnHotkeyPressed="HandleClose" />
		@if (!string.IsNullOrEmpty(ExistingDocumentUrl))
		{
			<MudBlazor.MudHotkey Key=JsKey.Enter OnHotkeyPressed="HandleDownload" />
			<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="HandleRemove" />
		}
	}

	<DialogTemplates>
		<Header>
			<div style="display: flex; align-items: center; gap: 10px;">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
					 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
					 style="color: #3b82f6; flex-shrink: 0;">
					<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
					<polyline points="17 8 12 3 7 8" />
					<line x1="12" y1="3" x2="12" y2="15" />
				</svg>
				<span style="font-size: 16px; font-weight: 600; color: #0f172a;">@Title</span>
			</div>
		</Header>
		<Content>
			<div style="padding: 20px;">
				@if (!string.IsNullOrEmpty(ExistingDocumentUrl))
				{
					<!-- Existing Document Section -->
					<div style="display: flex; align-items: center; gap: 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 14px 16px; margin-bottom: 16px;">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"
							 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
							 style="color: #10b981; flex-shrink: 0;">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="9" y1="15" x2="15" y2="15" />
							<line x1="9" y1="11" x2="15" y2="11" />
						</svg>
						<div style="min-width: 0;">
							<p style="margin: 0 0 2px 0; font-size: 13px; font-weight: 600; color: #0f172a;">
								Document on file
							</p>
							<p style="margin: 0; font-size: 12px; color: #64748b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
								@(ExistingDocumentUrl.Split('/').Last())
							</p>
						</div>
					</div>

					<!-- Action Buttons -->
					<div style="display: flex; justify-content: flex-end; gap: 8px;">
						<button class="dialog-btn dialog-btn-primary" @onclick="OnDownloadClick">Download (Enter)</button>
						<button class="dialog-btn dialog-btn-danger" @onclick="OnRemoveClick">Remove (Del)</button>
					</div>
				}
				else
				{
					<!-- Upload Area -->
					<div style="background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 8px; padding: 24px 20px; text-align: center;">
						<div style="display: flex; flex-direction: column; align-items: center; gap: 8px; margin-bottom: 16px;">
							<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none"
								 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
								 style="color: #94a3b8;">
								<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
								<polyline points="17 8 12 3 7 8" />
								<line x1="12" y1="3" x2="12" y2="15" />
							</svg>
							<div>
								<p style="margin: 0 0 2px 0; font-size: 14px; font-weight: 600; color: #0f172a;">
									Upload Document
								</p>
								<p style="margin: 0; font-size: 12px; color: #94a3b8;">
									PDF, DOC, DOCX, JPG, JPEG, PNG (Max 50MB)
								</p>
							</div>
						</div>

						<SfUploader AutoUpload="true" ShowFileList="true" ShowProgressBar="true"
									AllowMultiple="false" MaxFileSize="52428800" AllowedExtensions=".pdf,.doc,.docx,.jpg,.jpeg,.png"
									CssClass="custom-uploader">
							<UploaderEvents ValueChange="OnFileChange" OnRemove="OnFileRemove" />
						</SfUploader>
					</div>

					<!-- Info Section -->
					<div style="margin-top: 14px; padding: 10px 12px; background: #eff6ff; border-left: 3px solid #3b82f6; border-radius: 4px;">
						<p style="margin: 0; font-size: 12px; color: #1e40af; line-height: 1.5;">
							<strong>Note:</strong> @InfoMessage
						</p>
					</div>
				}
			</div>
		</Content>
	</DialogTemplates>
</SfDialog>

<style>
	/* Dialog Button Styles - consistent with confirmation dialogs */
	.dialog-btn {
		padding: 7px 16px;
		border-radius: 6px;
		font-size: 13px;
		font-weight: 500;
		cursor: pointer;
		border: 1px solid transparent;
		transition: background-color 0.15s ease;
		min-width: 90px;
	}

		.dialog-btn:disabled {
			opacity: 0.6;
			cursor: not-allowed;
		}

	.dialog-btn-primary {
		background: #3b82f6;
		color: #ffffff;
	}

		.dialog-btn-primary:hover:not(:disabled) {
			background: #2563eb;
		}

	.dialog-btn-danger {
		background: #dc2626;
		color: #ffffff;
	}

		.dialog-btn-danger:hover:not(:disabled) {
			background: #b91c1c;
		}

	/* Custom Uploader Styles */
	::deep .custom-uploader .e-upload {
		border: none;
		background: transparent;
	}

	::deep .custom-uploader .e-file-select-wrap {
		padding: 0;
	}

	::deep .custom-uploader .e-file-select {
		background: #3b82f6;
		color: #ffffff;
		border: none;
		border-radius: 6px;
		padding: 8px 20px;
		font-size: 13px;
		font-weight: 500;
		transition: background-color 0.15s ease;
	}

		::deep .custom-uploader .e-file-select:hover {
			background: #2563eb;
		}

	::deep .custom-uploader .e-file-drop {
		border: none;
		padding: 0;
		background: transparent;
	}

	::deep .custom-uploader .e-upload-files {
		margin-top: 14px;
		background: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 6px;
		text-align: left;
	}

	::deep .custom-uploader .e-upload-file-list {
		padding: 10px 14px;
	}

	::deep .custom-uploader .e-file-name {
		font-weight: 600;
		color: #0f172a;
		font-size: 13px;
	}

	::deep .custom-uploader .e-file-size {
		color: #64748b;
		font-size: 12px;
	}

	::deep .custom-uploader .e-file-status {
		color: #10b981;
		font-weight: 500;
		font-size: 12px;
	}

	::deep .custom-uploader .e-icons.e-file-delete-btn,
	::deep .custom-uploader .e-icons.e-file-remove-btn {
		color: #ef4444;
	}

		::deep .custom-uploader .e-icons.e-file-delete-btn:hover,
		::deep .custom-uploader .e-icons.e-file-remove-btn:hover {
			color: #dc2626;
		}

	::deep .custom-uploader .e-upload-progress-wrap {
		background: #e2e8f0;
		border-radius: 4px;
		overflow: hidden;
	}

	::deep .custom-uploader .e-upload-progress-bar {
		background: #3b82f6;
	}
</style>
