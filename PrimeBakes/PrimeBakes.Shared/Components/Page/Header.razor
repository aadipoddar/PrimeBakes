<div class="page-header">
    <div class="header-left">
        <img src="images/logo.png" alt="PrimeBakes" class="header-logo" />
        @if (LeftContent != null)
        {
            @LeftContent
        }
    </div>
    <div class="header-center">
        <h1 class="page-title">@Title</h1>
    </div>
    <div class="header-right">
        @if (RightContent != null)
        {
            @RightContent
        }
        @if (ShowBtButton)
        {
            <IconButton Icon="IconType.Bluetooth"
                        Variant="@(BtIsConnected ? ButtonVariant.BluetoothConnected : ButtonVariant.BluetoothDisconnected)"
                        Title="@(BtIsConnected ? $"Printer: {_btSaved?.Name} (Connected)" : $"Printer: {_btSaved?.Name} (Not Connected)")"
                        OnClick="HandleBtClick" />
        }
        <div class="header-divider"></div>
        <span class="user-name">@_user?.Name</span>
    </div>
</div>

@if (ShowBtButton)
{
    <BluetoothReconnectDialog @ref="_btDialog" PrinterName="@(_btSaved?.Name ?? "Unknown")" IsConnected="@BtIsConnected"
                              Disabled="@_isBtReconnecting" OnReconnect="HandleBtReconnect" OnDismiss="HandleBtDismiss"
                              OnDisconnect="HandleBtDisconnect" />
}

<style>
    /* Professional Header Section */
    .page-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: #ffffff;
        border-bottom: 1px solid #e2e8f0;
        padding: 10px 24px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 16px;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.02);
        min-height: 52px;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .header-logo {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
    }

    .header-divider {
        width: 1px;
        height: 24px;
        background: #e2e8f0;
        flex-shrink: 0;
    }

    .header-center {
        text-align: center;
    }

    .page-title {
        font-size: 17px;
        font-weight: 600;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.2px;
    }

    .header-right {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
    }

    .user-name {
        font-size: 13px;
        font-weight: 500;
        color: #0f172a;
        padding: 6px 10px;
        background: #f8fafc;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
    }

    @@media (max-width: 768px) {

        .header-divider,
        .user-name {
            display: none;
        }
    }
</style>
