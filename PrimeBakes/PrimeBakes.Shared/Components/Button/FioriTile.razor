@using Microsoft.AspNetCore.Components

<div class="fiori-tile-host">
	<SfButton CssClass="fiori-tile" OnClick="OnClick">
		<div class="ft-inner">
			<div class="ft-head">
				<p class="ft-title" style="@(CustomColor is not null ? $"color:{CustomColor}" : null)">@Title</p>
				@if (!string.IsNullOrWhiteSpace(Subtitle))
				{
					<p class="ft-subtitle" style="@(CustomColor is not null ? $"color:{CustomColor}" : null)">@Subtitle</p>
				}
			</div>

			<div class="ft-body"></div>

			<div class="ft-footer">
				@if (IconContent is not null)
				{
					<span class="ft-icon">@IconContent</span>
				}
				@if (!string.IsNullOrWhiteSpace(KPI))
				{
					<p class="ft-value @ValueSizeClass">@KPI</p>
				}
			</div>
		</div>
	</SfButton>
</div>
