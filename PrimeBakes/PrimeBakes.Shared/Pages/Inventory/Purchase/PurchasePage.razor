@using PrimeBakes.Library.Accounts.Masters.Models
@using PrimeBakes.Library.Inventory.Purchase.Models
@using PrimeBakes.Library.Inventory.RawMaterial.Models

@attribute [Route(InventoryRouteNames.Purchase)]
@attribute [Route(InventoryRouteNames.Purchase + "/{Id:int}")]

<PageTitle>Purchase - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _itemAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _otherChargesPercentField?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyU KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="UploadDocument" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyI KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseItemReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_purchase.Id > 0 ? $"Edit Purchase {_purchase.TransactionNo}" : "Create Purchase")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Upload Document (Ctrl + U)" OnClick="UploadDocument" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Purchase (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Purchase, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Item Report (Ctrl + I)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturn, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return Item Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="two-column-layout">

				<!-- Transaction -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Transaction</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete @ref="_firstFocus" T="CompanyModel"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="Select a Company"
													Label="Company (Ctrl + F)"
													ValueChanged="OnCompanyChanged"
													FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@AccountsRouteNames.CompanyMaster" />
							</div>

							<!-- Party -->
							<div class="form-field">
								<CustomAutoComplete T="LedgerModel"
													Value="_selectedParty"
													DataSource="@_parties"
													Placeholder="Select a Party"
													Label="Party"
													ValueChanged="OnPartyChanged"
													FieldValue="@nameof(LedgerModel.Name)"
													AddNewRoute="@AccountsRouteNames.LedgerMaster" />
							</div>

							<!-- Transaction Date -->
							<div class="form-field">
								<CustomDatePicker Value="_purchase.TransactionDateTime"
												  FinancialYear="@_selectedFinancialYear"
												  ValueChanged="OnTransactionDateChanged" />
							</div>

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_purchase.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							<!-- Challan No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_purchase.ChallanNo"
												 Label="Challan No"
												 Placeholder="Enter Challan No"
												 Required="false" />
							</div>

							<!-- Remarks -->
							<div class="form-field form-field-full">
								<CustomTextField @bind-Value="_purchase.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>

						</div>
					</div>
				</div>

				<!-- Financial -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Financial</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Sub Total -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_purchase.TotalAfterTax"
													Label="Sub Total"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<!-- Other Charges -->
							<div class="form-field">
								<div class="date-year-wrapper">
									<CustomNumericField @ref="_otherChargesPercentField"
														T="decimal"
														Value="_purchase.OtherChargesPercent"
														ValueChanged="OnOtherChargesPercentChanged"
														Label="Other Charges % (Ctrl + Shift + F)"
														Placeholder="0.00"
														Required="false"
														Min="0"
														Max="100" />

									<CustomNumericField T="decimal"
														Value="_purchase.OtherChargesAmount"
														Label="Other Charges Amt"
														Placeholder="0.00"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Cash Discount -->
							<div class="form-field">
								<div class="date-year-wrapper">
									<CustomNumericField T="decimal"
														Value="_purchase.CashDiscountPercent"
														ValueChanged="OnCashDiscountPercentChanged"
														Label="Cash Dis %"
														Placeholder="0.00"
														Required="false"
														Min="0"
														Max="100" />

									<CustomNumericField T="decimal"
														Value="_purchase.CashDiscountAmount"
														Label="Cash Dis Amt"
														Placeholder="0.00"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Round Off -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_purchase.RoundOffAmount"
													ValueChanged="OnRoundOffAmountChanged"
													Label="Round Off"
													Placeholder="0.00"
													Required="false" />
							</div>

							<hr class="form-divider" />

							<!-- Total Amount -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_purchase.TotalAmount"
													Label="Total Amount"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

						</div>
					</div>
				</div>
			</div>

			<!-- Add to Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Add Items to Cart</h2>
				</div>

				<div class="section-body">
					<!-- First Row: Item Selection and Basic Info -->
					<div class="cart-input-row">

						<!-- Item -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="RawMaterialModel"
												@ref="_itemAutoComplete"
												Value="_selectedRawMaterial"
												DataSource="@_rawMaterials"
												Placeholder="Select Item"
												Label="Item (Ctrl + G)"
												ValueChanged="OnItemChanged"
												FieldValue="@nameof(RawMaterialModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterial"
												OpenOnFocus="false" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Quantity"
												ValueChanged="OnItemQuantityChanged"
												Label="Qty"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Rate"
												ValueChanged="OnItemRateChanged"
												Label="Rate"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountPercent"
												ValueChanged="OnItemDiscountPercentChanged"
												Label="Disc %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTPercent"
												ValueChanged="OnItemCGSTPercentChanged"
												Label="CGST %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTPercent"
												ValueChanged="OnItemSGSTPercentChanged"
												Label="SGST %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTPercent"
												ValueChanged="OnItemIGSTPercentChanged"
												Label="IGST %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox Value="_selectedCart.InclusiveTax"
												ValueChanged="OnItemInclusiveTaxChanged"
												Label="Tax Incl." />
							</div>
						</div>

						<div class="cart-field">
						</div>
					</div>

					<!-- Second Row: Readonly Amounts Aligned with Percentages -->
					<div class="cart-input-row">
						<!-- Remarks (below item field) -->
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<!-- UOM (below Quantity) -->
						<div class="cart-field">
							<CustomTextField @bind-Value="_selectedCart.UnitOfMeasurement"
											 Label="UOM"
											 Placeholder="UOM..." />
						</div>

						<!-- Base Total (below Rate) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.BaseTotal"
												Label="Base"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Discount Amount (below Disc %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountAmount"
												Label="Disc Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- CGST Amount (below CGST %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTAmount"
												Label="CGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- SGST Amount (below SGST %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTAmount"
												Label="SGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- IGST Amount (below IGST %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTAmount"
												Label="IGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Total (below Tax Incl.) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Total"
												Label="Total"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Add Button -->
						<div class="cart-field cart-field-action">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Cart</h2>
				</div>

				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfCartGrid" DataSource="_cart"
							AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_cartGridContextMenuItems" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridEvents TValue="PurchaseItemCartModel" ContextMenuItemClicked="OnCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.ItemName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.Quantity)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.BaseTotal)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.DiscountAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-debit">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.AfterDiscount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.CGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.SGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.IGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.TotalTaxAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseItemCartModel.Total)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(PurchaseItemCartModel.ItemName)" HeaderText="Item Name" Width="200" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.UnitOfMeasurement)" HeaderText="UOM" Width="100" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.Quantity)" HeaderText="Qty" Width="100" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.Rate)" HeaderText="Rate" Width="110" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.BaseTotal)" HeaderText="Base Total" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.DiscountPercent)" HeaderText="Disc %" Width="120" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.DiscountAmount)" HeaderText="Disc Amt" Width="140" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-debit">@item.DiscountAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseItemCartModel.AfterDiscount)" HeaderText="After Disc" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.CGSTPercent)" HeaderText="CGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.CGSTAmount)" HeaderText="CGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.SGSTPercent)" HeaderText="SGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.SGSTAmount)" HeaderText="SGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.IGSTPercent)" HeaderText="IGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.IGSTAmount)" HeaderText="IGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.TotalTaxAmount)" HeaderText="Tax Total" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.InclusiveTax)" HeaderText="Tax Incl." Width="150" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(PurchaseItemCartModel.Total)" HeaderText="Total" Width="130" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Total.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseItemCartModel.Remarks)" HeaderText="Remarks" Width="150" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DocumentUploadDialog ExistingDocumentUrl="@_purchase?.DocumentUrl"
					  @bind-IsVisible="_isUploadDialogVisible"
					  OnFileChange="OnUploaderFileChange" OnFileRemove="OnRemoveFile"
					  OnDownloadClick="DownloadExistingDocument" OnRemoveClick="RemoveExistingDocument"
					  OnClose="CloseUploadDialog" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />