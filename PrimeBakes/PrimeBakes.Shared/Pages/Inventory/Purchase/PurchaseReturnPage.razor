@using PrimeBakesLibrary.Accounts.Masters.Models
@using PrimeBakesLibrary.Inventory.Purchase.Models
@using PrimeBakesLibrary.Inventory.RawMaterial.Models

@attribute [Route(InventoryRouteNames.PurchaseReturn)]
@attribute [Route(InventoryRouteNames.PurchaseReturn + "/{Id:int}")]

<PageTitle>Purchase Return - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfItemAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _sfOtherChargesPercent.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyU KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="UploadDocument" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyI KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnItemReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_purchaseReturn.Id > 0 ? $"Edit Purchase Return {_purchaseReturn.TransactionNo}" : "Create Purchase Return")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Upload Document (Ctrl + U)" OnClick="UploadDocument" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Purchase Return (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturn, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return Item Report (Ctrl + I)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Purchase, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Item Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Top Section: Transaction Summary and Financial Summary Side by Side -->
			<div class="two-column-layout">
				<!-- Transaction Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="16" y1="13" x2="8" y2="13" />
								<line x1="16" y1="17" x2="8" y2="17" />
								<polyline points="10 9 9 9 8 9" />
							</svg>
							<h2 class="section-title">Transaction Summary</h2>
						</div>
					</div>
					<div class="section-body">
						<div class="form-grid">

							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete @ref="_firstFocus" T="CompanyModel"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="Select a Company"
													Label="Company (Ctrl + F)"
													ValueChanged="OnCompanyChanged"
													FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@AccountsRouteNames.CompanyMaster" />
							</div>

							<!-- Party -->
							<div class="form-field">
								<CustomAutoComplete T="LedgerModel"
													Value="_selectedParty"
													DataSource="@_parties"
													Placeholder="Select a Party"
													Label="Party"
													ValueChanged="OnPartyChanged"
													FieldValue="@nameof(LedgerModel.Name)"
													AddNewRoute="@AccountsRouteNames.LedgerMaster" />
							</div>

							<!-- Transaction Date -->
							<div class="form-field">
								<CustomDatePicker Value="_purchaseReturn.TransactionDateTime"
												  FinancialYear="@_selectedFinancialYear"
												  ValueChanged="OnTransactionDateChanged" />
							</div>

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_purchaseReturn.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							<!-- Challan No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_purchaseReturn.ChallanNo"
												 Label="Challan No"
												 Placeholder="Enter Challan No"
												 Required="false" />
							</div>

							<!-- Remarks -->
							<div class="form-field form-field-full">
								<CustomTextField @bind-Value="_purchaseReturn.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>

						</div>
					</div>
				</div>

				<!-- Financial Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23" />
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
							</svg>
							<h2 class="section-title">Financial Summary</h2>
						</div>
					</div>
					<div class="section-body">
						<div class="form-grid">

							<!-- Sub Total -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_purchaseReturn.TotalAfterTax"
													Label="Sub Total"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<!-- Other Charges -->
							<div class="form-field">
								<div class="date-year-wrapper">
									<CustomNumericField @ref="_sfOtherChargesPercent"
														T="decimal"
														Value="_purchaseReturn.OtherChargesPercent"
														ValueChanged="OnOtherChargesPercentChanged"
														Label="Other Charges % (Ctrl + Shift + G)"
														Placeholder="0.00"
														Required="false"
														Min="0"
														Max="100" />

									<CustomNumericField T="decimal"
														Value="_purchaseReturn.OtherChargesAmount"
														Label="Other Charges Amt"
														Placeholder="0.00"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Cash Discount -->
							<div class="form-field">
								<div class="date-year-wrapper">
									<CustomNumericField T="decimal"
														Value="_purchaseReturn.CashDiscountPercent"
														ValueChanged="OnCashDiscountPercentChanged"
														Label="Cash Dis %"
														Placeholder="0.00"
														Required="false"
														Min="0"
														Max="100" />

									<CustomNumericField T="decimal"
														Value="_purchaseReturn.CashDiscountAmount"
														Label="Cash Dis Amt"
														Placeholder="0.00"
														ReadOnly="true"
														Required="false"
														TabIndex="-1" />
								</div>
							</div>

							<!-- Round Off -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_purchaseReturn.RoundOffAmount"
													ValueChanged="OnRoundOffAmountChanged"
													Label="Round Off"
													Placeholder="0.00"
													Required="false" />
							</div>

							<hr class="form-divider" />

							<!-- Total Amount -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_purchaseReturn.TotalAmount"
													Label="Total Amount"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

						</div>
					</div>
				</div>
			</div>

			<!-- Add to Cart Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Item to Cart</h2>
					</div>
				</div>
				<div class="section-body">
					<!-- First Row: Item Selection and Basic Info -->
					<div class="cart-input-row">

						<!-- Item -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="RawMaterialModel"
												@ref="_sfItemAutoComplete"
												Value="_selectedRawMaterial"
												DataSource="@_rawMaterials"
												Placeholder="Select Item"
												Label="Item (Ctrl + G)"
												ValueChanged="OnItemChanged"
												FieldValue="@nameof(RawMaterialModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterial"
												OpenOnFocus="false" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Quantity"
												ValueChanged="OnItemQuantityChanged"
												Label="Qty"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Rate"
												ValueChanged="OnItemRateChanged"
												Label="Rate"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountPercent"
												ValueChanged="OnItemDiscountPercentChanged"
												Label="Disc %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTPercent"
												ValueChanged="OnItemCGSTPercentChanged"
												Label="CGST %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTPercent"
												ValueChanged="OnItemSGSTPercentChanged"
												Label="SGST %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTPercent"
												ValueChanged="OnItemIGSTPercentChanged"
												Label="IGST %"
												Placeholder="0.00"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox Value="_selectedCart.InclusiveTax"
												ValueChanged="OnItemInclusiveTaxChanged"
												Label="Tax Incl." />
							</div>
						</div>

						<div class="cart-field">
						</div>
					</div>

					<!-- Second Row: Readonly Amounts Aligned with Percentages -->
					<div class="cart-input-row">
						<!-- Remarks (below item field) -->
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<!-- UOM (below Quantity) -->
						<div class="cart-field">
							<CustomTextField @bind-Value="_selectedCart.UnitOfMeasurement"
											 Label="UOM"
											 Placeholder="UOM..." />
						</div>

						<!-- Base Total (below Rate) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.BaseTotal"
												Label="Base"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Discount Amount (below Disc %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountAmount"
												Label="Disc Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- CGST Amount (below CGST %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTAmount"
												Label="CGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- SGST Amount (below SGST %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTAmount"
												Label="SGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- IGST Amount (below IGST %) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTAmount"
												Label="IGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Total (below Tax Incl.) -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Total"
												Label="Total"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Add Button -->
						<div class="cart-field cart-field-action">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Cart Items Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Purchase Return Items</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfCartGrid" DataSource="_cart" AllowTextWrap="true"
							AllowPaging="false" AllowSorting="true" AllowResizing="true" AllowFiltering="true"
							GridLines="GridLine.Horizontal" CssClass="professional-grid"
							ContextMenuItems="@_cartGridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="PurchaseReturnItemCartModel" ContextMenuItemClicked="OnCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.ItemName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.Quantity)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.BaseTotal)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.DiscountAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-debit">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.AfterDiscount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.CGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.SGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.IGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.TotalTaxAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnItemCartModel.Total)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.ItemName)" HeaderText="Item Name" Width="200" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.UnitOfMeasurement)" HeaderText="UOM" Width="100" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.Quantity)" HeaderText="Qty" Width="100" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.Rate)" HeaderText="Rate" Width="110" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.BaseTotal)" HeaderText="Base Total" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.DiscountPercent)" HeaderText="Disc %" Width="120" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.DiscountAmount)" HeaderText="Disc Amt" Width="140" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-discount">@item.DiscountAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.AfterDiscount)" HeaderText="After Disc" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.CGSTPercent)" HeaderText="CGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.CGSTAmount)" HeaderText="CGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.SGSTPercent)" HeaderText="SGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.SGSTAmount)" HeaderText="SGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.IGSTPercent)" HeaderText="IGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.IGSTAmount)" HeaderText="IGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.TotalTaxAmount)" HeaderText="Tax Total" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.InclusiveTax)" HeaderText="Tax Incl." Width="150" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.Total)" HeaderText="Total" Width="130" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Total.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseReturnItemCartModel.Remarks)" HeaderText="Remarks" Width="150" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DocumentUploadDialog ExistingDocumentUrl="@_purchaseReturn?.DocumentUrl"
					  @bind-IsVisible="_isUploadDialogVisible"
					  OnFileChange="OnUploaderFileChange" OnFileRemove="OnRemoveFile"
					  OnDownloadClick="DownloadExistingDocument" OnRemoveClick="RemoveExistingDocument"
					  OnClose="CloseUploadDialog" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />