@using PrimeBakes.Library.Accounts.Masters.Models
@using PrimeBakes.Library.Inventory.Purchase.Models
@using PrimeBakes.Library.Inventory.RawMaterial.Models

@attribute [Route(InventoryRouteNames.PurchaseItemReport)]

<PageTitle>Purchase Item Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Purchase, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyW KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleSummary" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyT KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleTransactionReturns" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ViewSelectedTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyL KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="DownloadSelectedOriginalInvoice" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedTransaction" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Purchase Item Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Purchase, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadTransactionOverviews" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudMenuItem Label="@(_showSummary ? "Hide Summary (Ctrl + W)" : "Show Summary (Ctrl + W)")" OnClick="ToggleSummary" />
					<MudBlazor.MudMenuItem Label="@(_showTransactionReturns ? "Hide Returns (Ctrl + T)" : "Show Returns (Ctrl + T)")" OnClick="ToggleTransactionReturns" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="ToggleDetailsView" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Purchase (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Purchase, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Item Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturn, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Purchase Return Item Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.PurchaseReturnItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing || _showSummary">
					<MudBlazor.MudMenuItem Label="View (Alt + O)" OnClick="ViewSelectedTransaction" />
					<MudBlazor.MudMenuItem Label="View Accounting Posting" OnClick="ViewFinancialAccountingPosting" />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" />
					<MudBlazor.MudMenuItem Label="Export Original (Alt + L)" OnClick="DownloadSelectedOriginalInvoice" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedTransaction" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<!-- Date Range -->
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<!-- Raw Material -->
						<div class="form-field">
							<CustomAutoComplete T="RawMaterialModel"
												Value="_selectedRawMaterial"
												DataSource="@_rawMaterials"
												Placeholder="All Items"
												Label="Item" Required="false"
												ValueChanged="OnRawMaterialChanged"
												FieldValue="@nameof(RawMaterialModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterial" />
						</div>

						<!-- Raw Material Category -->
						<div class="form-field">
							<CustomAutoComplete T="RawMaterialCategoryModel"
												Value="_selectedRawMaterialCategory"
												DataSource="@_rawMaterialCategories"
												Placeholder="All Categories"
												Label="Item Category" Required="false"
												ValueChanged="OnRawMaterialCategoryChanged"
												FieldValue="@nameof(RawMaterialCategoryModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterialCategory" />
						</div>

						<!-- Company -->
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="All Companies"
												Label="Company" Required="false"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@AccountsRouteNames.CompanyMaster" />
						</div>

						<!-- Party -->
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel"
												Value="_selectedParty"
												DataSource="@_parties"
												Placeholder="All Parties"
												Label="Party" Required="false"
												ValueChanged="OnPartyChanged"
												FieldValue="@nameof(LedgerModel.Name)"
												AddNewRoute="@AccountsRouteNames.LedgerMaster" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<SfGrid @ref="_sfGrid" TValue="PurchaseItemOverviewModel" DataSource="_transactionOverviews"
						AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="PurchaseItemOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.ItemName)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.Quantity)" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.ItemBaseTotal)" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.DiscountAmount)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.AfterDiscount)" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.SGSTAmount)" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.CGSTAmount)" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.IGSTAmount)" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.TotalTaxAmount)" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.Total)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(PurchaseItemOverviewModel.NetTotal)" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.ItemName)" HeaderText="Item" Visible="@(_showAllColumns || _selectedRawMaterial is null || _selectedRawMaterial.Id <= 0)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.ItemCode)" HeaderText="Code" Visible="_showAllColumns" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.ItemCategoryName)" HeaderText="Category" Visible="_showAllColumns" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.UnitOfMeasurement)" HeaderText="UOM" TextAlign="TextAlign.Center" Visible="@(_showAllColumns && !_showSummary)" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.Quantity)" HeaderText="Qty" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.Rate)" HeaderText="Rate" Visible="@(!_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.ItemBaseTotal)" HeaderText="Base Total" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.DiscountPercent)" HeaderText="Disc %" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.DiscountAmount)" HeaderText="Disc" Visible="_showAllColumns" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.AfterDiscount)" HeaderText="After Disc" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.SGSTPercent)" HeaderText="SGST %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.SGSTAmount)" HeaderText="SGST" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CGSTPercent)" HeaderText="CGST %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CGSTAmount)" HeaderText="CGST" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.IGSTPercent)" HeaderText="IGST %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.IGSTAmount)" HeaderText="IGST" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalTaxAmount)" HeaderText="Tax Amt" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.InclusiveTax)" HeaderText="Tax Incl." TextAlign="TextAlign.Center" Visible="@(_showAllColumns && !_showSummary)" DisplayAsCheckBox="true" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.Total)" HeaderText="Total" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.NetRate)" HeaderText="Net Rate" Visible="@(!_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.NetTotal)" HeaderText="Net Total" TotalColumn="true" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.ItemRemarks)" HeaderText="Item Remarks" Visible="@(_showAllColumns && !_showSummary)" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TransactionNo)" HeaderText="Transaction No" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CompanyName)" HeaderText="Company" Visible="@(!_showSummary && (_showAllColumns || _selectedCompany is null || _selectedCompany.Id <= 0))" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TransactionDateTime)" HeaderText="Date" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.FinancialYear)" HeaderText="Financial Year" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.ChallanNo)" HeaderText="Challan No" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.PartyName)" HeaderText="Party" Visible="@(!_showSummary && (_showAllColumns || _selectedParty is null || _selectedParty.Id <= 0))" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalItems)" HeaderText="Items" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalQuantity)" HeaderText="Quantity" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.BaseTotal)" HeaderText="Base Total" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.ItemDiscountAmount)" HeaderText="Item Disc" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalAfterItemDiscount)" HeaderText="After Disc" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalInclusiveTaxAmount)" HeaderText="Incl. Tax" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalExtraTaxAmount)" HeaderText="Extra Tax" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalAfterTax)" HeaderText="Sub Total" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.OtherChargesPercent)" HeaderText="Other Charges %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.OtherChargesAmount)" HeaderText="Other Charges" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CashDiscountPercent)" HeaderText="Cash Disc %" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CashDiscountAmount)" HeaderText="Cash Disc" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.RoundOffAmount)" HeaderText="Round Off" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.TotalAmount)" HeaderText="Total" Visible="@(_showAllColumns && !_showSummary)" TotalColumn="true" />

						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.Remarks)" HeaderText="Remarks" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.FinancialAccountingTransactionNo)" HeaderText="Accounting Transaction No" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CreatedByName)" HeaderText="Created By" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CreatedAt)" HeaderText="Created At" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.CreatedFromPlatform)" HeaderText="Created Platform" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.LastModifiedByUserName)" HeaderText="Modified By" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.LastModifiedAt)" HeaderText="Modified At" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.LastModifiedFromPlatform)" HeaderText="Modified Platform" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(PurchaseItemOverviewModel.MasterStatus)" Visible="@(_showDeleted && !_showSummary)" StatusColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />