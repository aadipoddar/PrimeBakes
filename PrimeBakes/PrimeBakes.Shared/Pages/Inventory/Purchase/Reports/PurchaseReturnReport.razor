										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnOverviewModel.CashDiscountAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
