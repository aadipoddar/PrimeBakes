												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnOverviewModel.ItemDiscountAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
