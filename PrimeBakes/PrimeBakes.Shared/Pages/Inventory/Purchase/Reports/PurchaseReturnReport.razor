											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseReturnOverviewModel.TotalQuantity)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
