											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.TotalAfterTax)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
