											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.TotalAmount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
