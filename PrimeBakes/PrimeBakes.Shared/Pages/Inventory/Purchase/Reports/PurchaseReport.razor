											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-debit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-debit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-debit">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.TotalAfterItemDiscount)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
