												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.OtherChargesAmount)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.OtherChargesAmount)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.CashDiscountAmount)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-discount">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-discount">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-discount">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.RoundOffAmount)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(PurchaseOverviewModel.TotalAmount)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(PurchaseOverviewModel.TransactionNo)" HeaderText="Trans No"
										Width="170" Visible="@(!_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.ChallanNo)" HeaderText="Challan No" Width="170"
										Visible="@(!_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.TransactionDateTime)" HeaderText="Date"
										Width="150" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="@(!_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.CompanyName)" HeaderText="Company" Width="180"
										Visible="@(_showAllColumns && !_showSummary && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.PartyName)" HeaderText="Party" Width="200"
										Visible="@(_selectedParty is null || _selectedParty.Id <= 0)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.FinancialYear)" HeaderText="Financial Year"
										Width="150" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.TotalItems)" HeaderText="Items" Width="100"
										TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.TotalQuantity)" HeaderText="Quantity"
										Width="120" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.BaseTotal)" HeaderText="Base Total" Width="130"
										Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.ItemDiscountAmount)" HeaderText="Disc"
										Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns">
								<Template>
									@{
										var item = (context as PurchaseOverviewModel);
										<span class="grid-discount">@item.ItemDiscountAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseOverviewModel.TotalAfterItemDiscount)"
										HeaderText="After Disc" Width="140" Format="N2" TextAlign="TextAlign.Right"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.TotalInclusiveTaxAmount)"
										HeaderText="Incl. Tax" Width="120" Format="N2" TextAlign="TextAlign.Center"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.TotalExtraTaxAmount)" HeaderText="Extra Tax"
										Width="120" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.TotalAfterTax)" HeaderText="Sub Total"
										Width="150" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.OtherChargesPercent)"
										HeaderText="Other Charges %" Width="150" Format="N2" TextAlign="TextAlign.Center"
										Visible="@(!_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.OtherChargesAmount)" HeaderText="Other Charges"
										Width="140" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.CashDiscountPercent)" HeaderText="Cash Disc %"
										Width="150" Format="N2" TextAlign="TextAlign.Center" Visible="@(!_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.CashDiscountAmount)" HeaderText="Cash Disc"
										Width="140" TextAlign="TextAlign.Right" Visible="_showAllColumns">
								<Template>
									@{
										var item = (context as PurchaseOverviewModel);
										<span class="grid-discount">@item.CashDiscountAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseOverviewModel.RoundOffAmount)" HeaderText="Round Off"
										Width="120" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.TotalAmount)" HeaderText="Total" Width="150"
										TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as PurchaseOverviewModel);
										<span class="grid-total">@item.TotalAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseOverviewModel.Status)" HeaderText="Status" Width="110"
										Visible="@(_showDeleted && !_showSummary)" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as PurchaseOverviewModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(PurchaseOverviewModel.Remarks)" HeaderText="Remarks" Width="200"
										Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.CreatedByName)" HeaderText="Created By"
										Width="150" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.CreatedAt)" HeaderText="Created At" Width="160"
										Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.CreatedFromPlatform)"
										HeaderText="Created Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.LastModifiedByUserName)"
										HeaderText="Modified By" Width="150" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.LastModifiedAt)" HeaderText="Modified At"
										Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(PurchaseOverviewModel.LastModifiedFromPlatform)"
										HeaderText="Modified Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Purchase Transaction"
						  IdentifierLabel="Transaction No" IdentifierValue="@_deleteTransactionNo" Disabled="@_isProcessing"
						  OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Purchase Transaction"
						   IdentifierLabel="Transaction No" IdentifierValue="@_recoverTransactionNo" Disabled="@_isProcessing"
						   OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
