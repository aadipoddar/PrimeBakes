@using PrimeBakes.Library.Accounts.Masters.Models
@using PrimeBakes.Library.Inventory.RawMaterial.Models
@using PrimeBakes.Library.Inventory.Stock.Models

@attribute [Route(InventoryRouteNames.RawMaterialStockReport)]

<PageTitle>Raw Material Stock Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockAdjustment, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadStockSummary" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadStockSummary" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Raw Material Stock Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Stock Adjustment (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockAdjustment, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadStockSummary" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="ToggleDetailsView" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Raw Material Stock Adjustment (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockAdjustment, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material Stock Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material Stock Detail Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockDetailReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterial, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material Category" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialCategory, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="RawMaterialCategoryModel"
												Value="_selectedCategory"
												DataSource="@_categories"
												Placeholder="All Categories"
												Label="Category" Required="false"
												ValueChanged="OnCategoryChanged"
												FieldValue="@nameof(RawMaterialCategoryModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterialCategory" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<SfGrid @ref="_sfGrid" TValue="RawMaterialStockSummaryModel" DataSource="_stockSummary"
						AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.RawMaterialName)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByRate)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByAverageInRate)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByAverageOutRate)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.OpeningValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.TotalInValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.TotalOutValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.PurchaseValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.PurchaseReturnValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.KitchenIssueValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.KitchenProductionValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.SaleValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.SaleReturnValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.StockTransferValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.BillValue)" />
								<GridColumnAggregate Field="@nameof(RawMaterialStockSummaryModel.AdjustmentValue)" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialName)" HeaderText="Raw Material" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialCode)" HeaderText="Code" Visible="_showAllColumns" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialCategoryName)" HeaderText="Category" Visible="@(_showAllColumns || _selectedCategory is null || _selectedCategory.Id <= 0)" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.UnitOfMeasurement)" HeaderText="UOM" TextAlign="TextAlign.Center" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.OpeningStock)" HeaderText="Opening" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.InStock)" HeaderText="Stock In" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.OutStock)" HeaderText="Stock Out" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingStock)" HeaderText="Closing" NegativePositiveColumn="true" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.MonthlyStock)" HeaderText="Net Movement" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseStock)" HeaderText="Purchase" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseReturnStock)" HeaderText="Purchase Return" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenIssueStock)" HeaderText="Kitchen Issue" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenProductionStock)" HeaderText="Kitchen Production" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleStock)" HeaderText="Sale" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleReturnStock)" HeaderText="Sale Return" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.StockTransferStock)" HeaderText="Stock Transfer" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.BillStock)" HeaderText="Bill" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AdjustmentStock)" HeaderText="Adjustment" Visible="_showAllColumns" NegativePositiveColumn="true" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.Rate)" HeaderText="Rate" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByRate)" HeaderText="Closing Value" TotalColumn="true" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageInRate)" HeaderText="Avg In Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByAverageInRate)" HeaderText="Value at Avg In" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageOutRate)" HeaderText="Avg Out Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByAverageOutRate)" HeaderText="Value at Avg Out" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.RateVariance)" HeaderText="Rate Variance" Visible="_showAllColumns" NegativePositiveColumn="true" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.OpeningValue)" HeaderText="Opening Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.TotalInValue)" HeaderText="Total In Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.TotalOutValue)" HeaderText="Total Out Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseValue)" HeaderText="Purchase Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseReturnValue)" HeaderText="Purchase Return Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenIssueValue)" HeaderText="Kitchen Issue Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenProductionValue)" HeaderText="Kitchen Production Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleValue)" HeaderText="Sale Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleReturnValue)" HeaderText="Sale Return Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.StockTransferValue)" HeaderText="Stock Transfer Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.BillValue)" HeaderText="Bill Value" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AdjustmentValue)" HeaderText="Adjustment Value" Visible="_showAllColumns" NegativePositiveColumn="true" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseRate)" HeaderText="Last Purchase Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AveragePurchaseRate)" HeaderText="Avg Purchase Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseReturnRate)" HeaderText="Last Purchase Return Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AveragePurchaseReturnRate)" HeaderText="Avg Purchase Return Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastKitchenIssueRate)" HeaderText="Last Kitchen Issue Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageKitchenIssueRate)" HeaderText="Avg Kitchen Issue Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastKitchenProductionRate)" HeaderText="Last Kitchen Production Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageKitchenProductionRate)" HeaderText="Avg Kitchen Production Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastSaleRate)" HeaderText="Last Sale Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageSaleRate)" HeaderText="Avg Sale Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastSaleReturnRate)" HeaderText="Last Sale Return Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageSaleReturnRate)" HeaderText="Avg Sale Return Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastStockTransferRate)" HeaderText="Last Stock Transfer Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageStockTransferRate)" HeaderText="Avg Stock Transfer Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastBillRate)" HeaderText="Last Bill Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageBillRate)" HeaderText="Avg Bill Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastAdjustmentRate)" HeaderText="Last Adjustment Rate" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageAdjustmentRate)" HeaderText="Avg Adjustment Rate" Visible="_showAllColumns" NumericColumn="true" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageDailyConsumption)" HeaderText="Avg Daily Use" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.DaysOnHand)" HeaderText="Days On Hand" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.StockTurnoverRatio)" HeaderText="Turnover" Visible="_showAllColumns" NegativePositiveColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.TransactionCount)" HeaderText="Txns" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseDate)" HeaderText="Last Purchase" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="_showAllColumns" />
						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.LastTransactionDate)" HeaderText="Last Transaction" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="_showAllColumns" />

						<CustomGridColumn Field="@nameof(RawMaterialStockSummaryModel.IsNegativeStock)" HeaderText="Negative?" TextAlign="TextAlign.Center" Visible="_showAllColumns" DisplayAsCheckBox="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
