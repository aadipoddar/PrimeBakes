@attribute [Route(PageRouteNames.RawMaterialStockReport)]

@using PrimeBakesLibrary.Models.Accounts.Masters
@using PrimeBakesLibrary.Models.Operations
@using PrimeBakesLibrary.Models.Inventory
@using PrimeBakesLibrary.Models.Inventory.Stock

<PageTitle>Raw Material Stock Report - Prime Bakes</PageTitle>

@if (_isLoading || _user is null)
{
	<AnimatedLoader Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="Raw Material Stock Report">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
										   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected"
								OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Refresh Data (Ctrl + R / F5)" IconCss="e-icons e-refresh" Id="Refresh"
										  Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="View" IconCss="e-icons e-table">
							<MenuItems>
								<MenuItem Text="@(_showAllColumns ? "Show Less (Ctrl + W)" : "All Columns (Ctrl + W)")"
										  IconCss="e-icons e-grid-view" Id="ToggleColumnsView" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDetails ? "Hide Details (Ctrl + Q)" : "Transaction Details (Ctrl + Q)")"
										  IconCss="e-icons e-chart" Id="ToggleDetailsView" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Periods" IconCss="e-icons e-clock">
							<MenuItems>
								<MenuItem Text="Today" Id="PeriodToday" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Day" Id="PeriodPreviousDay" Disabled="@_isProcessing" />
								<MenuItem Text="Next Day" Id="PeriodNextDay" Disabled="@_isProcessing" />
								<MenuItem Text="Current Month" Id="PeriodCurrentMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Month" Id="PeriodPreviousMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Next Month" Id="PeriodNextMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Current FY" Id="PeriodCurrentFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Previous FY" Id="PeriodPreviousFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Next FY" Id="PeriodNextFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="All Time" Id="PeriodAllTime" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="View (Ctrl + O)" IconCss="e-icons e-eye" Id="ViewSelected"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="DownloadSelectedPdf"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel"
										  Id="DownloadSelectedExcel" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Delete (Del)" IconCss="e-icons e-trash" Id="DeleteSelected"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Filters Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
						</svg>
						<h2 class="section-title">Filters</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="filters-container">
						<div class="filters-grid">
							<!-- Date Range -->
							<div class="form-field">
								<label class="field-label">Date Range</label>
								<SfDateRangePicker CssClass="custom-daterange" StartDate="_fromDate" EndDate="_toDate"
												   TValue="DateTime" Format="dd/MM/yyyy" AllowEdit="true" Placeholder="Select date range">
									<DateRangePickerEvents TValue="DateTime" ValueChange="OnDateRangeChanged" />
								</SfDateRangePicker>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Report Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<line x1="8" y1="6" x2="21" y2="6" />
							<line x1="8" y1="12" x2="21" y2="12" />
							<line x1="8" y1="18" x2="21" y2="18" />
							<line x1="3" y1="6" x2="3.01" y2="6" />
							<line x1="3" y1="12" x2="3.01" y2="12" />
							<line x1="3" y1="18" x2="3.01" y2="18" />
						</svg>
						<h2 class="section-title">Raw Material Stock Summary</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid ID="_sfStockGrid" @ref="_sfStockGrid" TValue="RawMaterialStockSummaryModel"
							DataSource="_stockSummary" AllowTextWrap="true" AllowPaging="true" AllowSorting="true"
							AllowResizing="true" AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true"
							GridLines="GridLine.Horizontal" CssClass="professional-grid" AllowGrouping="true"
							Toolbar="@(new List<string>() { "Search" })">

						<GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialName)"
														 Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.OpeningStock)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseStock)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.SaleStock)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.MonthlyStock)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingStock)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValue)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.WeightedAverageValue)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseValue)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialCode)" HeaderText="Code"
										Width="120" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialName)"
										HeaderText="Raw Material" Width="250" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialCategoryName)"
										HeaderText="Category" Width="180" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.UnitOfMeasurement)" HeaderText="UOM"
										Width="100" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.OpeningStock)"
										HeaderText="Opening Stock" Width="150" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseStock)" HeaderText="Purchase"
										Width="130" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleStock)" HeaderText="Sale"
										Width="130" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.MonthlyStock)"
										HeaderText="Monthly Stock" Width="150" Format="N2" TextAlign="TextAlign.Right"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingStock)"
										HeaderText="Closing Stock" Width="150" Format="N2" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as RawMaterialStockSummaryModel);
										<span
										class="@(item.ClosingStock < 0 ? "grid-debit" : "")">@item.ClosingStock.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.Rate)" HeaderText="Rate" Width="120"
										Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValue)"
										HeaderText="Closing Value" Width="150" Format="N2" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as RawMaterialStockSummaryModel);
										<span class="grid-total">@item.ClosingValue.ToString("N2")</span>
									}
								</Template>
							</GridColumn>

							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AveragePrice)" HeaderText="Avg Price"
										Width="130" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.WeightedAverageValue)"
										HeaderText="Weighted Avg Value" Width="180" Format="N2" TextAlign="TextAlign.Right"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchasePrice)"
										HeaderText="Last Purchase Price" Width="170" Format="N2" TextAlign="TextAlign.Right"
										Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseValue)"
										HeaderText="Last Purchase Value" Width="180" Format="N2" TextAlign="TextAlign.Right"
										Visible="_showAllColumns" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>

			<!-- Stock Details Grid Section (Visible when _showDetails is true) -->
			@if (_showDetails)
			{
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
								 stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<polyline points="14 2 14 8 20 8"></polyline>
								<line x1="16" y1="13" x2="8" y2="13"></line>
								<line x1="16" y1="17" x2="8" y2="17"></line>
								<polyline points="10 9 9 9 8 9"></polyline>
							</svg>
							<h2 class="section-title">Stock Details (Transaction Level)</h2>
						</div>
					</div>
					<div class="section-body grid-body">
						<SfGrid ID="_sfStockDetailsGrid" @ref="_sfStockDetailsGrid" TValue="RawMaterialStockDetailsModel"
								DataSource="_stockDetails" AllowTextWrap="true" AllowPaging="true" AllowSorting="true"
								AllowResizing="true" AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true"
								GridLines="GridLine.Horizontal" CssClass="professional-grid" AllowGrouping="true"
								ContextMenuItems="@_detailsGridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

							<GridEvents TValue="RawMaterialStockDetailsModel"
										ContextMenuItemClicked="OnDetailsGridContextMenuItemClicked" />

							<GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
							<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(RawMaterialStockDetailsModel.RawMaterialName)"
															 Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Transactions: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
											<GroupFooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Transactions: @aggregate.Count</strong>
												</div>
											</GroupFooterTemplate>
											<GroupCaptionTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Transactions: @aggregate.Count</strong>
												</div>
											</GroupCaptionTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(RawMaterialStockDetailsModel.Quantity)"
															 Type="AggregateType.Sum" Format="N2">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													<div><strong>@aggregate.Sum</strong></div>
												}
											</FooterTemplate>
											<GroupFooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													<div><strong>@aggregate.Sum</strong></div>
												}
											</GroupFooterTemplate>
											<GroupCaptionTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													<div><strong>@aggregate.Sum</strong></div>
												}
											</GroupCaptionTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(RawMaterialStockDetailsModel.Total)"
															 Type="AggregateType.Sum" Format="N2">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var total = aggregate?.Sum is null ? 0 : Convert.ToDecimal(aggregate.Sum);
													<div><strong
														class="@(total < 0 ? "grid-debit" : "grid-credit")">@total.ToString("N2")</strong>
													</div>
												}
											</FooterTemplate>
											<GroupFooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var total = aggregate?.Sum is null ? 0 : Convert.ToDecimal(aggregate.Sum);
													<div><strong
														class="@(total < 0 ? "grid-debit" : "grid-credit")">@total.ToString("N2")</strong>
													</div>
												}
											</GroupFooterTemplate>
											<GroupCaptionTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var total = aggregate?.Sum is null ? 0 : Convert.ToDecimal(aggregate.Sum);
													<div><strong
														class="@(total < 0 ? "grid-debit" : "grid-credit")">@total.ToString("N2")</strong>
													</div>
												}
											</GroupCaptionTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.TransactionDateTime)" HeaderText="Date"
											Width="130" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" />
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.TransactionNo)"
											HeaderText="Transaction No" Width="180" />
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.Type)" HeaderText="Type" Width="150">
									<Template>
										@{
											var item = (context as RawMaterialStockDetailsModel);
											<span class="transaction-type transaction-type-@item.Type.ToLower().Replace(" ", "-")">
												@item.Type
											</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.RawMaterialCode)" HeaderText="Code"
											Width="120" />
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.RawMaterialName)"
											HeaderText="Raw Material" Width="250" />
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.Quantity)" HeaderText="Qty" Width="130"
											Format="N2" TextAlign="TextAlign.Right">
									<Template>
										@{
											var item = (context as RawMaterialStockDetailsModel);
											<span class="@(item.Quantity < 0 ? "grid-debit" : "grid-credit")">
												@item.Quantity.ToString("N2")
											</span>
										}
									</Template>
								</GridColumn>
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.NetRate)" HeaderText="Rate" Width="120"
											Format="N2" TextAlign="TextAlign.Right" />
								<GridColumn Field="@nameof(RawMaterialStockDetailsModel.Total)" HeaderText="Total" Width="140"
											Format="N2" TextAlign="TextAlign.Right">
									<Template>
										@{
											var item = (context as RawMaterialStockDetailsModel);
											<span class="@(item.Total < 0 ? "grid-debit" : "grid-credit")">
												@item.Total.ToString("N2")
											</span>
										}
									</Template>
								</GridColumn>
							</GridColumns>
						</SfGrid>
					</div>
				</div>
			}

		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Stock Adjustment"
						  IdentifierLabel="Transaction No" IdentifierValue="@_deleteTransactionNo" IsPermanentDelete="true"
						  Disabled="@_isProcessing" OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<ToastNotification @ref="_toastNotification" />

