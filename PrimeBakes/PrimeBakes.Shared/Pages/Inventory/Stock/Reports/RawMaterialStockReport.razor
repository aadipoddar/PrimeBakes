@using PrimeBakesLibrary.Accounts.Masters.Models
@using PrimeBakesLibrary.Inventory.RawMaterial.Models
@using PrimeBakesLibrary.Inventory.Stock.Models

@attribute [Route(InventoryRouteNames.RawMaterialStockReport)]

<PageTitle>Raw Material Stock Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockAdjustment, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadStockSummary" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadStockSummary" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Raw Material Stock Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Stock Adjustment (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockAdjustment, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadStockSummary" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="ToggleDetailsView" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Raw Material Stock Adjustment (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockAdjustment, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material Stock Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material Stock Detail Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialStockDetailReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterial, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Raw Material Category" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RawMaterialCategory, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="RawMaterialCategoryModel"
												Value="_selectedCategory"
												DataSource="@_categories"
												Placeholder="All Categories"
												Label="Category" Required="false"
												ValueChanged="OnCategoryChanged"
												FieldValue="@nameof(RawMaterialCategoryModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterialCategory" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" TValue="RawMaterialStockSummaryModel" DataSource="_stockSummary"
							AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByRate)" Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialName)" HeaderText="Raw Material" Width="220" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialCode)" HeaderText="Code" Width="120" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.RawMaterialCategoryName)" HeaderText="Category" Width="170" Visible="@(_showAllColumns || _selectedCategory is null || _selectedCategory.Id <= 0)" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.UnitOfMeasurement)" HeaderText="UOM" Width="90" TextAlign="TextAlign.Center" />

							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.OpeningStock)" HeaderText="Opening" Width="200" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.InStock)" HeaderText="Stock In" Width="200" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.OutStock)" HeaderText="Stock Out" Width="200" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingStock)" HeaderText="Closing" Width="200" Format="N2" TextAlign="TextAlign.Right" />

							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.MonthlyStock)" HeaderText="Net Movement" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseStock)" HeaderText="Purchase" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseReturnStock)" HeaderText="Purchase Return" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenIssueStock)" HeaderText="Kitchen Issue" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenProductionStock)" HeaderText="Kitchen Production" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleStock)" HeaderText="Sale" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleReturnStock)" HeaderText="Sale Return" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.StockTransferStock)" HeaderText="Stock Transfer" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.BillStock)" HeaderText="Bill" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AdjustmentStock)" HeaderText="Adjustment" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.Rate)" HeaderText="Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByRate)" HeaderText="Closing Value" Width="200" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.ClosingValueByRate.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageInRate)" HeaderText="Avg In Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByAverageInRate)" HeaderText="Value at Avg In" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageOutRate)" HeaderText="Avg Out Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.ClosingValueByAverageOutRate)" HeaderText="Value at Avg Out" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.RateVariance)" HeaderText="Rate Variance" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.OpeningValue)" HeaderText="Opening Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.TotalInValue)" HeaderText="Total In Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.TotalOutValue)" HeaderText="Total Out Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseValue)" HeaderText="Purchase Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.PurchaseReturnValue)" HeaderText="Purchase Return Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenIssueValue)" HeaderText="Kitchen Issue Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.KitchenProductionValue)" HeaderText="Kitchen Production Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleValue)" HeaderText="Sale Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.SaleReturnValue)" HeaderText="Sale Return Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.StockTransferValue)" HeaderText="Stock Transfer Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.BillValue)" HeaderText="Bill Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AdjustmentValue)" HeaderText="Adjustment Value" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseRate)" HeaderText="Last Purchase Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AveragePurchaseRate)" HeaderText="Avg Purchase Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseReturnRate)" HeaderText="Last Purchase Return Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AveragePurchaseReturnRate)" HeaderText="Avg Purchase Return Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastKitchenIssueRate)" HeaderText="Last Kitchen Issue Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageKitchenIssueRate)" HeaderText="Avg Kitchen Issue Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastKitchenProductionRate)" HeaderText="Last Kitchen Production Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageKitchenProductionRate)" HeaderText="Avg Kitchen Production Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastSaleRate)" HeaderText="Last Sale Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageSaleRate)" HeaderText="Avg Sale Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastSaleReturnRate)" HeaderText="Last Sale Return Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageSaleReturnRate)" HeaderText="Avg Sale Return Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastStockTransferRate)" HeaderText="Last Stock Transfer Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageStockTransferRate)" HeaderText="Avg Stock Transfer Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastBillRate)" HeaderText="Last Bill Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageBillRate)" HeaderText="Avg Bill Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastAdjustmentRate)" HeaderText="Last Adjustment Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageAdjustmentRate)" HeaderText="Avg Adjustment Rate" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />

							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.AverageDailyConsumption)" HeaderText="Avg Daily Use" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.DaysOnHand)" HeaderText="Days On Hand" Width="200" Format="N1" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.StockTurnoverRatio)" HeaderText="Turnover" Width="200" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.TransactionCount)" HeaderText="Txns" Width="200" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastPurchaseDate)" HeaderText="Last Purchase" Width="200" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.LastTransactionDate)" HeaderText="Last Transaction" Width="200" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(RawMaterialStockSummaryModel.IsNegativeStock)" HeaderText="Negative?" Width="200" TextAlign="TextAlign.Center" Visible="_showAllColumns">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="@(item.IsNegativeStock ? "grid-debit" : string.Empty)">@(item.IsNegativeStock ? "Yes" : "No")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
