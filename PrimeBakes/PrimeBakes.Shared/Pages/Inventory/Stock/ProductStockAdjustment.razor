@using PrimeBakes.Library.Inventory.Stock.Models
@using PrimeBakes.Library.Operations.Location
@using PrimeBakes.Library.Store.Product.Models

@attribute [Route(InventoryRouteNames.ProductStockAdjustment)]

<PageTitle>Product Stock Adjustment - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _itemAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.ProductStockReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Create Product Stock Adjustment">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Product Stock Adjustment (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.ProductStockAdjustment, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Product Stock Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.ProductStockReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<!-- Transaction -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Transaction</h2>
				</div>

				<div class="section-body">
					<div class="form-grid">
						<!-- Transaction Date and Financial Year -->
						<div class="form-field">
							<CustomDatePicker @ref="_firstFocus"
											  Value="_transactionDateTime"
											  ShowFinancialYear="false"
											  ValueChanged="OnTransactionDateChanged" />
						</div>

						<!-- Outlet / Location -->
						<div class="form-field">
							<CustomAutoComplete T="LocationModel"
												Value="_selectedLocation"
												DataSource="@_locations"
												Placeholder="Select Outlet"
												Label="Outlet / Location"
												ValueChanged="OnLocationChanged"
												FieldValue="@nameof(LocationModel.Name)"
												AddNewRoute="@OperationRouteNames.Location" />
						</div>

						<!-- Transaction No -->
						<div class="form-field">
							<CustomTextField @bind-Value="_transactionNo"
											 Label="Transaction No"
											 Placeholder="Transaction No"
											 ReadOnly="true"
											 TabIndex="-1" />
						</div>
					</div>
				</div>
			</div>

			<!-- Add to Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Add Items to Cart</h2>
				</div>

				<div class="section-body">
					<div class="cart-input-row">
						<!-- Item Selection -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete @ref="_itemAutoComplete" T="ProductLocationOverviewModel"
												Value="_selectedProduct"
												DataSource="@_products"
												Placeholder="Select Item"
												Label="Item Name (Ctrl + G)"
												ValueChanged="OnItemChanged"
												FieldValue="@nameof(ProductLocationOverviewModel.Name)"
												AddNewRoute="@StoreRouteNames.Product"
												OpenOnFocus="false" />
						</div>

						<!-- Current Stock -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Stock"
												Label="Current Stock"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- New Quantity -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Quantity"
												ValueChanged="OnItemQuantityChanged"
												Label="New Qty"
												Placeholder="0.00" />
						</div>

						<!-- Rate -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Rate"
												Label="Rate"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Total -->
						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Total"
												Label="Total"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<!-- Add Button -->
						<div class="cart-field cart-field-action">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Cart</h2>
				</div>

				<div class="section-body grid-body">
					<SfGrid @ref="_sfCartGrid" DataSource="_cart"
							AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_cartGridContextMenuItems" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridEvents TValue="ProductStockAdjustmentCartModel" ContextMenuItemClicked="OnCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(ProductStockAdjustmentCartModel.ProductName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(ProductStockAdjustmentCartModel.Stock)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(ProductStockAdjustmentCartModel.Quantity)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(ProductStockAdjustmentCartModel.Total)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(ProductStockAdjustmentCartModel.ProductName)" HeaderText="Item Name" Width="250" />
							<GridColumn Field="@nameof(ProductStockAdjustmentCartModel.Stock)" HeaderText="Current Stock" Width="130" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(ProductStockAdjustmentCartModel.Quantity)" HeaderText="New Qty" Width="120" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(ProductStockAdjustmentCartModel.Rate)" HeaderText="Rate" Width="110" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(ProductStockAdjustmentCartModel.Total)" HeaderText="Total" Width="150" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Total.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
