@using PrimeBakes.Library.Inventory.RawMaterial.Models
@using PrimeBakes.Library.Inventory.Recipe.Models
@using PrimeBakes.Library.Store.Product.Models

@attribute [Route(InventoryRouteNames.RecipeItemReport)]

<PageTitle>Recipe Item Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Recipe, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadItemOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadItemOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ViewSelectedRecipe" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteSelectedTransaction" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Recipe Item Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Recipe (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Recipe, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadItemOverviews" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Recipe (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Recipe, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Recipe Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RecipeReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Recipe Item Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RecipeItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="View Recipe (Alt + O)" OnClick="ViewSelectedRecipe" />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Delete (Del)" OnClick="DeleteSelectedTransaction" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<div class="form-field">
							<CustomDatePicker @ref="_firstFocus"
											  Value="_effectiveDateTime"
											  Label="Effective Date"
											  ShowFinancialYear="false"
											  AddNewRoute="@null"
											  ValueChanged="OnEffectiveDateChanged" />
						</div>

						<div class="form-field">
							<CustomDatePicker Value="_costAsOnDateTime"
											  Label="Cost As On Date (Ctrl + F)"
											  ShowFinancialYear="false"
											  AddNewRoute="@null"
											  ValueChanged="OnCostAsOnDateChanged" />
						</div>

						<!-- Deduct -->
						<div class="form-field">
							<CustomAutoComplete T="YesNoFilterOption"
												Value="_selectedDeduct"
												DataSource="@YesNoFilterOptions.YesNo"
												Placeholder="All"
												Label="Deduct on Sale" Required="false"
												ValueChanged="OnDeductFilterChanged"
												FieldValue="@nameof(YesNoFilterOption.Name)" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="RawMaterialModel"
												Value="_selectedRawMaterial"
												DataSource="@_rawMaterials"
												Placeholder="All Raw Materials"
												Label="Raw Material" Required="false"
												ValueChanged="OnRawMaterialChanged"
												FieldValue="@nameof(RawMaterialModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterial" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="RawMaterialCategoryModel"
												Value="_selectedRawMaterialCategory"
												DataSource="@_rawMaterialCategories"
												Placeholder="All Categories"
												Label="Category" Required="false"
												ValueChanged="OnRawMaterialCategoryChanged"
												FieldValue="@nameof(RawMaterialCategoryModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterialCategory" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="ProductModel"
												Value="_selectedProduct"
												DataSource="@_products"
												Placeholder="All Products"
												Label="Recipe (Product)" Required="false"
												ValueChanged="OnProductChanged"
												FieldValue="@nameof(ProductModel.Name)"
												AddNewRoute="@StoreRouteNames.Product" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<SfGrid @ref="_sfGrid" TValue="RecipeItemOverviewModel" DataSource="_itemOverviews"
						AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="RecipeItemOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridColumnAggregate Field="@nameof(RecipeItemOverviewModel.ItemName)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(RecipeItemOverviewModel.Amount)" CustomColor="grid-total" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.ItemName)" HeaderText="Raw Material" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.ItemCode)" HeaderText="Code" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.ItemCategoryName)" HeaderText="Category" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.UnitOfMeasurement)" HeaderText="UOM" TextAlign="TextAlign.Center" />

						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.Quantity)" HeaderText="Quantity" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.Rate)" HeaderText="Rate" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.Amount)" HeaderText="Amount" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.PerUnit)" HeaderText="Per Unit" NumericColumn="true" />

						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.ProductName)" HeaderText="Recipe (Product)" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.RecipeQuantity)" HeaderText="Recipe Qty" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.Deduct)" HeaderText="Deduct on Sale" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.FromDate)" HeaderText="Effective Date" Format="dd/MM/yy" Type="ColumnType.DateOnly" TextAlign="TextAlign.Center" />

						<CustomGridColumn Field="@nameof(RecipeItemOverviewModel.MasterStatus)" Visible="@_showDeleted" StatusColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
