@using PrimeBakesLibrary.Inventory.RawMaterial.Models
@using PrimeBakesLibrary.Inventory.Recipe.Models
@using PrimeBakesLibrary.Store.Product.Models

@attribute [Route(InventoryRouteNames.Recipe)]

<PageTitle>Recipe - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RecipeReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _itemAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@($"Recipe{(_selectedProduct is null ? "" : $" - {_selectedProduct.Name}")}")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Recipe (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || _recipe is null || _recipe.Id == 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || _recipe is null || _recipe.Id == 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Recipe (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Recipe, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Recipe Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.RecipeReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Product Selection Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10" />
							<line x1="2" y1="12" x2="22" y2="12" />
							<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
						</svg>
						<h2 class="section-title">Select Product</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- Product -->
						<div class="form-field">
							<CustomAutoComplete @ref="_firstFocus" T="ProductLocationOverviewModel" Value="_selectedProduct" DataSource="@_products" Placeholder="Select a Product" Label="Product (Ctrl + F)" ValueChanged="OnProductChanged"
												FieldValue="@nameof(ProductLocationOverviewModel.Name)" AddNewRoute="@StoreRouteNames.Product" />
						</div>

						<!-- Quantity -->
						<div class="form-field">
							<CustomNumericField T="decimal" Value="_recipe.Quantity" ValueChanged="OnRecipeQuantityChanged" Label="Quantity" Placeholder="Enter Quantity" Min="0" />
						</div>

						<!-- Deduct -->
						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_recipe.Deduct" Label="Deduct on Sale" />
							</div>
						</div>

						<!-- Recipe Date -->
						<div class="form-field">
							<CustomDatePicker Value="_recipeDateTime" Label="Recipe Date" ShowFinancialYear="false" AddNewRoute="@null" ValueChanged="OnRecipeDateChanged" />
						</div>
					</div>
				</div>
			</div>

			<!-- Add Raw Material to Recipe Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Raw Material to Recipe</h2>
					</div>
				</div>
				<div class="section-body">
					<!-- Single Row: Raw Material and Quantity -->
					<div class="cart-input-row">
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete @ref="_itemAutoComplete" T="RawMaterialModel" @bind-Value="_selectedRawMaterial" DataSource="@_rawMaterials" Placeholder="Select Raw Material" Label="Raw Material (Ctrl + G)"
												FieldValue="@nameof(RawMaterialModel.Name)" AddNewRoute="@InventoryRouteNames.RawMaterial" OpenOnFocus="false" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal" @bind-Value="_selectedCart.Quantity" Label="Quantity" Placeholder="0.00" Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal" Value="@(_selectedRawMaterial?.Rate ?? 0)" Label="Rate" Placeholder="0.00" ReadOnly="true" Required="false" TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal" Value="@(_selectedCart.Quantity * (_selectedRawMaterial?.Rate ?? 0))" Label="Amount" Placeholder="0.00" ReadOnly="true" Required="false" TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal" Value="@(_recipe.Quantity > 0 ? _selectedCart.Quantity * (_selectedRawMaterial?.Rate ?? 0) / _recipe.Quantity : 0m)" Label="Per Unit" Placeholder="0.00" ReadOnly="true" Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field cart-field-action">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Recipe Items Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Recipe Items</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfCartGrid" DataSource="_recipeItems" AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true" AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_recipeGridContextMenuItems">

						<GridEvents TValue="RecipeItemCartModel" ContextMenuItemClicked="OnRecipeGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(RecipeItemCartModel.ItemName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RecipeItemCartModel.Quantity)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RecipeItemCartModel.Amount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RecipeItemCartModel.PerUnit)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(RecipeItemCartModel.ItemName)" HeaderText="Raw Material Name" Width="250" />
							<GridColumn Field="@nameof(RecipeItemCartModel.Quantity)" HeaderText="Quantity" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(RecipeItemCartModel.Rate)" HeaderText="Rate" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(RecipeItemCartModel.Amount)" HeaderText="Amount" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(RecipeItemCartModel.PerUnit)" HeaderText="Per Unit" Width="150" TextAlign="TextAlign.Right" Format="N2" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />