@attribute [Route(PageRouteNames.Recipe)]

@using PrimeBakesLibrary.Models.Inventory;
@using PrimeBakesLibrary.Models.Operations;
@using PrimeBakesLibrary.Models.Store.Product;

<PageTitle>Recipe - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="OnSaveButtonClick" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="DownloadPdfInvoice" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="DownloadExcelInvoice" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfItemAutoComplete.FocusAsync()" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" />

@if (_isLoading)
{
	<AnimatedLoader Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="Product Recipe Management">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300" Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewRecipe" Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveRecipe" Disabled="@_isProcessing" />
								<MenuItem Text="Delete Recipe" IconCss="e-icons e-trash" Id="DeleteRecipe" Disabled="@(_isProcessing || _recipe is null || _recipe.Id == 0)" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="ExportPdfInvoice" Disabled="@(_isProcessing || _recipe is null || _recipe.Id == 0)" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel" Id="ExportExcelInvoice" Disabled="@(_isProcessing || _recipe is null || _recipe.Id == 0)" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit Item (Insert)" IconCss="e-icons e-edit" Id="EditSelectedRecipeItem" Disabled="@_isProcessing" />
								<MenuItem Text="Delete Item (Del)" IconCss="e-icons e-trash" Id="DeleteSelectedRecipeItem" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Product Selection Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10" />
							<line x1="2" y1="12" x2="22" y2="12" />
							<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
						</svg>
						<h2 class="section-title">Select Product</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- Product -->
						<div class="form-field">
							<AutoCompleteWithAdd TItem="ProductLocationOverviewModel" TValue="ProductLocationOverviewModel"
												 Value="@_selectedProduct" DataSource="@_products" Placeholder="Select a Product"
												 Label="Product" ValueChange="OnProductChanged"
												 FieldValue="@nameof(ProductLocationOverviewModel.Name)" AddNewRoute="@PageRouteNames.Product" />
						</div>

						<!-- Quantity -->
						<div class="form-field">
							<label class="field-label">
								Quantity <span class="required">*</span>
							</label>
							<SfNumericTextBox @bind-Value="_recipe.Quantity" Placeholder="Enter Quantity" Min="0"
											  FloatLabelType="FloatLabelType.Never" CssClass="custom-numeric" />
						</div>

						<!-- Deduct -->
						<div class="form-field">
							<label class="field-label">Deduct on Sale</label>
							<div class="checkbox-wrapper">
								<SfCheckBox @bind-Checked="_recipe.Deduct" Label="Deduct" CssClass="custom-checkbox" />
							</div>
						</div>

						<!-- Recipe Date -->
						<div class="form-field">
							<DatePickerWithAdd @bind-Value="_recipeDateTime" Label="Recipe Date" ValueChange="OnRecipeDateChanged" />
						</div>
					</div>
				</div>
			</div>

			<!-- Add Raw Material to Recipe Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Raw Material to Recipe</h2>
					</div>
				</div>
				<div class="section-body">
					<!-- Single Row: Raw Material and Quantity -->
					<div class="cart-input-row">
						<div class="cart-field cart-field-wide">
							<AutoCompleteWithAdd @ref="_sfItemAutoComplete" @bind-Value="_selectedRawMaterial" TValue="RawMaterialModel" TItem="RawMaterialModel" DataSource="@_rawMaterials" Placeholder="Select Raw Material" Label="Raw Material"
												 FieldValue="@nameof(RawMaterialModel.Name)" AddNewRoute="@PageRouteNames.RawMaterial" />
						</div>

						<div class="cart-field">
							<label class="cart-label">Quantity <span class="required">*</span></label>
							<SfNumericTextBox @bind-Value="_selectedCart.Quantity" TValue="decimal" Min="0" ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never" CssClass="custom-numeric editable-field" />
						</div>

						<div class="cart-field">
							<label class="cart-label">Rate <span class="required">*</span></label>
							<SfNumericTextBox Value="@(_rawMaterials.FirstOrDefault(r => r.Id == _selectedRawMaterial?.Id)?.Rate ?? 0)"
											  TValue="decimal" Readonly="true"
											  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
											  CssClass="custom-numeric readonly-field" TabIndex="-1" />
						</div>

						<div class="cart-field">
							<label class="cart-label">Amount <span class="required">*</span></label>
							<SfNumericTextBox Value="@(_selectedCart.Quantity * (_rawMaterials.FirstOrDefault(r => r.Id == _selectedRawMaterial?.Id)?.Rate ?? 0))"
											  TValue="decimal" Readonly="true"
											  ShowSpinButton="false" Placeholder="0.00" FloatLabelType="FloatLabelType.Never"
											  CssClass="custom-numeric readonly-field" TabIndex="-1" />
						</div>

						<div class="cart-field">
							<label class="cart-label" style="visibility: hidden;">Action</label>
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" Disabled="_isProcessing" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Recipe Items Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Recipe Items</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfCartGrid" DataSource="_recipeItems" AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true" AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_recipeGridContextMenuItems">

						<GridEvents TValue="RecipeItemCartModel" ContextMenuItemClicked="OnRecipeGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(RecipeItemCartModel.ItemName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RecipeItemCartModel.Quantity)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(RecipeItemCartModel.Amount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="PerUnit" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(RecipeItemCartModel.ItemName)" HeaderText="Raw Material Name" Width="250" />
							<GridColumn Field="@nameof(RecipeItemCartModel.Quantity)" HeaderText="Quantity" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(RecipeItemCartModel.Rate)" HeaderText="Rate" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(RecipeItemCartModel.Amount)" HeaderText="Amount" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn HeaderText="Per Unit" Width="150" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = context as RecipeItemCartModel;
										var perUnit = _recipe.Quantity > 0 ? item.Amount / _recipe.Quantity : 0m;
									}
									@perUnit.ToString("N2")
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />
