@attribute [Route(PageRouteNames.KitchenProductionReport)]

@using PrimeBakesLibrary.Models.Accounts.Masters
@using PrimeBakesLibrary.Models.Operations
@using PrimeBakesLibrary.Models.Inventory.Kitchen

<PageTitle>Kitchen Production Report - Prime Bakes</PageTitle>

@if (_isLoading || _user is null)
{
	<AnimatedLoader Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="Kitchen Production Report">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
									   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected"
									OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
											  Disabled="@_isProcessing" />
								<MenuItem Text="Refresh Data (Ctrl + R / F5)" IconCss="e-icons e-refresh" Id="Refresh"
											  Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash"
											  Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showSummary ? "Hide Summary (Ctrl + W)" : "Show Summary (Ctrl + W)")" IconCss="e-icons e-chart"
											  Id="ToggleSummary" Disabled="@_isProcessing" />
								<MenuItem Text="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" IconCss="e-icons e-table"
											  Id="ToggleDetailsView" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
											  Disabled="@_isProcessing" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
											  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Open" IconCss="e-icons e-folder-open">
							<MenuItems>
								<MenuItem Text="Item Report (Ctrl + I)" Id="ItemReport" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Periods" IconCss="e-icons e-clock">
							<MenuItems>
								<MenuItem Text="Today" Id="PeriodToday" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Day" Id="PeriodPreviousDay" Disabled="@_isProcessing" />
								<MenuItem Text="Next Day" Id="PeriodNextDay" Disabled="@_isProcessing" />
								<MenuItem Text="Current Month" Id="PeriodCurrentMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Previous Month" Id="PeriodPreviousMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Next Month" Id="PeriodNextMonth" Disabled="@_isProcessing" />
								<MenuItem Text="Current FY" Id="PeriodCurrentFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Previous FY" Id="PeriodPreviousFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="Next FY" Id="PeriodNextFinancialYear" Disabled="@_isProcessing" />
								<MenuItem Text="All Time" Id="PeriodAllTime" Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="View (Ctrl + O)" IconCss="e-icons e-eye" Id="ViewSelected" Disabled="@(_isProcessing || _showSummary)" />
								<MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="DownloadSelectedPdf"
											  Disabled="@(_isProcessing || _showSummary)" />
								<MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel" Id="DownloadSelectedExcel"
											  Disabled="@(_isProcessing || _showSummary)" />
								<MenuItem Separator="true" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelected"
											  Disabled="@(_isProcessing || _showSummary)" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Filters Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
						</svg>
						<h2 class="section-title">Filters</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="filters-container">
						<div class="filters-grid">
							<!-- Date Range -->
							<div class="form-field">
								<label class="field-label">Date Range</label>
								<SfDateRangePicker CssClass="custom-daterange" StartDate="_fromDate" EndDate="_toDate"
												   TValue="DateTime" Format="dd/MM/yyyy" AllowEdit="true" Placeholder="Select date range">
									<DateRangePickerEvents TValue="DateTime" ValueChange="OnDateRangeChanged" />
								</SfDateRangePicker>
							</div>

							<!-- Company -->
							<div class="form-field">
								<label class="field-label">Company</label>
								<SfAutoComplete CssClass="custom-autocomplete" Value="@_selectedCompany"
												TValue="CompanyModel" TItem="CompanyModel" DataSource="@_companies"
												Placeholder="All Companies" AllowFiltering="true"
												FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains">
									<AutoCompleteEvents TItem="CompanyModel" TValue="CompanyModel"
														ValueChange="OnCompanyChanged" />
									<AutoCompleteFieldSettings Value="Name" />
								</SfAutoComplete>
							</div>

							<!-- Kitchen -->
							<div class="form-field">
								<label class="field-label">Kitchen</label>
								<SfAutoComplete CssClass="custom-autocomplete" Value="@_selectedKitchen"
												TValue="LocationModel" TItem="LocationModel" DataSource="@_kitchens"
												Placeholder="All Kitchens" AllowFiltering="true"
												FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains">
									<AutoCompleteEvents TItem="LocationModel" TValue="LocationModel"
														ValueChange="OnKitchenChanged" />
									<AutoCompleteFieldSettings Value="Name" />
								</SfAutoComplete>
							</div>
						</div>

					</div>
				</div>
			</div>

			<!-- Report Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<line x1="8" y1="6" x2="21" y2="6" />
							<line x1="8" y1="12" x2="21" y2="12" />
							<line x1="8" y1="18" x2="21" y2="18" />
							<line x1="3" y1="6" x2="3.01" y2="6" />
							<line x1="3" y1="12" x2="3.01" y2="12" />
							<line x1="3" y1="18" x2="3.01" y2="18" />
						</svg>
						<h2 class="section-title">Kitchen Production Transactions</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid ID="_sfGrid" @ref="_sfGrid" TValue="KitchenProductionOverviewModel"
							DataSource="_transactionOverviews" AllowTextWrap="true" AllowPaging="true" AllowSorting="true"
							AllowResizing="true" AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true"
							GridLines="GridLine.Horizontal" AllowGrouping="true" CssClass="professional-grid"
							ContextMenuItems="@_gridContextMenuItems"
							Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="KitchenProductionOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(KitchenProductionOverviewModel.TransactionNo)"
														 Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(KitchenProductionOverviewModel.TotalItems)"
														 Type="AggregateType.Sum" Format="N0">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(KitchenProductionOverviewModel.TotalQuantity)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div><strong>@aggregate.Sum</strong></div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(KitchenProductionOverviewModel.TotalAmount)"
														 Type="AggregateType.Sum" Format="N2">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</FooterTemplate>
										<GroupFooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupFooterTemplate>
										<GroupCaptionTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												<div class="aggregate-value aggregate-total">
													<strong>@aggregate.Sum</strong>
												</div>
											}
										</GroupCaptionTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.TransactionNo)" HeaderText="Trans No"
										Width="170" Visible="@(!_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.TransactionDateTime)"
										HeaderText="Date" Width="150" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="@(!_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.CompanyName)" HeaderText="Company"
										Width="180" Visible="@(_showAllColumns && !_showSummary && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.KitchenName)" HeaderText="Kitchen"
										Width="200" Visible="@(_selectedKitchen is null || _selectedKitchen.Id <= 0)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.FinancialYear)"
										HeaderText="Financial Year" Width="150" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.TotalItems)" HeaderText="Items"
										Width="100" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.TotalQuantity)" HeaderText="Qty"
										Width="120" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.TotalAmount)" HeaderText="Total"
										Width="150" TextAlign="TextAlign.Right">
								<Template>
									@{
										var item = (context as KitchenProductionOverviewModel);
										<span class="grid-total">@item.TotalAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.Status)" HeaderText="Status"
										Width="110" Visible="@(_showDeleted && !_showSummary)" TextAlign="TextAlign.Center">
								<Template>
									@{
										var item = (context as KitchenProductionOverviewModel);
										<span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.Remarks)" HeaderText="Remarks"
										Width="200" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.CreatedByName)"
										HeaderText="Created By" Width="150" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.CreatedAt)" HeaderText="Created At"
										Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.CreatedFromPlatform)"
										HeaderText="Created Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.LastModifiedByUserName)"
										HeaderText="Modified By" Width="150" Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.LastModifiedAt)"
										HeaderText="Modified At" Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
										Visible="@(_showAllColumns && !_showSummary)" />
							<GridColumn Field="@nameof(KitchenProductionOverviewModel.LastModifiedFromPlatform)"
										HeaderText="Modified Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Kitchen Production Transaction"
						  IdentifierLabel="Transaction No" IdentifierValue="@_deleteTransactionNo" IsPermanentDelete="true"
						  Disabled="@_isProcessing" OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Kitchen Production Transaction"
						   IdentifierLabel="Transaction No" IdentifierValue="@_recoverTransactionNo" Disabled="@_isProcessing"
						   OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
