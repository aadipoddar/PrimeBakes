@attribute [Route(PageRouteNames.KitchenIssueItemReport)]

@using PrimeBakesLibrary.Models.Accounts.Masters
@using PrimeBakesLibrary.Models.Operations
@using PrimeBakesLibrary.Models.Inventory.Kitchen

<PageTitle>Kitchen Issue Item Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateToTransactionPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" />
<MudBlazor.MudHotkey Key=JsKey.KeyW KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleSummary" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateToTransactionHistory" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ViewSelectedTransaction" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="DownloadSelectedPdfInvoice" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="DownloadSelectedExcelInvoice" />

@if (_isLoading || _user is null)
{
    <AnimatedLoader Visible="true" />
}
else
{
    <div class="page-shell">
        <Header Title="Kitchen Issue Item Report">
            <LeftContent>
                <SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
                    <MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
                                           Easing="ease" />
                    <MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected"
                                OnOpen='async () => await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0)' />
                    <MenuItems>
                        <MenuItem Text="File" IconCss="e-icons e-folder">
                            <MenuItems>
                                <MenuItem Text="New Transaction (Ctrl + N)" IconCss="e-icons e-plus" Id="NewTransaction"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Refresh Data (Ctrl + R / F5)" IconCss="e-icons e-refresh" Id="Refresh"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="@(_showSummary ? "Hide Summary (Ctrl + W)" : "Show Summary (Ctrl + W)")"
                                          IconCss="e-icons e-chart" Id="ToggleSummary" Disabled="@_isProcessing" />
                                <MenuItem Text="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")"
                                          IconCss="e-icons e-table" Id="ToggleDetailsView" Disabled="@_isProcessing" />
                                <MenuItem Separator="true" />
                                <MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
                                          Disabled="@_isProcessing" />
                            </MenuItems>
                        </MenuItem>
                        <MenuItem Text="Open" IconCss="e-icons e-folder-open">
                            <MenuItems>
                                <MenuItem Text="Transaction History Report (Ctrl + H)" Id="TransactionHistory"
                                          Disabled="@_isProcessing" />
                            </MenuItems>
                        </MenuItem>
                        <MenuItem Text="Periods" IconCss="e-icons e-clock">
                            <MenuItems>
                                <MenuItem Text="Today" Id="PeriodToday" Disabled="@_isProcessing" />
                                <MenuItem Text="Previous Day" Id="PeriodPreviousDay" Disabled="@_isProcessing" />
                                <MenuItem Text="Next Day" Id="PeriodNextDay" Disabled="@_isProcessing" />
                                <MenuItem Text="Current Month" Id="PeriodCurrentMonth" Disabled="@_isProcessing" />
                                <MenuItem Text="Previous Month" Id="PeriodPreviousMonth" Disabled="@_isProcessing" />
                                <MenuItem Text="Next Month" Id="PeriodNextMonth" Disabled="@_isProcessing" />
                                <MenuItem Text="Current FY" Id="PeriodCurrentFinancialYear" Disabled="@_isProcessing" />
                                <MenuItem Text="Previous FY" Id="PeriodPreviousFinancialYear" Disabled="@_isProcessing" />
                                <MenuItem Text="Next FY" Id="PeriodNextFinancialYear" Disabled="@_isProcessing" />
                                <MenuItem Text="All Time" Id="PeriodAllTime" Disabled="@_isProcessing" />
                            </MenuItems>
                        </MenuItem>
                        <MenuItem Text="Transaction" IconCss="e-icons e-chart">
                            <MenuItems>
                                <MenuItem Text="View (Ctrl + O)" IconCss="e-icons e-eye" Id="ViewSelected"
                                          Disabled="@(_isProcessing || _showSummary)" />
                                <MenuItem Text="Export PDF (Alt + P)" IconCss="e-icons e-export-pdf" Id="DownloadSelectedPdf"
                                          Disabled="@(_isProcessing || _showSummary)" />
                                <MenuItem Text="Export Excel (Alt + E)" IconCss="e-icons e-export-excel"
                                          Id="DownloadSelectedExcel" Disabled="@(_isProcessing || _showSummary)" />
                            </MenuItems>
                        </MenuItem>
                    </MenuItems>
                </SfMenu>
            </LeftContent>
            <RightContent>
                <IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
            </RightContent>
        </Header>

        <!-- Main Content Container -->
        <div class="page-container">

            <!-- Filters Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
                        </svg>
                        <h2 class="section-title">Filters</h2>
                    </div>
                </div>
                <div class="section-body">
                    <div class="filters-container">
                        <div class="filters-grid">
                            <!-- Date Range -->
                            <div class="form-field">
                                <label class="field-label">Date Range</label>
                                <SfDateRangePicker CssClass="custom-daterange" StartDate="_fromDate" EndDate="_toDate"
                                                   TValue="DateTime" Format="dd/MM/yyyy" AllowEdit="true" Placeholder="Select date range">
                                    <DateRangePickerEvents TValue="DateTime" ValueChange="OnDateRangeChanged" />
                                </SfDateRangePicker>
                            </div>

                            <!-- Company -->
                            <div class="form-field">
                                <AutoCompleteWithAdd TItem="CompanyModel" TValue="CompanyModel"
                                                Value="@_selectedCompany"
                                                DataSource="@_companies"
                                                Placeholder="All Companies"
                                                Label="Company" Required="false"
                                                ValueChange="OnCompanyChanged"
                                                FieldValue="@nameof(CompanyModel.Name)"
                                                AddNewRoute="@PageRouteNames.CompanyMaster" />
                            </div>

                            <!-- Kitchen -->
                            <div class="form-field">
                                <AutoCompleteWithAdd TItem="KitchenModel" TValue="KitchenModel"
                                                Value="@_selectedKitchen"
                                                DataSource="@_kitchens"
                                                Placeholder="All Kitchens"
                                                Label="Kitchen" Required="false"
                                                ValueChange="OnKitchenChanged"
                                                FieldValue="@nameof(KitchenModel.Name)"
                                                AddNewRoute="@PageRouteNames.Kitchen" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Report Grid Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round">
                            <line x1="8" y1="6" x2="21" y2="6" />
                            <line x1="8" y1="12" x2="21" y2="12" />
                            <line x1="8" y1="18" x2="21" y2="18" />
                            <line x1="3" y1="6" x2="3.01" y2="6" />
                            <line x1="3" y1="12" x2="3.01" y2="12" />
                            <line x1="3" y1="18" x2="3.01" y2="18" />
                        </svg>
                        <h2 class="section-title">Kitchen Issue Item Transactions</h2>
                    </div>
                </div>
                <div class="section-body grid-body">
                    <SfGrid ID="_sfGrid" @ref="_sfGrid" TValue="KitchenIssueItemOverviewModel"
                            DataSource="_transactionOverviews" AllowTextWrap="true" AllowPaging="true" AllowSorting="true"
                            AllowResizing="true" AllowFiltering="true" AllowExcelExport="true" AllowPdfExport="true"
                            AllowGrouping="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
                            ContextMenuItems="@_gridContextMenuItems" Toolbar="@(new List<string>() { "Search" })">

                        <GridEvents TValue="KitchenIssueItemOverviewModel"
                                    ContextMenuItemClicked="OnGridContextMenuItemClicked" />
                        <GridGroupSettings ShowDropArea="true" ShowGroupedColumn="true" ShowUngroupButton="true" />
                        <GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
                        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

                        <GridAggregates>
                            <GridAggregate>
                                <GridAggregateColumns>
                                    <GridAggregateColumn Field="@nameof(KitchenIssueItemOverviewModel.ItemName)"
                                                         Type="AggregateType.Count">
                                        <FooterTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                            }
                                            <div class="aggregate-label">
                                                <strong>Total Items: @aggregate.Count</strong>
                                            </div>
                                        </FooterTemplate>
                                        <GroupFooterTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                            }
                                            <div class="aggregate-label">
                                                <strong>Total Items: @aggregate.Count</strong>
                                            </div>
                                        </GroupFooterTemplate>
                                        <GroupCaptionTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                            }
                                            <div class="aggregate-label">
                                                <strong>Total Items: @aggregate.Count</strong>
                                            </div>
                                        </GroupCaptionTemplate>
                                    </GridAggregateColumn>
                                    <GridAggregateColumn Field="@nameof(KitchenIssueItemOverviewModel.Quantity)"
                                                         Type="AggregateType.Sum" Format="N2">
                                        <FooterTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                                <div><strong>@aggregate.Sum</strong></div>
                                            }
                                        </FooterTemplate>
                                        <GroupFooterTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                                <div><strong>@aggregate.Sum</strong></div>
                                            }
                                        </GroupFooterTemplate>
                                        <GroupCaptionTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                                <div><strong>@aggregate.Sum</strong></div>
                                            }
                                        </GroupCaptionTemplate>
                                    </GridAggregateColumn>
                                    <GridAggregateColumn Field="@nameof(KitchenIssueItemOverviewModel.Total)"
                                                         Type="AggregateType.Sum" Format="N2">
                                        <FooterTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                                <div class="aggregate-value aggregate-total">
                                                    <strong>@aggregate.Sum</strong>
                                                </div>
                                            }
                                        </FooterTemplate>
                                        <GroupFooterTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                                <div class="aggregate-value aggregate-total">
                                                    <strong>@aggregate.Sum</strong>
                                                </div>
                                            }
                                        </GroupFooterTemplate>
                                        <GroupCaptionTemplate>
                                            @{
                                                var aggregate = (context as AggregateTemplateContext);
                                                <div class="aggregate-value aggregate-total">
                                                    <strong>@aggregate.Sum</strong>
                                                </div>
                                            }
                                        </GroupCaptionTemplate>
                                    </GridAggregateColumn>
                                </GridAggregateColumns>
                            </GridAggregate>
                        </GridAggregates>

                        <GridColumns>
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.ItemName)" HeaderText="Item"
                                        Width="200" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.ItemCode)" HeaderText="Code"
                                        Width="130" Visible="@_showAllColumns" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.ItemCategoryName)"
                                        HeaderText="Category" Width="150" Visible="@_showAllColumns" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.TransactionNo)" HeaderText="Trans No"
                                        Width="170" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.TransactionDateTime)" HeaderText="Date"
                                        Width="150" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.CompanyName)" HeaderText="Company"
                                        Width="180"
                                        Visible="@(_showAllColumns && !_showSummary && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.KitchenName)" HeaderText="Kitchen"
                                        Width="200"
                                        Visible="@(!_showSummary && (_selectedKitchen is null || _selectedKitchen.Id <= 0))" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.Quantity)" HeaderText="Quantity"
                                        Width="120" Format="N2" TextAlign="TextAlign.Right" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.Rate)" HeaderText="Rate" Width="120"
                                        Format="N2" TextAlign="TextAlign.Right" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.Total)" HeaderText="Total" Width="150"
                                        TextAlign="TextAlign.Right">
                                <Template>
                                    @{
                                        var detailItem = (context as KitchenIssueItemOverviewModel);
                                        <span class="grid-total">@detailItem.Total.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.KitchenIssueRemarks)"
                                        HeaderText="Issue Remarks" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(KitchenIssueItemOverviewModel.Remarks)" HeaderText="Item Remarks"
                                        Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>

        <Footer />
    </div>
}

<ToastNotification @ref="_toastNotification" />
