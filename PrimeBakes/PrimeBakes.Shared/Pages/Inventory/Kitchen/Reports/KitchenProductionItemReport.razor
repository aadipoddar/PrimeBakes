@using PrimeBakes.Library.Accounts.Masters.Models
@using PrimeBakes.Library.Inventory.Kitchen.Models
@using PrimeBakes.Library.Store.Product.Models

@attribute [Route(InventoryRouteNames.KitchenProductionItemReport)]

<PageTitle>Kitchen Production Item Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenProduction, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyW KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleSummary" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenProductionReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ViewSelectedTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedTransaction" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Kitchen Production Item Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenProduction, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadTransactionOverviews" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudMenuItem Label="@(_showSummary ? "Hide Summary (Ctrl + W)" : "Show Summary (Ctrl + W)")" OnClick="ToggleSummary" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="ToggleDetailsView" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Kitchen Production (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenProduction, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Kitchen Production Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenProductionReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Kitchen Production Item Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenProductionItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Kitchen Issue" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenIssue, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Kitchen Issue Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenIssueReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Kitchen Issue Item Report" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenIssueItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Kitchen" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.Kitchen, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing || _showSummary">
					<MudBlazor.MudMenuItem Label="View (Alt + O)" OnClick="ViewSelectedTransaction" />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedTransaction" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="ProductModel"
												Value="_selectedProduct"
												DataSource="@_products"
												Placeholder="All Products"
												Label="Product" Required="false"
												ValueChanged="OnProductChanged"
												FieldValue="@nameof(ProductModel.Name)"
												AddNewRoute="@StoreRouteNames.Product" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="ProductCategoryModel"
												Value="_selectedProductCategory"
												DataSource="@_productCategories"
												Placeholder="All Categories"
												Label="Product Category" Required="false"
												ValueChanged="OnProductCategoryChanged"
												FieldValue="@nameof(ProductCategoryModel.Name)"
												AddNewRoute="@StoreRouteNames.ProductCategory" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="All Companies"
												Label="Company" Required="false"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@AccountsRouteNames.CompanyMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="KitchenModel"
												Value="_selectedKitchen"
												DataSource="@_kitchens"
												Placeholder="All Kitchens"
												Label="Kitchen" Required="false"
												ValueChanged="OnKitchenChanged"
												FieldValue="@nameof(KitchenModel.Name)"
												AddNewRoute="@InventoryRouteNames.Kitchen" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<SfGrid @ref="_sfGrid" TValue="KitchenProductionItemOverviewModel" DataSource="_transactionOverviews"
						AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="KitchenProductionItemOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridColumnAggregate Field="@nameof(KitchenProductionItemOverviewModel.ItemName)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(KitchenProductionItemOverviewModel.Quantity)" />
								<GridColumnAggregate Field="@nameof(KitchenProductionItemOverviewModel.Total)" CustomColor="grid-total" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.ItemName)" HeaderText="Product" Visible="@(_showAllColumns || _selectedProduct is null || _selectedProduct.Id <= 0)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.ItemCode)" HeaderText="Code" Visible="@_showAllColumns" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.ItemCategoryName)" HeaderText="Category" Visible="@(_showAllColumns || _selectedProductCategory is null || _selectedProductCategory.Id <= 0)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.Quantity)" HeaderText="Quantity" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.Rate)" HeaderText="Rate" Visible="@(!_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.Total)" HeaderText="Total" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.ItemRemarks)" HeaderText="Item Remarks" Visible="@(_showAllColumns && !_showSummary)" />

						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.TransactionNo)" HeaderText="Transaction No" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.CompanyName)" HeaderText="Company" Visible="@(!_showSummary && (_showAllColumns || _selectedCompany is null || _selectedCompany.Id <= 0))" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.TransactionDateTime)" HeaderText="Date" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.FinancialYear)" HeaderText="Financial Year" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.KitchenName)" HeaderText="Kitchen" Visible="@(!_showSummary && (_showAllColumns || _selectedKitchen is null || _selectedKitchen.Id <= 0))" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.TotalItems)" HeaderText="Total Items" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.TotalQuantity)" HeaderText="Total Qty" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.TotalAmount)" HeaderText="Total Amount" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />

						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.KitchenProductionRemarks)" HeaderText="Production Remarks" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.CreatedByName)" HeaderText="Created By" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.CreatedAt)" HeaderText="Created At" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.CreatedFromPlatform)" HeaderText="Created Platform" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.LastModifiedByUserName)" HeaderText="Modified By" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.LastModifiedAt)" HeaderText="Modified At" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.LastModifiedFromPlatform)" HeaderText="Modified Platform" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(KitchenProductionItemOverviewModel.MasterStatus)" Visible="@(_showDeleted && !_showSummary)" StatusColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
