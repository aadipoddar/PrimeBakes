@using PrimeBakesLibrary.Accounts.Masters.Models
@using PrimeBakesLibrary.Inventory.Kitchen.Models
@using PrimeBakesLibrary.Inventory.RawMaterial.Models

@attribute [Route(InventoryRouteNames.KitchenIssue)]
@attribute [Route(InventoryRouteNames.KitchenIssue + "/{Id:int}")]

<PageTitle>Kitchen Issue - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfFirstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfItemAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenIssueReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyI KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenIssueItemReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_kitchenIssue.Id > 0 ? $"Edit Kitchen Issue {_kitchenIssue.TransactionNo}" : "Create Kitchen Issue")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Transaction History Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenIssueReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Item Report (Ctrl + I)" OnClick="() => AuthenticationService.NavigateToRoute(InventoryRouteNames.KitchenIssueItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Transaction Summary Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="16" y1="13" x2="8" y2="13" />
							<line x1="16" y1="17" x2="8" y2="17" />
							<polyline points="10 9 9 9 8 9" />
						</svg>
						<h2 class="section-title">Transaction Summary</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- Company -->
						<div class="form-field">
							<CustomAutoComplete @ref="_sfFirstFocus" T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="Select a Company"
												Label="Company (Ctrl + F)"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@AccountsRouteNames.CompanyMaster" />
						</div>

						<!-- Kitchen -->
						<div class="form-field">
							<CustomAutoComplete T="KitchenModel"
												Value="_selectedKitchen"
												DataSource="@_kitchens"
												Placeholder="Select a Kitchen"
												Label="Kitchen"
												ValueChanged="OnKitchenChanged"
												FieldValue="@nameof(KitchenModel.Name)"
												AddNewRoute="@InventoryRouteNames.Kitchen" />
						</div>

						<!-- Transaction Date -->
						<div class="form-field">
							<CustomDatePicker Value="_kitchenIssue.TransactionDateTime"
											  FinancialYear="@_selectedFinancialYear"
											  ValueChanged="OnTransactionDateChanged" />
						</div>

						<!-- Transaction No -->
						<div class="form-field">
							<CustomTextField @bind-Value="_kitchenIssue.TransactionNo"
											 Label="Transaction No"
											 Placeholder="Transaction No"
											 ReadOnly="true"
											 TabIndex="-1" />
						</div>

						<!-- Remarks -->
						<div class="form-field form-field-full">
							<CustomTextField @bind-Value="_kitchenIssue.Remarks"
											 Label="Remarks / Narration"
											 Placeholder="Enter remarks..."
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<!-- Add to Cart Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Item to Cart</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="cart-input-row">
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="RawMaterialModel"
												@ref="_sfItemAutoComplete"
												Value="_selectedRawMaterial"
												DataSource="@_rawMaterials"
												Placeholder="Select Item"
												Label="Item (Ctrl + G)"
												ValueChanged="OnItemChanged"
												FieldValue="@nameof(RawMaterialModel.Name)"
												AddNewRoute="@InventoryRouteNames.RawMaterial"
												OpenOnFocus="false" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="@(_stockSummary.FirstOrDefault(s => s.RawMaterialId == _selectedRawMaterial?.Id)?.ClosingStock ?? 0)"
												Label="Current Stock"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Quantity"
												ValueChanged="OnItemQuantityChanged"
												Label="Qty"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomTextField @bind-Value="_selectedCart.UnitOfMeasurement"
											 Label="UOM"
											 Placeholder="UOM..." />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Rate"
												ValueChanged="OnItemRateChanged"
												Label="Rate"
												Placeholder="0.00"
												Required="false"
												Min="0" />
						</div>

						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Total"
												Label="Total"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field cart-field-action">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Cart Items Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Kitchen Issue Items</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid ID="_sfCartGrid" @ref="_sfCartGrid" DataSource="_cart" AllowTextWrap="true" AllowPaging="false"
							AllowSorting="true" AllowResizing="true" AllowFiltering="true" GridLines="GridLine.Horizontal"
							CssClass="professional-grid" ContextMenuItems="@_cartGridContextMenuItems"
							Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="KitchenIssueItemCartModel" ContextMenuItemClicked="OnCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(KitchenIssueItemCartModel.ItemName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(KitchenIssueItemCartModel.Quantity)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(KitchenIssueItemCartModel.Total)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(KitchenIssueItemCartModel.ItemName)" HeaderText="Item Name" Width="200" />
							<GridColumn Field="@nameof(KitchenIssueItemCartModel.UnitOfMeasurement)" HeaderText="UOM" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(KitchenIssueItemCartModel.Quantity)" HeaderText="Qty" Width="100" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(KitchenIssueItemCartModel.Rate)" HeaderText="Rate" Width="110" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(KitchenIssueItemCartModel.Total)" HeaderText="Total" Width="130" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Total.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(KitchenIssueItemCartModel.Remarks)" HeaderText="Remarks" Width="150" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />