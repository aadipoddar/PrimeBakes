@attribute [Route(PageRouteNames.DiningTable)]

@using PrimeBakesLibrary.Models.Restuarant.Dining

<PageTitle>Dining Table Management - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveDiningTable" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteSelectedItem" />

@if (_isLoading)
{
	<AnimatedLoader Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="Dining Table Management">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
										   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewDiningTable"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveDiningTable"
										  Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash"
										  Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelected"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelected"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<div class="page-container">

			<!-- Dining Table Entry Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">Dining Table Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- Dining Table Name -->
						<div class="form-field">
							<label class="field-label">
								Dining Table Name <span class="required">*</span>
							</label>
							<SfTextBox @bind-Value="_diningTable.Name" Placeholder="Enter dining table name"
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>

						<!-- Dining Area -->
						<div class="form-field">
							<label class="field-label">Dining Area <span class="required">*</span></label>
							<SfAutoComplete @bind-Value="_selectedDiningAreaName" TValue="string" TItem="DiningAreaModel"
											Placeholder="Select dining area" DataSource="@_diningAreas" PopupHeight="300px"
											CssClass="custom-autocomplete" AllowFiltering="true"
											FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains">
								<AutoCompleteFieldSettings Value="Name" />
								<AutoCompleteEvents TValue="string" TItem="DiningAreaModel"
													ValueChange="OnDiningAreaChange" />
							</SfAutoComplete>
						</div>

						<!-- Remarks -->
						<div class="form-field form-field-span-2">
							<label class="field-label">Remarks</label>
							<SfTextBox @bind-Value="_diningTable.Remarks" Placeholder="Enter remarks (optional)"
									   Multiline="true" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>
					</div>
				</div>
			</div>

			<!-- Dining Tables List Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Dining Tables List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_diningTables" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_diningTableGridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="DiningTableModel" ContextMenuItemClicked="OnDiningTableGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(DiningTableModel.Id)" HeaderText="ID" Width="80"
										TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(DiningTableModel.Name)" HeaderText="Table Name" Width="250" />
							<GridColumn HeaderText="Dining Area" Width="200">
								<Template>
									@{
										var diningTable = (context as DiningTableModel);
										var diningArea = _diningAreas.FirstOrDefault(da => da.Id == diningTable.DiningAreaId);
										<span>@(diningArea?.Name ?? "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(DiningTableModel.Remarks)" HeaderText="Remarks" Width="400" />
							<GridColumn Field="@nameof(DiningTableModel.Status)" HeaderText="Status" Width="110"
										TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var diningTable = (context as DiningTableModel);
										<span class="@(diningTable.Status ? string.Empty : "grid-debit")">@(diningTable.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Dining Table" IdentifierLabel="Dining Table Name"
						  IdentifierValue="@_deleteDiningTableName" Disabled="@_isProcessing" OnConfirm="ConfirmDelete"
						  OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Dining Table"
						   IdentifierLabel="Dining Table Name" IdentifierValue="@_recoverDiningTableName" Disabled="@_isProcessing"
						   OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
