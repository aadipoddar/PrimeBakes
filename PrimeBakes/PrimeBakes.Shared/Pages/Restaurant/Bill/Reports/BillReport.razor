                                        TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.TotalQuantity)" HeaderText="Qty" Width="120"
                                        Format="N2" TextAlign="TextAlign.Right" />
                            <GridColumn Field="@nameof(BillOverviewModel.BaseTotal)" HeaderText="Base Total" Width="130"
                                        Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.ItemDiscountAmount)" HeaderText="Disc" Width="130"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="grid-discount">@item.ItemDiscountAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.TotalAfterItemDiscount)" HeaderText="After Disc"
                                        Width="140" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.TotalInclusiveTaxAmount)" HeaderText="Incl Tax"
                                        Width="120" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.TotalExtraTaxAmount)" HeaderText="Extra Tax"
                                        Width="120" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.TotalAfterTax)" HeaderText="Sub Total" Width="130"
                                        Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.DiscountPercent)" HeaderText="Disc %" Width="130"
                                        Format="N2" TextAlign="TextAlign.Center" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.DiscountAmount)" HeaderText="Dis" Width="130"
                                        TextAlign="TextAlign.Right">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="grid-discount">@item.DiscountAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.ServiceChargePercent)" HeaderText="Service %"
                                        Width="130" Format="N2" TextAlign="TextAlign.Center" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.ServiceChargeAmount)" HeaderText="Service Charge"
                                        Width="140" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.RoundOffAmount)" HeaderText="Round Off" Width="120"
                                        Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(BillOverviewModel.TotalAmount)" HeaderText="Total" Width="150"
                                        TextAlign="TextAlign.Right">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="grid-total">@item.TotalAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.Cash)" HeaderText="Cash" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="grid-total">@item.Cash.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.Card)" HeaderText="Card" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="grid-total">@item.Card.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.UPI)" HeaderText="UPI" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="grid-total">@item.UPI.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.Credit)" HeaderText="Credit" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="grid-total">@item.Credit.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.PaymentModes)" HeaderText="Payment Modes"
                                        Width="180" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.Running)" HeaderText="Running" Width="100"
                                        TextAlign="TextAlign.Center" Visible="@(!_showSummary)">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span>@(item?.Running == true ? "Running" : "Billed")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.Status)" HeaderText="Status" Width="110"
                                        TextAlign="TextAlign.Center" Visible="@(_showDeleted && !_showSummary)">
                                <Template>
                                    @{
                                        var item = (context as BillOverviewModel);
                                        <span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(BillOverviewModel.Remarks)" HeaderText="Remarks" Width="200"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.CreatedByName)" HeaderText="Created By" Width="150"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.CreatedAt)" HeaderText="Created At" Width="160"
                                        Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.CreatedFromPlatform)" HeaderText="Created Platform"
                                        Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.LastModifiedByUserName)" HeaderText="Modified By"
                                        Width="150" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.LastModifiedAt)" HeaderText="Modified At"
                                        Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.LastModifiedFromPlatform)"
                                        HeaderText="Modified Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(BillOverviewModel.FinancialAccountingTransactionNo)"
                                        HeaderText="Accounts Posting" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>

        <Footer />
    </div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Bill Transaction"
                          IdentifierLabel="Transaction No" IdentifierValue="@_deleteTransactionNo" Disabled="@_isProcessing"
                          OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Bill Transaction"
                           IdentifierLabel="Transaction No" IdentifierValue="@_recoverTransactionNo" Disabled="@_isProcessing"
                           OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
