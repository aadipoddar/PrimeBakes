@attribute [Route(RestaurantRouteNames.DiningMobileDashboard)]

<PageTitle>Dining Dashboard - Prime Bakes</PageTitle>

<HeadContent>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet" />
</HeadContent>

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	var totalTables = _diningTables.Count;
	var runningCount = _diningTables.Count(t => _runningBills.Any(b => b.DiningTableId == t.Id && b.Running));
	var liveTotal = _runningBills.Where(b => b.Running).Sum(b => b.TotalAmount);

	<div class="pb-screen">
		<div class="pb-header">
			<div class="pb-header__main">
				<div class="pb-header__sub">@_now.ToString("dddd") · @runningCount of @totalTables running</div>
				<h1 class="pb-header__title">Tables</h1>
			</div>
			<div class="pb-header__actions">
				<button type="button" class="pb-icon-btn" @onclick="() => NavigationManager.NavigateTo(OperationRouteNames.Dashboard)" aria-label="Back (Ctrl + B)">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
				</button>
			</div>
		</div>

		<div class="pb-stats">
			<div class="pb-stat pb-stat--rouge">
				<div class="pb-stat__label">Running</div>
				<div class="pb-stat__value">@runningCount</div>
			</div>
			<div class="pb-stat pb-stat--moss">
				<div class="pb-stat__label">Open</div>
				<div class="pb-stat__value">@(totalTables - runningCount)</div>
			</div>
			<div class="pb-stat pb-stat--ink">
				<div class="pb-stat__label">Live total</div>
				<div class="pb-stat__value">₹@liveTotal.ToString("N0")</div>
			</div>
		</div>

		<div class="pb-scroll">
			@if (_diningAreas.Count == 0)
			{
				<div class="pb-empty">
					<h2 class="pb-empty__title">No dining areas</h2>
					<p class="pb-empty__sub">No active dining areas found for your location.</p>
				</div>
			}
			else
			{
				@foreach (var area in _diningAreas)
				{
					var areaTables = _diningTables.Where(t => t.DiningAreaId == area.Id).OrderBy(t => t.Name).ToList();
					var areaRunning = areaTables.Count(t => _runningBills.Any(b => b.DiningTableId == t.Id && b.Running));

					<div class="pb-section">
						<div class="pb-section__head">
							<p class="pb-section__title">@area.Name</p>
							<span class="pb-section__count">@areaRunning running · @areaTables.Count tables</span>
						</div>

						@if (areaTables.Count == 0)
						{
							<div class="pb-grid__empty">No active tables in this area.</div>
						}
						else
						{
							<div class="pb-tables">
								@foreach (var table in areaTables)
								{
									var runningBill = _runningBills.FirstOrDefault(b => b.DiningTableId == table.Id && b.Running);
									var isRunning = runningBill is not null;

									<button type="button" class="pb-table-card @(isRunning ? "is-running" : "")"
											@onclick='() => NavigationManager.NavigateTo($"{RestaurantRouteNames.BillMobile}/table/{table.Id}")'>
										<div class="pb-table-card__top">
											<div class="pb-table-card__num">@table.Name</div>
											@if (isRunning)
											{
												<span class="pb-table-card__clock">
													<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
													@Elapsed(runningBill.TransactionDateTime)
												</span>
											}
										</div>
										@if (isRunning)
										{
											<div class="pb-table-card__bottom">
												<div class="pb-table-card__amt">₹@runningBill.TotalAmount.ToString("N0")</div>
												<div class="pb-table-card__meta">@runningBill.TotalItems items · @(((int)runningBill.TotalQuantity)) qty</div>
											</div>
										}
										else
										{
											<span class="pb-pill is-available"><span class="pb-dot"></span>Available</span>
										}
									</button>
								}
							</div>
						}
					</div>
				}
			}
			<div class="pb-scroll__bottom-pad"></div>
		</div>
	</div>
}

<style>
	.pb-screen {
		--bg-app: #f7f2ea;
		--surface: #ffffff;
		--surface-2: #faf5ec;
		--surface-3: #f1ebdf;
		--ink-1: #1d1813;
		--ink-2: #5a5147;
		--ink-3: #9a8f7f;
		--line-1: #ece4d3;
		--line-2: #ddd2bd;
		--rouge: #b13a5e;
		--rouge-dark: #8a2748;
		--rouge-soft: #f7e4ec;
		--rouge-tint: #fdf6f8;
		--moss: #4f7a5a;
		--moss-soft: #e3ecdd;
		--r-sm: 12px;
		--r-md: 16px;
		--r-lg: 22px;
		--r-pill: 999px;
		--ff-sans: "Plus Jakarta Sans", -apple-system, system-ui, sans-serif;
		--ff-mono: "JetBrains Mono", ui-monospace, monospace;
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: var(--bg-app);
		color: var(--ink-1);
		font-family: var(--ff-sans);
		font-size: 15px;
		line-height: 1.4;
		letter-spacing: -0.005em;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		z-index: 1;
	}

		.pb-screen *,
		.pb-screen *::before,
		.pb-screen *::after {
			box-sizing: border-box;
		}

	/* Header */
	.pb-header {
		padding: 14px 22px 14px;
		padding-top: max(14px, env(safe-area-inset-top));
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 12px;
		flex-shrink: 0;
	}

	.pb-header__main {
		min-width: 0;
	}

	.pb-header__sub {
		font-size: 12.5px;
		color: var(--ink-3);
		margin-bottom: 6px;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		font-weight: 500;
		font-variant-numeric: tabular-nums;
	}

	.pb-header__title {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 26px;
		letter-spacing: -0.025em;
		line-height: 1.15;
		margin: 0;
		color: var(--ink-1);
	}

	.pb-header__actions {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.pb-icon-btn {
		width: 38px;
		height: 38px;
		border-radius: var(--r-pill);
		background: var(--surface);
		border: 1px solid var(--line-1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-2);
		cursor: pointer;
		flex-shrink: 0;
		padding: 0;
	}

		.pb-icon-btn:active {
			transform: scale(0.96);
		}

	/* Summary stats */
	.pb-stats {
		display: flex;
		gap: 10px;
		padding: 0 18px 16px;
		flex-shrink: 0;
	}

	.pb-stat {
		flex: 1;
		min-width: 0;
		border: 1px solid var(--line-1);
		border-radius: 16px;
		padding: 11px 13px;
	}

	.pb-stat--rouge {
		background: var(--rouge-soft);
	}

	.pb-stat--moss {
		background: var(--moss-soft);
	}

	.pb-stat--ink {
		background: var(--surface);
	}

	.pb-stat__label {
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-weight: 700;
		opacity: 0.72;
	}

	.pb-stat--rouge .pb-stat__label,
	.pb-stat--rouge .pb-stat__value {
		color: var(--rouge-dark);
	}

	.pb-stat--moss .pb-stat__label,
	.pb-stat--moss .pb-stat__value {
		color: var(--moss);
	}

	.pb-stat--ink .pb-stat__label,
	.pb-stat--ink .pb-stat__value {
		color: var(--ink-1);
	}

	.pb-stat__value {
		font-family: var(--ff-sans);
		font-size: 23px;
		margin-top: 3px;
		letter-spacing: -0.02em;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}

	/* Scroll */
	.pb-scroll {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}

		.pb-scroll::-webkit-scrollbar {
			display: none;
		}

	.pb-scroll__bottom-pad {
		height: 8px;
	}

	/* Section */
	.pb-section {
		margin: 0 18px 18px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		overflow: hidden;
	}

	.pb-section__head {
		padding: 14px 18px 8px;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
	}

	.pb-section__title {
		font-size: 11.5px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin: 0;
	}

	.pb-section__count {
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.04em;
		font-variant-numeric: tabular-nums;
	}

	.pb-grid__empty {
		padding: 24px 18px;
		text-align: center;
		color: var(--ink-3);
		font-size: 13.5px;
	}

	/* Table cards */
	.pb-tables {
		padding: 12px 14px 14px;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 10px;
	}

	.pb-table-card {
		background: var(--surface-2);
		border: 1px solid var(--line-1);
		border-radius: 18px;
		padding: 14px;
		min-height: 130px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 10px;
		text-align: left;
		font-family: var(--ff-sans);
		cursor: pointer;
		color: var(--ink-1);
	}

		.pb-table-card:active {
			transform: scale(0.98);
		}

		.pb-table-card.is-running {
			background: linear-gradient(180deg, #fdf6f8 0%, #f9eaf0 100%);
			border-color: var(--rouge-soft);
		}

	.pb-table-card__top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 8px;
	}

	.pb-table-card__num {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 30px;
		line-height: 0.95;
		letter-spacing: -0.03em;
		color: var(--ink-1);
		font-variant-numeric: tabular-nums;
		word-break: break-word;
	}

	.pb-table-card.is-running .pb-table-card__num {
		font-style: italic;
		color: var(--rouge);
	}

	.pb-table-card__clock {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 11px;
		color: var(--rouge-dark);
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		flex-shrink: 0;
	}

	.pb-table-card__amt {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 17px;
		letter-spacing: -0.02em;
		color: var(--ink-1);
		font-variant-numeric: tabular-nums;
	}

	.pb-table-card__meta {
		font-size: 11px;
		color: var(--ink-3);
		letter-spacing: 0.02em;
		margin-top: 4px;
		font-variant-numeric: tabular-nums;
	}

	.pb-pill {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 10px;
		border-radius: var(--r-pill);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.02em;
		width: fit-content;
	}

		.pb-pill.is-available {
			background: var(--moss-soft);
			color: var(--moss);
			border: 1px solid transparent;
		}

	.pb-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: currentColor;
	}

	/* Empty */
	.pb-empty {
		margin: 18px;
		padding: 48px 24px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		text-align: center;
	}

	.pb-empty__title {
		margin: 0;
		font-size: 20px;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--ink-1);
	}

	.pb-empty__sub {
		margin: 8px 0 0;
		color: var(--ink-3);
		font-size: 14px;
	}
</style>
