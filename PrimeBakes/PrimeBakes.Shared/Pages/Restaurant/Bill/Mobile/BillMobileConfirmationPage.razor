@attribute [Route(RestaurantRouteNames.BillMobileConfirmation)]

<PageTitle>Bill Settled - Prime Bakes</PageTitle>

<HeadContent>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet" />
</HeadContent>

<div class="pb-screen">
	<div class="pb-topbar">
		<button type="button" class="pb-icon-btn" @onclick="() => NavigationManager.NavigateTo(OperationRouteNames.Dashboard, true)" aria-label="Home">
			<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
				<path d="M3 11l9-8 9 8" />
				<path d="M5 10v10h5v-6h4v6h5V10" />
			</svg>
		</button>
	</div>

	<div class="pb-scroll">
		<div class="pb-success">
			<div class="pb-success__icon">
				<svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M4 12l5 5 11-11" />
				</svg>
			</div>
			<h1 class="pb-success__title">Bill settled.</h1>
			<p class="pb-success__sub">@PaymentSummary()</p>
		</div>

		@if (_bill is not null)
		{
			<div class="pb-receipt">
				<div class="pb-receipt__head">
					<div>
						<div class="pb-receipt__label">Bill no.</div>
						<div class="pb-receipt__value pb-receipt__value--mono">@_bill.TransactionNo</div>
					</div>
					<div class="pb-receipt__head-right">
						<div class="pb-receipt__label">Closed</div>
						<div class="pb-receipt__value pb-receipt__value--mono">@_bill.CreatedAt.ToString("h:mm tt").ToLower()</div>
					</div>
				</div>

				<div class="pb-receipt__lines">
					@foreach (var item in _cart)
					{
						<div class="pb-receipt__line">
							<span class="pb-receipt__line-name">
								@item.ItemName<span class="pb-receipt__line-qty-inline"> × @((int)item.Quantity)</span>
							</span>
							<span class="pb-receipt__line-amt">₹@((item.Rate * item.Quantity).ToString("N0"))</span>
						</div>
					}
				</div>

				<div class="pb-receipt__summary">
					<div class="pb-receipt__sum-row">
						<span>Base · @((int)_bill.TotalQuantity) qty</span>
						<span class="pb-receipt__sum-val">₹@_bill.TotalAfterTax.ToString("N2")</span>
					</div>
					@if (_bill.DiscountAmount > 0)
					{
						<div class="pb-receipt__sum-row">
							<span>Discount · @_bill.DiscountPercent.ToString("0.##")%</span>
							<span class="pb-receipt__sum-val pb-receipt__sum-val--moss">−₹@_bill.DiscountAmount.ToString("N2")</span>
						</div>
					}
					@if (_bill.ServiceChargeAmount > 0)
					{
						<div class="pb-receipt__sum-row">
							<span>Service · @_bill.ServiceChargePercent.ToString("0.##")%</span>
							<span class="pb-receipt__sum-val">+₹@_bill.ServiceChargeAmount.ToString("N2")</span>
						</div>
					}
					@if (_bill.RoundOffAmount != 0)
					{
						<div class="pb-receipt__sum-row">
							<span>Round off</span>
							<span class="pb-receipt__sum-val pb-receipt__sum-val--muted">@(_bill.RoundOffAmount >= 0 ? "+" : "−")₹@Math.Abs(_bill.RoundOffAmount).ToString("N2")</span>
						</div>
					}
				</div>

				<div class="pb-receipt__total">
					<span class="pb-receipt__total-label">Total paid</span>
					<span class="pb-receipt__total-value">₹@_bill.TotalAmount.ToString("N0")</span>
				</div>
			</div>
		}

		<div class="pb-scroll__bottom-pad"></div>
	</div>

	<div class="pb-cta-bar">
		<div class="pb-cta-row">
			<button type="button" class="pb-cta pb-cta--outline" @onclick="PrintThermal" disabled="@(_bill is null || _isPrinting)">
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
					<path d="M6 9V3h12v6" />
					<rect x="3" y="9" width="18" height="9" rx="2" />
					<rect x="7" y="14" width="10" height="6" rx="1" />
				</svg>
				@(_isPrinting ? "Preparing…" : "Thermal")
			</button>
			<button type="button" class="pb-cta pb-cta--primary" @onclick="() => NavigationManager.NavigateTo(RestaurantRouteNames.DiningMobileDashboard, true)">
				New bill
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
					<path d="M5 12h14" />
					<path d="M13 5l7 7-7 7" />
				</svg>
			</button>
		</div>
	</div>
</div>

<style>
	.pb-screen {
		--bg-app: #f7f2ea;
		--surface: #ffffff;
		--surface-2: #faf5ec;
		--surface-3: #f1ebdf;
		--ink-1: #1d1813;
		--ink-2: #5a5147;
		--ink-3: #9a8f7f;
		--line-1: #ece4d3;
		--line-2: #ddd2bd;
		--moss: #4f7a5a;
		--moss-soft: #e3ecdd;
		--r-lg: 22px;
		--ff-sans: "Plus Jakarta Sans", -apple-system, system-ui, sans-serif;
		--ff-mono: "JetBrains Mono", ui-monospace, monospace;
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: var(--bg-app);
		color: var(--ink-1);
		font-family: var(--ff-sans);
		font-size: 15px;
		line-height: 1.4;
		letter-spacing: -0.005em;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		z-index: 1;
	}

		.pb-screen *,
		.pb-screen *::before,
		.pb-screen *::after {
			box-sizing: border-box;
		}

	.pb-topbar {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		padding: 14px 18px 0;
		padding-top: max(14px, env(safe-area-inset-top));
		flex-shrink: 0;
	}

	.pb-icon-btn {
		width: 38px;
		height: 38px;
		border-radius: 999px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-2);
		cursor: pointer;
		padding: 0;
	}

		.pb-icon-btn:active {
			transform: scale(0.96);
		}

	.pb-scroll {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}

		.pb-scroll::-webkit-scrollbar {
			display: none;
		}

	.pb-scroll__bottom-pad {
		height: 16px;
	}

	/* Success block */
	.pb-success {
		padding: 28px 24px 12px;
		text-align: center;
		animation: pb-fadeUp 0.6s ease-out;
	}

	.pb-success__icon {
		width: 64px;
		height: 64px;
		border-radius: 999px;
		background: var(--moss-soft);
		color: var(--moss);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 22px;
		animation: pb-pop 0.6s cubic-bezier(0.18, 1.2, 0.4, 1.1) 0.1s both;
	}

	.pb-success__title {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 32px;
		letter-spacing: -0.025em;
		line-height: 1.15;
		margin: 0;
		color: var(--ink-1);
	}

	.pb-success__sub {
		font-size: 14.5px;
		color: var(--ink-2);
		margin: 10px 0 0;
		letter-spacing: -0.005em;
	}

	/* Receipt card */
	.pb-receipt {
		margin: 16px 18px 0;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		padding: 16px 18px;
		animation: pb-fadeUp 0.6s ease-out 0.15s both;
	}

	.pb-receipt__head {
		display: flex;
		justify-content: space-between;
		margin-bottom: 14px;
		gap: 12px;
	}

	.pb-receipt__head-right {
		text-align: right;
	}

	.pb-receipt__label {
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		font-weight: 600;
	}

	.pb-receipt__value {
		font-size: 15px;
		margin-top: 4px;
		color: var(--ink-1);
		font-variant-numeric: tabular-nums;
	}

	.pb-receipt__value--mono {
		font-family: var(--ff-mono);
	}

	.pb-receipt__lines {
		border-top: 1px dashed var(--line-2);
		padding-top: 12px;
	}

	.pb-receipt__line {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		font-size: 13.5px;
		padding: 5px 0;
		color: var(--ink-2);
		gap: 12px;
	}

	.pb-receipt__line-name {
		flex: 1;
		min-width: 0;
		white-space: normal;
		word-break: break-word;
		overflow-wrap: anywhere;
		line-height: 1.4;
	}

	.pb-receipt__line-qty-inline {
		color: var(--ink-3);
		font-variant-numeric: tabular-nums;
	}

	.pb-receipt__line-amt {
		font-variant-numeric: tabular-nums;
		color: var(--ink-1);
		font-weight: 600;
	}

	.pb-receipt__summary {
		border-top: 1px dashed var(--line-2);
		margin-top: 10px;
		padding-top: 10px;
	}

	.pb-receipt__sum-row {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 3px 0;
		font-size: 13px;
		color: var(--ink-3);
	}

	.pb-receipt__sum-val {
		font-variant-numeric: tabular-nums;
		color: var(--ink-2);
	}

	.pb-receipt__sum-val--moss {
		color: var(--moss);
	}

	.pb-receipt__sum-val--muted {
		color: var(--ink-3);
	}

	.pb-receipt__total {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-top: 12px;
		margin-top: 8px;
		border-top: 1px dashed var(--line-2);
	}

	.pb-receipt__total-label {
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-3);
		font-weight: 600;
	}

	.pb-receipt__total-value {
		font-size: 26px;
		font-weight: 700;
		letter-spacing: -0.02em;
		font-variant-numeric: tabular-nums;
		color: var(--ink-1);
	}

	/* CTA */
	.pb-cta-bar {
		flex-shrink: 0;
		padding: 12px 18px 14px;
		padding-bottom: max(14px, env(safe-area-inset-bottom));
		background: linear-gradient(to top, var(--bg-app) 60%, rgba(247, 242, 234, 0));
	}

	.pb-cta-row {
		display: flex;
		gap: 10px;
	}

	.pb-cta {
		border: 0;
		border-radius: 18px;
		padding: 16px;
		font-size: 14.5px;
		font-weight: 600;
		font-family: var(--ff-sans);
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		letter-spacing: -0.005em;
	}

	.pb-cta--outline {
		flex: 1;
		background: var(--surface);
		color: var(--ink-1);
		border: 1px solid var(--line-1);
	}

	.pb-cta--primary {
		flex: 2;
		background: var(--ink-1);
		color: #fff;
	}

	.pb-cta:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.pb-cta:active:not(:disabled) {
		transform: scale(0.99);
	}

	@@keyframes pb-fadeUp {
		from {
			opacity: 0;
			transform: translateY(12px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@@keyframes pb-pop {
		0% {
			opacity: 0;
			transform: scale(0.6);
		}

		70% {
			transform: scale(1.06);
		}

		100% {
			opacity: 1;
			transform: scale(1);
		}
	}

	@@media (prefers-reduced-motion: reduce) {
		.pb-success, .pb-success__icon, .pb-receipt {
			animation: none;
		}
	}
</style>
