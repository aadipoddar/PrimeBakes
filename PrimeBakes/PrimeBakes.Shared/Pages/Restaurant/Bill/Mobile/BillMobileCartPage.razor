@attribute [Route(RestaurantRouteNames.BillMobileCart)]
@attribute [Route($"{RestaurantRouteNames.BillMobileCart}/table/{{DiningTableId:int}}")]

@using PrimeBakesLibrary.Restaurant.Bill.Models

<PageTitle>Bill Cart - Prime Bakes</PageTitle>

<HeadContent>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet" />
</HeadContent>

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	var newUnits = (int)_cart.Sum(c => c.Quantity);
	var newTotal = _cart.Sum(c => c.Rate * c.Quantity);

	<div class="pb-screen">
		<div class="pb-header">
			<div class="pb-header__main">
				<div class="pb-header__sub">
					@(_diningArea?.Name ?? "Dining")
					@if (_runningBill is not null)
					{
						<text> · #@_runningBill.TransactionNo</text>
					}
				</div>
				<h1 class="pb-header__title">@(_diningTable.Name) cart</h1>
			</div>
			<div class="pb-header__actions">
				<button type="button" class="pb-icon-btn"
						@onclick='() => NavigationManager.NavigateTo($"{RestaurantRouteNames.BillMobile}/table/{_diningTable.Id}")'
						aria-label="Back to menu">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
				</button>
			</div>
		</div>

		<div class="pb-scroll">
			@if (_cart.Count == 0 && _previousCart.Count == 0)
			{
				<div class="pb-empty">
					<div class="pb-empty__icon">
						<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
							<path d="M5 7h14l-1.5 9a2 2 0 01-2 1.7H8.5a2 2 0 01-2-1.7L5 7z" />
							<path d="M9 7V5a3 3 0 116 0v2" />
						</svg>
					</div>
					<h2 class="pb-empty__title">Bill is empty</h2>
					<p class="pb-empty__sub">Add items from the menu to get started.</p>
					<button type="button" class="pb-add-btn pb-empty__cta"
							@onclick='() => NavigationManager.NavigateTo($"{RestaurantRouteNames.BillMobile}/table/{_diningTable.Id}")'
							disabled="@_isProcessing">
						Back to menu
					</button>
				</div>
			}
			else
			{
				@if (_cart.Count > 0)
				{
					<div class="pb-section">
						<div class="pb-section__head">
							<p class="pb-section__title">New items</p>
							<span class="pb-section__count">@_cart.Count lines · @newUnits qty</span>
						</div>
						@foreach (var item in _cart)
						{
							<div class="pb-cart-row" @key="item.ItemId">
								<div class="pb-cart-row__top">
									<p class="pb-product__name">@item.ItemName</p>
									<div class="pb-cart-row__total">₹@((item.Rate * item.Quantity).ToString("N0"))</div>
								</div>
								<div class="pb-product__meta">₹@item.Rate.ToString("N0") each</div>

								<div class="pb-cart-row__controls">
									<div class="pb-qty">
										<button type="button" class="pb-qty__btn" disabled="@(_isProcessing || item.Quantity <= 0)"
												@onclick="@(() => UpdateQuantity(item, item.Quantity - 1))" aria-label="Decrease">
											<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /></svg>
										</button>
										<input type="tel" inputmode="numeric" pattern="[0-9]*" class="pb-qty__input"
											   value="@((int)item.Quantity)" disabled="@_isProcessing"
											   @onchange="@(e => OnQuantityInput(item, e.Value?.ToString()))" />
										<button type="button" class="pb-qty__btn" disabled="@_isProcessing"
												@onclick="@(() => UpdateQuantity(item, item.Quantity + 1))" aria-label="Increase">
											<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14" /></svg>
										</button>
									</div>
									<input class="pb-remarks-input" placeholder="Kitchen instructions…"
										   value="@item.Remarks" disabled="@_isProcessing"
										   @onchange="@(e => UpdateRemarks(item, e.Value?.ToString()))" />
								</div>
							</div>
						}
					</div>
				}

				@if (_previousCart.Count > 0)
				{
					<div class="pb-section pb-section--sent">
						<div class="pb-section__head">
							<p class="pb-section__title">Previously sent</p>
							<span class="pb-section__count pb-section__count--sent">
								<span class="pb-dot pb-dot--terra"></span>KOT · read-only
							</span>
						</div>
						<div class="pb-sent">
							@foreach (var item in _previousCart)
							{
								<div class="pb-sent__row" @key="item.ItemId">
									<div class="pb-sent__head">
										<p class="pb-product__name">@item.ItemName</p>
										<span class="pb-sent__amt">₹@item.Total.ToString("N0")</span>
									</div>
									<div class="pb-product__meta">@(((int)item.Quantity)) × ₹@item.Rate.ToString("N0")</div>
									@if (!string.IsNullOrWhiteSpace(item.Remarks))
									{
										<div class="pb-sent__remarks">✱ @item.Remarks</div>
									}
								</div>
							}
						</div>
					</div>
				}

				<div class="pb-scroll__bottom-pad"></div>
			}
		</div>

		@if (_cart.Count > 0 || _previousCart.Count > 0)
		{
			<div class="pb-cta-bar">
				<button type="button" class="pb-cta" @onclick="GoToPayment" disabled="@_isProcessing">
					<span class="pb-cta__side">
						@(_isProcessing ? "Please wait…" : "Settle bill")
					</span>
					<span class="pb-cta__side">
						<span class="pb-cta__price">₹@newTotal.ToString("N0")</span>
						<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
							<path d="M5 12h14" />
							<path d="M13 5l7 7-7 7" />
						</svg>
					</span>
				</button>
			</div>
		}
	</div>
}

<style>
	.pb-screen {
		--bg-app: #f7f2ea;
		--surface: #ffffff;
		--surface-2: #faf5ec;
		--surface-3: #f1ebdf;
		--ink-1: #1d1813;
		--ink-2: #5a5147;
		--ink-3: #9a8f7f;
		--line-1: #ece4d3;
		--line-2: #ddd2bd;
		--rouge: #b13a5e;
		--rouge-dark: #8a2748;
		--rouge-tint: #fdf6f8;
		--moss: #4f7a5a;
		--terra: #b85a3c;
		--butter-soft: #f6e9cd;
		--r-sm: 12px;
		--r-md: 16px;
		--r-lg: 22px;
		--r-pill: 999px;
		--ff-sans: "Plus Jakarta Sans", -apple-system, system-ui, sans-serif;
		--ff-mono: "JetBrains Mono", ui-monospace, monospace;
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: var(--bg-app);
		color: var(--ink-1);
		font-family: var(--ff-sans);
		font-size: 15px;
		line-height: 1.4;
		letter-spacing: -0.005em;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		z-index: 1;
	}

		.pb-screen *,
		.pb-screen *::before,
		.pb-screen *::after {
			box-sizing: border-box;
		}

	/* Header */
	.pb-header {
		padding: 14px 22px 14px;
		padding-top: max(14px, env(safe-area-inset-top));
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 12px;
		flex-shrink: 0;
	}

	.pb-header__main {
		min-width: 0;
	}

	.pb-header__sub {
		font-size: 12.5px;
		color: var(--ink-3);
		margin-bottom: 6px;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		font-weight: 500;
		font-variant-numeric: tabular-nums;
	}

	.pb-header__title {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 26px;
		letter-spacing: -0.025em;
		line-height: 1.15;
		margin: 0;
		color: var(--ink-1);
	}

	.pb-header__actions {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.pb-icon-btn {
		width: 38px;
		height: 38px;
		border-radius: var(--r-pill);
		background: var(--surface);
		border: 1px solid var(--line-1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-2);
		cursor: pointer;
		flex-shrink: 0;
		padding: 0;
	}

		.pb-icon-btn:active {
			transform: scale(0.96);
		}

	/* Scroll */
	.pb-scroll {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}

		.pb-scroll::-webkit-scrollbar {
			display: none;
		}

	.pb-scroll__bottom-pad {
		height: 16px;
	}

	/* Section */
	.pb-section {
		margin: 0 18px 16px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		overflow: hidden;
	}

	.pb-section--sent {
		background: var(--butter-soft);
		border-color: var(--line-2);
	}

	.pb-section__head {
		padding: 14px 18px 8px;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
	}

	.pb-section__title {
		font-size: 11.5px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin: 0;
	}

	.pb-section__count {
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.04em;
		font-variant-numeric: tabular-nums;
	}

	.pb-section__count--sent {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.pb-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		display: inline-block;
	}

	.pb-dot--terra {
		background: var(--terra);
	}

	/* New item rows */
	.pb-cart-row {
		padding: 14px 18px;
		border-top: 1px solid var(--line-1);
	}

	.pb-cart-row__top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 10px;
	}

	.pb-product__name {
		font-size: 14.5px;
		font-weight: 500;
		letter-spacing: -0.01em;
		margin: 0;
		color: var(--ink-1);
		flex: 1;
		min-width: 0;
		white-space: normal;
		word-break: break-word;
		overflow-wrap: anywhere;
		line-height: 1.35;
	}

	.pb-cart-row__total {
		font-weight: 600;
		font-size: 15px;
		color: var(--ink-1);
		font-variant-numeric: tabular-nums;
		letter-spacing: -0.01em;
		flex-shrink: 0;
	}

	.pb-product__meta {
		font-size: 12px;
		color: var(--ink-3);
		margin-top: 2px;
		letter-spacing: 0.01em;
		font-variant-numeric: tabular-nums;
	}

	.pb-cart-row__controls {
		display: flex;
		align-items: center;
		gap: 10px;
		margin-top: 10px;
	}

	.pb-remarks-input {
		flex: 1;
		min-width: 0;
		height: 36px;
		padding: 0 14px;
		border-radius: var(--r-pill);
		border: 1px dashed var(--line-2);
		background: var(--surface);
		font-family: var(--ff-sans);
		font-size: 12.5px;
		color: var(--ink-1);
		outline: none;
	}

		.pb-remarks-input::placeholder {
			color: var(--ink-3);
		}

		.pb-remarks-input:focus {
			border-style: solid;
			border-color: var(--ink-1);
		}

	/* Qty */
	.pb-qty {
		display: inline-flex;
		align-items: stretch;
		background: var(--surface);
		border: 1px solid var(--line-2);
		border-radius: 12px;
		overflow: hidden;
		height: 36px;
		flex-shrink: 0;
	}

	.pb-qty__btn {
		width: 34px;
		background: var(--surface-2);
		border: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-1);
		cursor: pointer;
		padding: 0;
		font-size: 16px;
	}

		.pb-qty__btn:active {
			background: var(--surface-3);
		}

		.pb-qty__btn:disabled {
			color: var(--ink-3);
			cursor: not-allowed;
			opacity: 0.5;
		}

	.pb-qty__input {
		width: 46px;
		border: 0;
		border-left: 1px solid var(--line-1);
		border-right: 1px solid var(--line-1);
		background: var(--surface);
		font-family: var(--ff-sans);
		font-size: 14.5px;
		font-weight: 700;
		color: var(--ink-1);
		text-align: center;
		font-variant-numeric: tabular-nums;
		padding: 0 4px;
		outline: none;
		-moz-appearance: textfield;
		appearance: textfield;
	}

		.pb-qty__input::-webkit-outer-spin-button,
		.pb-qty__input::-webkit-inner-spin-button {
			-webkit-appearance: none;
			margin: 0;
		}

		.pb-qty__input:focus {
			background: var(--rouge-tint);
			color: var(--rouge-dark);
		}

	/* Previously sent */
	.pb-sent {
		padding: 2px 18px 16px;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.pb-sent__head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 12px;
	}

	.pb-sent__amt {
		font-weight: 600;
		font-size: 14px;
		color: var(--ink-1);
		font-variant-numeric: tabular-nums;
		flex-shrink: 0;
	}

	.pb-sent__remarks {
		margin-top: 6px;
		font-size: 12px;
		font-style: italic;
		color: var(--ink-2);
		letter-spacing: -0.005em;
	}

	/* Empty */
	.pb-empty {
		margin: 18px;
		padding: 48px 24px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}

	.pb-empty__icon {
		width: 64px;
		height: 64px;
		border-radius: 999px;
		background: var(--surface-3);
		color: var(--ink-3);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 8px;
	}

	.pb-empty__title {
		margin: 0;
		font-size: 20px;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--ink-1);
	}

	.pb-empty__sub {
		margin: 0 0 12px;
		color: var(--ink-3);
		font-size: 14px;
	}

	.pb-empty__cta {
		padding: 0 22px;
	}

	.pb-add-btn {
		background: var(--ink-1);
		color: #fff;
		border: 0;
		border-radius: 12px;
		padding: 0 18px;
		height: 36px;
		font-family: var(--ff-sans);
		font-size: 13.5px;
		font-weight: 600;
		letter-spacing: -0.005em;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
	}

		.pb-add-btn:disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}

	/* CTA */
	.pb-cta-bar {
		flex-shrink: 0;
		padding: 12px 18px 14px;
		padding-bottom: max(14px, env(safe-area-inset-bottom));
		background: linear-gradient(to top, var(--bg-app) 60%, rgba(247, 242, 234, 0));
		position: relative;
	}

	.pb-cta {
		width: 100%;
		background: var(--ink-1);
		color: #fff;
		border: 0;
		border-radius: 18px;
		padding: 16px 20px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		font-size: 15px;
		font-weight: 500;
		cursor: pointer;
		letter-spacing: -0.005em;
		font-family: var(--ff-sans);
	}

		.pb-cta:active:not(:disabled) {
			transform: scale(0.99);
		}

		.pb-cta:disabled {
			opacity: 0.6;
			cursor: not-allowed;
		}

	.pb-cta__side {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.pb-cta__price {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 17px;
		letter-spacing: -0.015em;
		font-variant-numeric: tabular-nums;
	}
</style>
