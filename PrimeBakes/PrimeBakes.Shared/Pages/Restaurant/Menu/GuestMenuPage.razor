@using PrimeBakes.Library.Store.Product.Models

@attribute [Route(RestaurantRouteNames.Menu + "/{LocationId:int}")]

<PageTitle>Menu - Prime Bakes</PageTitle>

<HeadContent>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&family=Instrument+Serif:ital@@0;1&display=swap" rel="stylesheet" />
</HeadContent>

@if (_isLoading)
{
	<LoadingScreen />
}
else
{
	var items = GetItems();

	<div class="pb-screen">

		@* ── Header ── *@
		<div class="pb-menu-header">
			<div class="pb-menu-eyebrow">@(_location?.Name ?? "Our Menu")</div>
			<div class="pb-menu-brand">Prime Bakes</div>
			<div class="pb-menu-tagline">All-day bakery &amp; café</div>

			@if (_categories.Count > 0)
			{
				<div class="pb-menu-diets">
					@foreach (var ft in FoodTypeOptions.FoodTypes)
					{
						var code = DietCode(ft);
						var on = _diets.Contains(code);
						<button type="button" class="pb-dietchip pb-dietchip--@(code) @(on ? "is-on" : "")"
								@onclick="@(() => ToggleDiet(code))" aria-pressed="@on">
							<span class="pb-diet pb-diet--@(code)"><i></i></span>@ft
						</button>
					}
					@if (_diets.Count > 0)
					{
						<button type="button" class="pb-dietclear" @onclick="ClearDiets">
							<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
							Clear
						</button>
					}
				</div>
			}
		</div>

		@* ── Category tabs ── *@
		@if (_categories.Count > 0)
		{
			<div class="pb-chips">
				@foreach (var cat in _categories)
				{
					<button type="button" class="pb-chip @(cat.Id == _selectedCategory?.Id ? "is-active" : "")"
							@onclick="@(() => SelectCategory(cat))">
						@cat.Name
					</button>
				}
			</div>
		}

		@* ── Body ── *@
		<div class="pb-scroll">
			<div class="pb-card">
				<div class="pb-card__toolbar">
					<div class="pb-search">
						<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="7" />
							<path d="M20 20l-3.5-3.5" />
						</svg>
						<input placeholder="Search the menu…" value="@_query" @oninput="OnQueryChange" />
						@if (!string.IsNullOrWhiteSpace(_query))
						{
							<button type="button" class="pb-search__clear" @onclick="ClearQuery" aria-label="Clear search">
								<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
							</button>
						}
					</div>
				</div>

				@if (_categories.Count == 0)
				{
					<div class="pb-empty">
						<div class="pb-empty__title">Menu coming soon</div>
						<div class="pb-empty__sub">There are no items on this outlet's menu yet.</div>
					</div>
				}
				else if (items.Count == 0)
				{
					<div class="pb-empty">
						<div class="pb-empty__title">Nothing found</div>
						<div class="pb-empty__sub">@(IsFiltering ? "No items match your filters. Try clearing them." : "No items in this category.")</div>
					</div>
				}
				else
				{
					<div class="pb-items">
						@foreach (var item in items)
						{
							<div class="pb-item" @key="item.ProductId">
								<span class="pb-diet pb-diet--@DietCode(item.FoodType)"><i></i></span>
								<div class="pb-item__main">
									<span class="pb-item__name">@item.Name</span>
									@if (!string.IsNullOrWhiteSpace(item.Remarks))
									{
										<div class="pb-item__desc">@item.Remarks</div>
									}
								</div>
								<div class="pb-item__price">@Money(item.Rate)</div>
							</div>
						}
					</div>
				}
			</div>
			<div class="pb-scroll__pad"></div>
		</div>
	</div>
}

<style>
	.pb-screen {
		--bg-app: #f7f2ea;
		--surface: #ffffff;
		--surface-2: #faf5ec;
		--surface-3: #f1ebdf;
		--ink-1: #1d1813;
		--ink-2: #5a5147;
		--ink-3: #9a8f7f;
		--line-1: #ece4d3;
		--line-2: #ddd2bd;
		--rouge: #b13a5e;
		--butter: #c89343;
		--butter-soft: #f6e9cd;
		--moss: #4f7a5a;
		--moss-soft: #e3ecdd;
		--terra: #b85a3c;
		--terra-soft: #f5dccf;
		--r-lg: 22px;
		--r-pill: 999px;
		--ff-sans: "Plus Jakarta Sans", -apple-system, system-ui, sans-serif;
		--ff-serif: "Instrument Serif", Georgia, serif;
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: var(--bg-app);
		color: var(--ink-1);
		font-family: var(--ff-sans);
		font-size: 15px;
		line-height: 1.4;
		letter-spacing: -0.005em;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		z-index: 1;
	}

		.pb-screen *,
		.pb-screen *::before,
		.pb-screen *::after {
			box-sizing: border-box;
		}

	/* ── Header ── */
	.pb-menu-header {
		flex-shrink: 0;
		padding: calc(18px + env(safe-area-inset-top)) 24px 16px;
		text-align: center;
		background: linear-gradient(180deg, var(--surface-2) 0%, var(--bg-app) 100%);
	}

	.pb-menu-eyebrow {
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--rouge);
	}

	.pb-menu-brand {
		font-family: var(--ff-serif);
		font-size: 40px;
		line-height: 1;
		color: var(--ink-1);
		margin-top: 8px;
		letter-spacing: -0.01em;
	}

	.pb-menu-tagline {
		font-size: 13px;
		color: var(--ink-2);
		margin-top: 8px;
		letter-spacing: 0.01em;
	}

	.pb-menu-diets {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin-top: 16px;
		flex-wrap: wrap;
	}

	/* ── Diet filter chips ── */
	.pb-dietchip {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		cursor: pointer;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: -0.005em;
		padding: 7px 13px;
		border-radius: var(--r-pill);
		border: 1px solid var(--line-1);
		background: var(--surface);
		color: var(--ink-2);
		font-family: var(--ff-sans);
		transition: background 0.12s ease, border-color 0.12s ease;
	}

		.pb-dietchip.is-on {
			color: var(--ink-1);
		}

		.pb-dietchip--v.is-on {
			border-color: var(--moss);
			background: var(--moss-soft);
		}

		.pb-dietchip--e.is-on {
			border-color: var(--butter);
			background: var(--butter-soft);
		}

		.pb-dietchip--n.is-on {
			border-color: var(--terra);
			background: var(--terra-soft);
		}

	.pb-dietclear {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		cursor: pointer;
		font-size: 12px;
		font-weight: 600;
		padding: 7px 11px;
		border-radius: var(--r-pill);
		border: 1px solid var(--line-1);
		background: transparent;
		color: var(--ink-3);
		font-family: var(--ff-sans);
	}

	/* ── Diet mark (FSSAI-style) ── */
	.pb-diet {
		width: 14px;
		height: 14px;
		border: 1.5px solid var(--line-2);
		border-radius: 3px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

		.pb-diet i {
			width: 7px;
			height: 7px;
			display: block;
			background: var(--ink-3);
			border-radius: 50%;
		}

	.pb-diet--v {
		border-color: var(--moss);
	}

		.pb-diet--v i {
			background: var(--moss);
		}

	.pb-diet--e {
		border-color: var(--butter);
	}

		.pb-diet--e i {
			background: var(--butter);
		}

	.pb-diet--n {
		border-color: var(--terra);
	}

		.pb-diet--n i {
			background: var(--terra);
			border-radius: 0;
			clip-path: polygon(50% 0, 100% 100%, 0 100%);
		}

	/* ── Category tabs ── */
	.pb-chips {
		display: flex;
		gap: 8px;
		overflow-x: auto;
		overflow-y: hidden;
		padding: 12px 18px;
		scrollbar-width: none;
		flex-shrink: 0;
	}

		.pb-chips::-webkit-scrollbar {
			display: none;
		}

	.pb-chip {
		flex-shrink: 0;
		padding: 8px 14px;
		border-radius: var(--r-pill);
		font-size: 13.5px;
		font-weight: 500;
		letter-spacing: -0.005em;
		background: var(--surface);
		color: var(--ink-2);
		border: 1px solid var(--line-1);
		white-space: nowrap;
		cursor: pointer;
		font-family: var(--ff-sans);
		line-height: 1.2;
	}

		.pb-chip.is-active {
			background: var(--ink-1);
			color: #fff;
			border-color: var(--ink-1);
		}

	/* ── Scroll / body ── */
	.pb-scroll {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}

		.pb-scroll::-webkit-scrollbar {
			display: none;
		}

	.pb-scroll__pad {
		height: 8px;
	}

	.pb-card {
		margin: 14px 18px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		overflow: hidden;
	}

	.pb-card__toolbar {
		padding: 12px 14px;
		border-bottom: 1px solid var(--line-1);
	}

	.pb-search {
		display: flex;
		align-items: center;
		gap: 10px;
		background: var(--surface-2);
		border: 1px solid var(--line-1);
		border-radius: 12px;
		padding: 10px 13px;
		color: var(--ink-3);
	}

		.pb-search input {
			flex: 1;
			border: 0;
			background: transparent;
			outline: none;
			font: 500 14.5px var(--ff-sans);
			color: var(--ink-1);
			padding: 0;
			letter-spacing: -0.005em;
			min-width: 0;
		}

			.pb-search input::placeholder {
				color: var(--ink-3);
				font-weight: 400;
			}

	.pb-search__clear {
		background: transparent;
		border: 0;
		color: var(--ink-3);
		cursor: pointer;
		padding: 2px;
		display: inline-flex;
	}

	/* ── Items ── */
	.pb-item {
		display: flex;
		gap: 12px;
		align-items: flex-start;
		padding: 14px 18px;
		border-bottom: 1px solid var(--line-1);
	}

		.pb-item:last-of-type {
			border-bottom: 0;
		}

		.pb-item .pb-diet {
			margin-top: 2px;
		}

	.pb-item__main {
		flex: 1;
		min-width: 0;
	}

	.pb-item__name {
		font-size: 15.5px;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--ink-1);
		word-break: break-word;
		overflow-wrap: anywhere;
		line-height: 1.35;
	}

	.pb-item__desc {
		font-size: 13px;
		color: var(--ink-3);
		margin-top: 3px;
		letter-spacing: 0.005em;
		line-height: 1.4;
		word-break: break-word;
		overflow-wrap: anywhere;
	}

	.pb-item__price {
		font-size: 15.5px;
		font-weight: 700;
		color: var(--ink-1);
		font-variant-numeric: tabular-nums;
		letter-spacing: -0.01em;
		flex-shrink: 0;
	}

	/* ── Empty state ── */
	.pb-empty {
		text-align: center;
		padding: 48px 24px;
	}

	.pb-empty__title {
		font-family: var(--ff-serif);
		font-size: 24px;
		font-style: italic;
		color: var(--ink-2);
	}

	.pb-empty__sub {
		font-size: 13px;
		color: var(--ink-3);
		margin-top: 8px;
	}
</style>
