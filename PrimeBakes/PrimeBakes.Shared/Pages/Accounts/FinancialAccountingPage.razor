@using PrimeBakes.Library.Accounts.FinancialAccounting.Models
@using PrimeBakes.Library.Accounts.Masters.Models

@attribute [Route(AccountsRouteNames.FinancialAccounting)]
@attribute [Route(AccountsRouteNames.FinancialAccounting + "/{Id:int}")]

<PageTitle>Financial Accounting - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _sfLedgerAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.FinancialAccountingReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="() => EditSelectedCartItem()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="() => RemoveSelectedCartItem()" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_accounting.Id > 0 ? $"Edit Financial Accounting {_accounting.TransactionNo}" : "Create Financial Accounting")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Accounting Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.FinancialAccountingReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Ledger Report" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.AccountingLedgerReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Bank Reconciliation" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.BankReconciliation, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Trial Balance" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.TrialBalanceReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Profit & Loss" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.ProfitAndLossReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Balance Sheet" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.BalanceSheetReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="two-column-layout">

				<!-- Transaction -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Transaction</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">
							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete @ref="_firstFocus" T="CompanyModel"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="Select Company"
													Label="Company (Ctrl + F)"
													ValueChanged="OnCompanyChanged"
													FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@AccountsRouteNames.CompanyMaster" />
							</div>

							<!-- Voucher -->
							<div class="form-field">
								<CustomAutoComplete T="VoucherModel"
													Value="_selectedVoucher"
													DataSource="@_vouchers"
													Placeholder="Select Voucher"
													Label="Voucher"
													ValueChanged="OnVoucherChanged"
													FieldValue="@nameof(VoucherModel.Name)"
													AddNewRoute="@AccountsRouteNames.VoucherMaster" />
							</div>

							<!-- Transaction Date -->
							<div class="form-field">
								<CustomDatePicker @bind-Value="_accounting.TransactionDateTime"
												  FinancialYear="@_selectedFinancialYear" />
							</div>

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_accounting.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Enter Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							@if (_accounting.Id > 0 && _accounting.ReferenceId is not null && _accounting.ReferenceId > 0)
							{
								<!-- Reference No -->
								<div class="form-field">
									<div class="reference-wrapper">
										<CustomTextField @bind-Value="_accounting.ReferenceNo"
														 Label="Reference No"
														 Placeholder="Enter Reference No"
														 ReadOnly="true" />
										@if (!string.IsNullOrWhiteSpace(_accounting.ReferenceNo))
										{
											<div class="reference-actions">
												<IconButton Icon="IconType.View" Variant="ButtonVariant.View"
															Size="ButtonSize.Small" Title="View Transaction"
															OnClick="ViewReferenceTransaction" />
											</div>
										}
									</div>
								</div>
							}

							<!-- Remarks -->
							<div class="form-field">
								<CustomTextField @bind-Value="_accounting.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>
						</div>
					</div>
				</div>

				<!-- Financial -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Financial</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">
							<!-- Total Credit -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_accounting.TotalCreditAmount"
													Placeholder="0.00"
													Label="Total Credit"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<!-- Total Debit -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_accounting.TotalDebitAmount"
													Placeholder="0.00"
													Label="Total Debit"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							<hr class="form-divider" />

							<!-- Difference -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="@(_accounting.TotalDebitAmount - _accounting.TotalCreditAmount)"
													Placeholder="0.00"
													Label="Difference"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="two-column-layout-equal">

				<!-- Add to Cart -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Add Items to Cart</h2>
					</div>

					<div class="section-body">
						<!-- Single Row: All Components -->
						<div class="cart-input-row">

							<div class="cart-field cart-field-ultra-wide">
								<div class="reference-wrapper">
									<CustomAutoComplete @ref="_sfLedgerAutoComplete" T="LedgerModel"
														Value="_selectedLedger"
														DataSource="@_ledgers"
														Placeholder="Select Ledger"
														Label="Ledger (Ctrl + G)"
														ValueChanged="OnItemChanged" OpenOnFocus="false"
														FieldValue="@nameof(LedgerModel.Name)"
														AddNewRoute="@AccountsRouteNames.LedgerMaster" />

									@if (_showReferenceInstrument)
									{
										<div class="reference-actions">
											<IconButton Icon="IconType.Get" Variant="ButtonVariant.Get" Size="ButtonSize.Small"
														Title="Get References" OnClick="GetReferences" />
										</div>
									}
								</div>
							</div>

							@if (_showReferenceInstrument)
							{
								<div class="cart-field cart-field-wide">
									<div class="reference-wrapper">
										<CustomAutoComplete T="FinancialAccountingLedgerOverviewModel"
															Value="_selectedAccountingLedger"
															DataSource="@_accountingLedgers"
															Placeholder="Select Reference"
															Label="Reference No" Required="false"
															ValueChanged="OnReferenceChanged"
															FieldValue="@nameof(FinancialAccountingLedgerOverviewModel.LedgerReferenceNo)" />
										<div class="reference-actions">
											<IconButton Icon="IconType.View" Variant="ButtonVariant.View" Size="ButtonSize.Small"
														Title="View Transaction" OnClick="ViewCartReferenceTransaction" />
										</div>
									</div>
								</div>
							}

							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal?"
													@bind-Value="_selectedCart.Debit"
													Min="0"
													Label="Debit"
													Placeholder="0.00"
													Required="false" />
							</div>

							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal?"
													@bind-Value="_selectedCart.Credit"
													Min="0"
													Label="Credit"
													Placeholder="0.00"
													Required="false" />
							</div>

							@if (_showReferenceInstrument)
							{
								<div class="cart-field cart-field-wide">
									<CustomTextField @bind-Value="_selectedCart.InstrumentNo"
													 Label="Instrument No"
													 Placeholder="Cheque / UTR no..."
													 Required="false" />
								</div>

								<div class="cart-field cart-field-wide">
									<CustomDatePicker @bind-NullableValue="_selectedCart.InstrumentDate"
													  Label="Instrument Date"
													  Required="false"
													  ShowFinancialYear="false" />
								</div>
							}

							<div class="cart-field cart-field-ultra-wide">
								<CustomTextField @bind-Value="_selectedCart.Remarks"
												 Label="Remarks"
												 Placeholder="Entry narration..."
												 Required="false" />
							</div>

							<div class="cart-field cart-field-wide">
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart"
											OnClick="AddItemToCart" />
							</div>
						</div>
					</div>
				</div>

				<!-- Cart -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Cart</h2>
					</div>

					
					<SfGrid @ref="_sfCartGrid" DataSource="_cart"
							AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_cartGridContextMenuItems"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridEvents TValue="FinancialAccountingLedgerCartModel" ContextMenuItemClicked="OnCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridColumnAggregate Field="@nameof(FinancialAccountingLedgerCartModel.LedgerName)" Type="AggregateType.Count" Format="N0" />
									<GridColumnAggregate Field="@nameof(FinancialAccountingLedgerCartModel.Debit)" CustomColor="grid-debit" />
									<GridColumnAggregate Field="@nameof(FinancialAccountingLedgerCartModel.Credit)" CustomColor="grid-credit" />
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.LedgerName)" HeaderText="Ledger Name" />
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.Debit)" HeaderText="Debit" CustomColor="grid-debit" />
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.Credit)" HeaderText="Credit" CustomColor="grid-credit" />
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.ReferenceType)" HeaderText="Ref Type" Visible="_showReferenceInstrument" />
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.ReferenceNo)" HeaderText="Ref No" Visible="_showReferenceInstrument" />
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.InstrumentNo)" HeaderText="Instrument No" Visible="_showReferenceInstrument" />
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.InstrumentDate)" HeaderText="Instrument Date" Format="dd/MM/yy" Type="ColumnType.DateTime" Visible="_showReferenceInstrument" />
							<CustomGridColumn Field="@nameof(FinancialAccountingLedgerCartModel.Remarks)" HeaderText="Remarks" Width="500" />
						</GridColumns>
					</SfGrid>
				</div>

			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />