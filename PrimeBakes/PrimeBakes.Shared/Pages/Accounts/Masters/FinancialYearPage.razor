@using PrimeBakes.Library.Accounts.Masters.Models

@attribute [Route(AccountsRouteNames.FinancialYearMaster)]

<PageTitle>Financial Year Management - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Financial Year Management">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudMenuItem Label="Auto Generate Next Year" OnClick="AutoGenerateNextYear" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Master Details</h2>
				</div>

				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomDatePicker @ref="_firstFocus"
											  Value="StartDateTime"
											  ValueChanged="OnStartDateChanged"
											  Label="Start Date (Ctrl + F)"
											  ShowFinancialYear="false" />
						</div>

						<div class="form-field">
							<CustomDatePicker Value="EndDateTime"
											  ValueChanged="OnEndDateChanged"
											  Label="End Date"
											  ShowFinancialYear="false" />
						</div>

						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_financialYear.YearNo"
												Label="Year No"
												Placeholder="Enter year number"
												Format="N0"
												Min="1" />
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_financialYear.Locked"
												Label="Is Locked" />
							</div>
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_financialYear.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Master List</h2>
				</div>

				<SfGrid @ref="_sfGrid" DataSource="@_financialYears"
						AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="FinancialYearModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridColumns>
						<CustomGridColumn Field="@nameof(FinancialYearModel.Id)" HeaderText="ID" Width="100" TextAlign="TextAlign.Center" />
						<CustomGridColumn Field="@nameof(FinancialYearModel.StartDate)" HeaderText="Start Date" TextAlign="TextAlign.Center" Format="dd-MMM-yyyy" />
						<CustomGridColumn Field="@nameof(FinancialYearModel.EndDate)" HeaderText="End Date" TextAlign="TextAlign.Center" Format="dd-MMM-yyyy" />
						<CustomGridColumn Field="@nameof(FinancialYearModel.YearNo)" HeaderText="Year No" TextAlign="TextAlign.Center" />
						<CustomGridColumn Field="@nameof(FinancialYearModel.Remarks)" HeaderText="Remarks" />
						<CustomGridColumn Field="@nameof(FinancialYearModel.Locked)" HeaderText="Locked" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
						<CustomGridColumn Field="@nameof(FinancialYearModel.Status)" Visible="_showDeleted" StatusColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
