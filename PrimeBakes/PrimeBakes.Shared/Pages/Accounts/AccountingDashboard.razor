@attribute [Route(PageRouteNames.AccountsDashboard)]

<PageTitle>Accounting - Prime Bakes</PageTitle>

@if (_isLoading || _user is null)
{
	<LoadingScreen Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="Accounting" />

		<div class="page-container">

			<!-- Entry Pages -->
			<div class="launchpad-section">
				<h2 class="launchpad-section-title">Entry Pages</h2>
				<div class="dashboard-grid">
					<FioriTile Title="Financial Accounting" Subtitle="Record journal entries and transactions" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialAccounting)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23" />
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
							</svg>
						</IconContent>
					</FioriTile>
				</div>
			</div>

			<!-- Financial Reports -->
			@if (_user.Reports)
			{
				<div class="launchpad-section">
					<h2 class="launchpad-section-title">Financial Reports</h2>
					<div class="dashboard-grid">
						<FioriTile Title="Financial Accounting Report" Subtitle="View accounting transaction history" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialAccountingReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
								</svg>
							</IconContent>
						</FioriTile>

						<FioriTile Title="Ledger Report" Subtitle="View detailed ledger transactions" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.AccountingLedgerReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
									<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
								</svg>
							</IconContent>
						</FioriTile>

						<FioriTile Title="Trial Balance" Subtitle="View trial balance summary" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.TrialBalanceReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
									<line x1="8" y1="21" x2="16" y2="21" />
									<line x1="12" y1="17" x2="12" y2="21" />
									<line x1="7" y1="7" x2="7" y2="11" />
									<line x1="12" y1="7" x2="12" y2="11" />
									<line x1="17" y1="7" x2="17" y2="11" />
								</svg>
							</IconContent>
						</FioriTile>

						<FioriTile Title="Profit &amp; Loss" Subtitle="View income and expense summary" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.ProfitAndLossReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<line x1="12" y1="1" x2="12" y2="23" />
									<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
								</svg>
							</IconContent>
						</FioriTile>

						<FioriTile Title="Balance Sheet" Subtitle="View assets, liabilities &amp; equity" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.BalanceSheetReport)">
							<IconContent>
								<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<line x1="12" y1="3" x2="12" y2="21" />
									<line x1="3" y1="6" x2="21" y2="6" />
									<path d="M5 6L3 12h4L5 6" />
									<path d="M19 6l-2 6h4l-2-6" />
									<line x1="7" y1="21" x2="17" y2="21" />
								</svg>
							</IconContent>
						</FioriTile>
					</div>
				</div>
			}

			<!-- Master Data -->
			<div class="launchpad-section">
				<h2 class="launchpad-section-title">Master Data</h2>
				<div class="dashboard-grid">
					<FioriTile Title="Ledgers" Subtitle="Manage ledger accounts" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.LedgerMaster)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="16" y1="13" x2="8" y2="13" />
								<line x1="16" y1="17" x2="8" y2="17" />
								<line x1="10" y1="9" x2="8" y2="9" />
							</svg>
						</IconContent>
					</FioriTile>

					<FioriTile Title="Group" Subtitle="Manage account groups" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.GroupMaster)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
								<circle cx="9" cy="7" r="4" />
								<path d="M23 21v-2a4 4 0 0 0-3-3.87" />
								<path d="M16 3.13a4 4 0 0 1 0 7.75" />
							</svg>
						</IconContent>
					</FioriTile>

					<FioriTile Title="Account Type" Subtitle="Manage account types" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.AccountTypeMaster)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
								<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
							</svg>
						</IconContent>
					</FioriTile>

					<FioriTile Title="Voucher" Subtitle="Manage voucher types" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.VoucherMaster)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="12" y1="18" x2="12" y2="12" />
								<line x1="9" y1="15" x2="15" y2="15" />
							</svg>
						</IconContent>
					</FioriTile>

					<FioriTile Title="Financial Years" Subtitle="Manage financial year periods" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.FinancialYearMaster)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
								<line x1="16" y1="2" x2="16" y2="6" />
								<line x1="8" y1="2" x2="8" y2="6" />
								<line x1="3" y1="10" x2="21" y2="10" />
							</svg>
						</IconContent>
					</FioriTile>

					<FioriTile Title="States" Subtitle="Manage state/UT information" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.StateUTMaster)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10" />
								<line x1="2" y1="12" x2="22" y2="12" />
								<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
							</svg>
						</IconContent>
					</FioriTile>

					<FioriTile Title="Company" Subtitle="Manage company settings" OnClick="() => NavigationManager.NavigateTo(PageRouteNames.CompanyMaster)">
						<IconContent>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
								<polyline points="9 22 9 12 15 12 15 22" />
							</svg>
						</IconContent>
					</FioriTile>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

<style>
	.launchpad-section {
		margin-bottom: 28px;
	}

	.launchpad-section-title {
		font-size: 15px;
		font-weight: 600;
		color: var(--gray-700, #334155);
		margin: 0 0 12px 0;
	}
</style>
