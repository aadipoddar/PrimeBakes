@using PrimeBakes.Library.Accounts.FinancialAccounting.Models
@using PrimeBakes.Library.Accounts.Masters.Models

@attribute [Route(AccountsRouteNames.TrialBalanceReport)]

<PageTitle>Trial Balance - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.FinancialAccounting, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTrialBalance" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTrialBalance" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />

@if (_isLoading)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Trial Balance">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.FinancialAccounting, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadTrialBalance" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="() => ToggleDetailsView()" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Accounting Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.FinancialAccountingReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Ledger Report" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.AccountingLedgerReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Bank Reconciliation" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.BankReconciliation, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Profit & Loss" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.ProfitAndLossReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Balance Sheet" OnClick="() => AuthenticationService.NavigateToRoute(AccountsRouteNames.BalanceSheetReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<!-- Date Range -->
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<!-- Company -->
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="All Companies"
												Label="Company" Required="false"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@AccountsRouteNames.CompanyMaster" />
						</div>

						<!-- Group -->
						<div class="form-field">
							<CustomAutoComplete T="GroupModel"
												Value="_selectedGroup"
												DataSource="@_groups"
												Placeholder="All Groups"
												Label="Group" Required="false"
												ValueChanged="OnGroupChanged"
												FieldValue="@nameof(GroupModel.Name)"
												AddNewRoute="@AccountsRouteNames.GroupMaster" />
						</div>

						<!-- Account Type -->
						<div class="form-field">
							<CustomAutoComplete T="AccountTypeModel"
												Value="_selectedAccountType"
												DataSource="@_accountTypes"
												Placeholder="All Account Types"
												Label="Account Type" Required="false"
												ValueChanged="OnAccountTypeChanged"
												FieldValue="@nameof(AccountTypeModel.Name)"
												AddNewRoute="@AccountsRouteNames.AccountTypeMaster" />
						</div>
					</div>

				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<SfGrid @ref="_sfGrid" TValue="TrialBalanceModel" DataSource="_trialBalance"
						AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "10", "20", "50", "100", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>

								<GridColumnAggregate Field="@nameof(TrialBalanceModel.LedgerName)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.OpeningBalance)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.OpeningDebit)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.OpeningCredit)" CustomColor="grid-credit" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.Debit)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.Credit)" CustomColor="grid-credit" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.ClosingDebit)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.ClosingCredit)" CustomColor="grid-credit" />
								<GridColumnAggregate Field="@nameof(TrialBalanceModel.ClosingBalance)" CustomColor="grid-total" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(TrialBalanceModel.LedgerName)" HeaderText="Ledger Name" />
						<CustomGridColumn Field="@nameof(TrialBalanceModel.LedgerCode)" HeaderText="Code" Visible="_showAllColumns" />
						<CustomGridColumn Field="@nameof(TrialBalanceModel.GroupName)" HeaderText="Group" />
						<CustomGridColumn Field="@nameof(TrialBalanceModel.AccountTypeName)" HeaderText="Account Type" />

						<CustomGridColumn Field="@nameof(TrialBalanceModel.OpeningBalance)" HeaderText="Opening Balance" NumericColumn="true" />
						
						<CustomGridColumn Field="@nameof(TrialBalanceModel.OpeningDebit)" HeaderText="Opening Debit" Visible="_showAllColumns" CustomColor="grid-debit"/>
						<CustomGridColumn Field="@nameof(TrialBalanceModel.OpeningCredit)" HeaderText="Opening Credit" Visible="_showAllColumns" CustomColor="grid-credit" />

						<CustomGridColumn Field="@nameof(TrialBalanceModel.Debit)" HeaderText="Debit" CustomColor="grid-debit"/>
						<CustomGridColumn Field="@nameof(TrialBalanceModel.Credit)" HeaderText="Credit" CustomColor="grid-credit"/>

						<CustomGridColumn Field="@nameof(TrialBalanceModel.ClosingDebit)" HeaderText="Closing Debit" Visible="_showAllColumns" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(TrialBalanceModel.ClosingCredit)" HeaderText="Closing Credit" Visible="_showAllColumns" CustomColor="grid-credit" />

						<CustomGridColumn Field="@nameof(TrialBalanceModel.ClosingBalance)" HeaderText="Closing Balance" NumericColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
