@attribute [Route(StoreRouteNames.OrderMobileCart)]

<PageTitle>Order Cart - Prime Bakes</PageTitle>

<HeadContent>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet" />
</HeadContent>

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	var pageSize = 6;
	var allItems = GetFilteredCart();
	var pageCount = Math.Max(1, (int)Math.Ceiling(allItems.Count / (double)pageSize));
	var safePage = Math.Max(0, Math.Min(_page, pageCount - 1));
	var paged = allItems.Skip(safePage * pageSize).Take(pageSize).ToList();
	var totalQty = (int)_cart.Sum(c => c.Quantity);
	var productCount = _cart.Count;

	<div class="pb-screen">
		<div class="pb-header">
			<div class="pb-header__main">
				<div class="pb-header__sub">@productCount products · @totalQty units</div>
				<h1 class="pb-header__title">Cart</h1>
			</div>
			<div class="pb-header__actions">
				<button type="button" class="pb-icon-btn"
						@onclick="@(() => NavigationManager.NavigateTo(StoreRouteNames.OrderMobile))"
						aria-label="Back to catalog">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
				</button>
				<button type="button" class="pb-icon-btn"
						@onclick="@(() => NavigationManager.NavigateTo(OperationRouteNames.Dashboard))"
						aria-label="Home">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
						<path d="M3 11l9-8 9 8" />
						<path d="M5 10v10h5v-6h4v6h5V10" />
					</svg>
				</button>
			</div>
		</div>

		<div class="pb-scroll">
			@if (_cart.Count == 0)
			{
				<div class="pb-empty">
					<div class="pb-empty__icon">
						<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
							<path d="M5 7h14l-1.5 9a2 2 0 01-2 1.7H8.5a2 2 0 01-2-1.7L5 7z" />
							<path d="M9 7V5a3 3 0 116 0v2" />
						</svg>
					</div>
					<h2 class="pb-empty__title">Cart is empty</h2>
					<p class="pb-empty__sub">Add products from the catalog to get started.</p>
					<button type="button" class="pb-add-btn pb-empty__cta"
							@onclick="@(() => NavigationManager.NavigateTo(StoreRouteNames.OrderMobile))"
							disabled="@_isProcessing">
						Back to catalog
					</button>
				</div>
			}
			else
			{
				<div class="pb-grid">
					<div class="pb-grid__toolbar">
						<div class="pb-grid__search">
							<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="11" cy="11" r="7" />
								<path d="M20 20l-3.5-3.5" />
							</svg>
							<input placeholder="Search cart…" value="@_query"
								   @oninput="@(e => OnQueryChange(e.Value?.ToString()))" />
							@if (!string.IsNullOrWhiteSpace(_query))
							{
								<button type="button" class="pb-grid__search-clear" @onclick="() => OnQueryChange(null)" aria-label="Clear search">
									<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
								</button>
							}
						</div>
					</div>

					<div class="pb-grid__head">
						<span class="pb-grid__head--product">Product</span>
						<span class="pb-grid__head--qty">Quantity</span>
					</div>

					@if (paged.Count == 0)
					{
						<div class="pb-grid__empty">
							No products match &ldquo;@_query&rdquo;.
						</div>
					}
					else
					{
						@foreach (var item in paged)
						{
							<div class="pb-grid__row" @key="item.ItemId">
								<div class="pb-grid__row-info">
									<p class="pb-product__name">@item.ItemName</p>
								</div>
								<div class="pb-grid__row-actions pb-grid__row-actions--wide">
									<div class="pb-qty">
										<button type="button" class="pb-qty__btn"
												disabled="@(_isProcessing || item.Quantity <= 0)"
												@onclick="@(() => UpdateQuantity(item, item.Quantity - 1))"
												aria-label="Decrease">
											<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /></svg>
										</button>
										<input type="tel" inputmode="numeric" pattern="[0-9]*" class="pb-qty__input"
											   value="@((int)item.Quantity)"
											   disabled="@_isProcessing"
											   @onchange="@(e => OnQuantityInput(item, e.Value?.ToString()))" />
										<button type="button" class="pb-qty__btn"
												disabled="@_isProcessing"
												@onclick="@(() => UpdateQuantity(item, item.Quantity + 1))"
												aria-label="Increase">
											<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14" /></svg>
										</button>
									</div>
									<button type="button" class="pb-row-remove"
											disabled="@_isProcessing"
											@onclick="@(() => UpdateQuantity(item, 0))" aria-label="Remove">
										<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
											<path d="M4 7h16M9 7V5a2 2 0 012-2h2a2 2 0 012 2v2M6 7l1 13a2 2 0 002 2h6a2 2 0 002-2l1-13" />
										</svg>
									</button>
								</div>
							</div>
						}
					}

					<div class="pb-grid__pager">
						<div class="pb-grid__pager-nav">
							<button type="button" class="pb-pgbtn" disabled="@(safePage == 0)" @onclick="() => _page = Math.Max(0, _page - 1)" aria-label="Previous">
								<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
							</button>
							<span class="pb-grid__pager-count">
								@(safePage + 1) <span class="pb-grid__pager-of">of @pageCount</span>
							</span>
							<button type="button" class="pb-pgbtn" disabled="@(safePage >= pageCount - 1)" @onclick="() => _page++" aria-label="Next">
								<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
							</button>
						</div>
						<div class="pb-grid__pager-total">@allItems.Count @(allItems.Count == 1 ? "item" : "items")</div>
					</div>
				</div>

				<div class="pb-section">
					<div class="pb-section__head">
						<p class="pb-section__title">Remarks</p>
						<span class="pb-section__count">Optional</span>
					</div>
					<div class="pb-section__body">
						<textarea class="pb-remarks" placeholder="Add any special instructions for this order…"
								  value="@_orderRemarks" disabled="@_isProcessing"
								  @onchange="@(e => _orderRemarks = e.Value?.ToString() ?? string.Empty)"></textarea>
					</div>
				</div>

				<div class="pb-scroll__bottom-pad"></div>
			}
		</div>

		@if (_cart.Count > 0)
		{
			<div class="pb-cta-bar">
				<button type="button" class="pb-cta" @onclick="OnPlaceOrderClick" disabled="@(_isProcessing || _cart.Sum(c => c.Quantity) <= 0)">
					<span class="pb-cta__side">
						@(_isProcessing ? "Placing order…" : "Place order")
					</span>
					<span class="pb-cta__side">
						<span class="pb-cta__meta">@totalQty.ToString("N0") units</span>
						<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
							<path d="M5 12h14" />
							<path d="M13 5l7 7-7 7" />
						</svg>
					</span>
				</button>
			</div>
		}
	</div>
}

<MobileValidationErrorDialog @bind-Visible="_showValidationDialog" Errors="_validationErrors" ContextLabel="order" />

<style>
	.pb-screen {
		--bg-app: #f7f2ea;
		--surface: #ffffff;
		--surface-2: #faf5ec;
		--surface-3: #f1ebdf;
		--ink-1: #1d1813;
		--ink-2: #5a5147;
		--ink-3: #9a8f7f;
		--line-1: #ece4d3;
		--line-2: #ddd2bd;
		--rouge: #b13a5e;
		--rouge-dark: #8a2748;
		--rouge-soft: #f7e4ec;
		--rouge-tint: #fdf6f8;
		--moss: #4f7a5a;
		--moss-soft: #e3ecdd;
		--r-sm: 12px;
		--r-md: 16px;
		--r-lg: 22px;
		--r-pill: 999px;
		--ff-sans: "Plus Jakarta Sans", -apple-system, system-ui, sans-serif;
		--ff-mono: "JetBrains Mono", ui-monospace, monospace;
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: var(--bg-app);
		color: var(--ink-1);
		font-family: var(--ff-sans);
		font-size: 15px;
		line-height: 1.4;
		letter-spacing: -0.005em;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		z-index: 1;
	}

		.pb-screen *,
		.pb-screen *::before,
		.pb-screen *::after {
			box-sizing: border-box;
		}

	/* Header */
	.pb-header {
		padding: 14px 22px 14px;
		padding-top: max(14px, env(safe-area-inset-top));
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 12px;
		flex-shrink: 0;
	}

	.pb-header__main {
		min-width: 0;
	}

	.pb-header__sub {
		font-size: 12.5px;
		color: var(--ink-3);
		margin-bottom: 6px;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		font-weight: 500;
		font-variant-numeric: tabular-nums;
	}

	.pb-header__title {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 26px;
		letter-spacing: -0.025em;
		line-height: 1.15;
		margin: 0;
		color: var(--ink-1);
	}

	.pb-header__actions {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.pb-icon-btn {
		width: 38px;
		height: 38px;
		border-radius: var(--r-pill);
		background: var(--surface);
		border: 1px solid var(--line-1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-2);
		cursor: pointer;
		flex-shrink: 0;
		padding: 0;
	}

		.pb-icon-btn:active {
			transform: scale(0.96);
		}

	/* Scroll */
	.pb-scroll {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}

		.pb-scroll::-webkit-scrollbar {
			display: none;
		}

	.pb-scroll__bottom-pad {
		height: 16px;
	}

	/* Empty state */
	.pb-empty {
		margin: 18px;
		padding: 48px 24px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 8px;
	}

	.pb-empty__icon {
		width: 64px;
		height: 64px;
		border-radius: 999px;
		background: var(--surface-3);
		color: var(--ink-3);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 8px;
	}

	.pb-empty__title {
		margin: 0;
		font-size: 20px;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: var(--ink-1);
	}

	.pb-empty__sub {
		margin: 0 0 12px;
		color: var(--ink-3);
		font-size: 14px;
	}

	.pb-empty__cta {
		padding: 0 22px;
	}

	/* Grid card */
	.pb-grid {
		margin: 0 18px 16px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		overflow: hidden;
	}

	.pb-grid__toolbar {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 10px 14px;
		background: var(--surface);
		border-bottom: 1px solid var(--line-1);
	}

	.pb-grid__search {
		flex: 1;
		display: flex;
		align-items: center;
		gap: 8px;
		background: var(--surface-2);
		border: 1px solid var(--line-1);
		border-radius: 10px;
		padding: 9px 12px;
		color: var(--ink-3);
	}

		.pb-grid__search input {
			flex: 1;
			border: 0;
			background: transparent;
			outline: none;
			font: 500 14px var(--ff-sans);
			color: var(--ink-1);
			padding: 0;
			min-width: 0;
		}

			.pb-grid__search input::placeholder {
				color: var(--ink-3);
				font-weight: 400;
			}

	.pb-grid__search-clear {
		background: transparent;
		border: 0;
		color: var(--ink-3);
		cursor: pointer;
		padding: 2px;
		display: inline-flex;
	}

	.pb-grid__head {
		display: flex;
		align-items: center;
		padding: 8px 18px;
		background: var(--surface-3);
		border-bottom: 1px solid var(--line-1);
		font-size: 10.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.09em;
		color: var(--ink-3);
	}

	.pb-grid__head--product {
		flex: 1;
	}

	.pb-grid__head--qty {
		width: 168px;
		text-align: right;
	}

	.pb-grid__row {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 12px 18px;
		border-bottom: 1px solid var(--line-1);
		min-height: 56px;
	}

	.pb-grid__row-info {
		align-self: center;
	}

	.pb-grid__row:last-of-type {
		border-bottom: 0;
	}

	.pb-grid__row-info {
		flex: 1;
		min-width: 0;
	}

	.pb-product__name {
		font-size: 14.5px;
		font-weight: 500;
		letter-spacing: -0.01em;
		margin: 0;
		color: var(--ink-1);
		white-space: normal;
		word-break: break-word;
		overflow-wrap: anywhere;
		line-height: 1.35;
	}

	.pb-grid__row-actions {
		width: 130px;
		display: flex;
		justify-content: flex-end;
		align-items: center;
	}

	.pb-grid__row-actions--wide {
		width: 168px;
		gap: 6px;
	}

	.pb-grid__empty {
		padding: 36px 18px;
		text-align: center;
		color: var(--ink-3);
		font-size: 13.5px;
	}

	.pb-row-remove {
		background: transparent;
		border: 0;
		color: var(--ink-3);
		cursor: pointer;
		padding: 6px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

		.pb-row-remove:active {
			transform: scale(0.95);
		}

		.pb-row-remove:disabled {
			opacity: 0.4;
			cursor: not-allowed;
		}

	/* Qty */
	.pb-qty {
		display: inline-flex;
		align-items: stretch;
		background: var(--surface);
		border: 1px solid var(--line-2);
		border-radius: 12px;
		overflow: hidden;
		height: 36px;
	}

	.pb-qty__btn {
		width: 34px;
		background: var(--surface-2);
		border: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-1);
		cursor: pointer;
		padding: 0;
		font-size: 16px;
	}

		.pb-qty__btn:active {
			background: var(--surface-3);
		}

		.pb-qty__btn:disabled {
			color: var(--ink-3);
			cursor: not-allowed;
			opacity: 0.5;
		}

	.pb-qty__input {
		width: 52px;
		border: 0;
		border-left: 1px solid var(--line-1);
		border-right: 1px solid var(--line-1);
		background: var(--surface);
		font-family: var(--ff-sans);
		font-size: 14.5px;
		font-weight: 700;
		color: var(--ink-1);
		text-align: center;
		font-variant-numeric: tabular-nums;
		padding: 0 4px;
		outline: none;
		-moz-appearance: textfield;
		appearance: textfield;
	}

		.pb-qty__input::-webkit-outer-spin-button,
		.pb-qty__input::-webkit-inner-spin-button {
			-webkit-appearance: none;
			margin: 0;
		}

		.pb-qty__input:focus {
			background: var(--rouge-tint);
			color: var(--rouge-dark);
		}

	.pb-add-btn {
		background: var(--ink-1);
		color: #fff;
		border: 0;
		border-radius: 12px;
		padding: 0 18px;
		height: 36px;
		font-family: var(--ff-sans);
		font-size: 13.5px;
		font-weight: 600;
		letter-spacing: -0.005em;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
	}

		.pb-add-btn:disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}

	/* Pager */
	.pb-grid__pager {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 10px 14px;
		background: var(--surface-2);
		border-top: 1px solid var(--line-1);
		font-size: 12.5px;
		color: var(--ink-3);
	}

	.pb-grid__pager-nav {
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.pb-grid__pager-count {
		padding: 0 8px;
		color: var(--ink-2);
		font-weight: 600;
		font-variant-numeric: tabular-nums;
	}

	.pb-grid__pager-of {
		color: var(--ink-3);
		font-weight: 400;
	}

	.pb-grid__pager-total {
		font-variant-numeric: tabular-nums;
	}

	.pb-pgbtn {
		width: 32px;
		height: 32px;
		border-radius: 10px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-1);
		cursor: pointer;
		padding: 0;
	}

		.pb-pgbtn:disabled {
			color: var(--ink-3);
			opacity: 0.4;
			cursor: not-allowed;
		}

	/* Section card */
	.pb-section {
		margin: 0 18px 18px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		overflow: hidden;
	}

	.pb-section__head {
		padding: 14px 18px 8px;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
	}

	.pb-section__title {
		font-size: 11.5px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin: 0;
	}

	.pb-section__count {
		font-size: 11.5px;
		color: var(--ink-3);
		letter-spacing: 0.04em;
	}

	.pb-section__body {
		padding: 0 18px 16px;
	}

	.pb-remarks {
		width: 100%;
		min-height: 80px;
		background: var(--surface-2);
		border: 1px solid var(--line-1);
		border-radius: 12px;
		padding: 12px 14px;
		color: var(--ink-1);
		font-size: 14px;
		font-family: var(--ff-sans);
		line-height: 1.5;
		resize: vertical;
		outline: none;
	}

		.pb-remarks::placeholder {
			color: var(--ink-3);
		}

		.pb-remarks:focus {
			border-color: var(--rouge);
			background: var(--rouge-tint);
		}

	/* CTA */
	.pb-cta-bar {
		flex-shrink: 0;
		padding: 12px 18px 14px;
		padding-bottom: max(14px, env(safe-area-inset-bottom));
		background: linear-gradient(to top, var(--bg-app) 60%, rgba(247, 242, 234, 0));
		position: relative;
	}

	.pb-cta {
		width: 100%;
		background: var(--ink-1);
		color: #fff;
		border: 0;
		border-radius: 18px;
		padding: 16px 20px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		font-size: 15px;
