@attribute [Route(PageRouteNames.OrderMobile)]

<PageTitle>Order - Prime Bakes</PageTitle>

<HeadContent>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@@400;500;600;700;800&family=JetBrains+Mono:wght@@400;500&display=swap" rel="stylesheet" />
</HeadContent>

@if (_isLoading || _user is null)
{
	<LoadingScreen Visible="true" />
}
else
{
	var pageSize = 10;
	var visibleProducts = GetFilteredProducts();
	var pageCount = Math.Max(1, (int)Math.Ceiling(visibleProducts.Count / (double)pageSize));
	var safePage = Math.Max(0, Math.Min(_page, pageCount - 1));
	var paged = visibleProducts.Skip(safePage * pageSize).Take(pageSize).ToList();
	var totalQty = (int)_cart.Sum(c => c.Quantity);

	<div class="pb-screen">
		<div class="pb-header">
			<div class="pb-header__main">
				<div class="pb-header__sub">New order@(string.IsNullOrWhiteSpace(_location?.Name) ? "" : " · " + _location.Name)</div>
				<h1 class="pb-header__title">Catalog</h1>
			</div>
			<div class="pb-header__actions">
				<button type="button" class="pb-icon-btn" @onclick="@(() => NavigationManager.NavigateTo(PageRouteNames.Dashboard))" aria-label="Home">
					<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
						<path d="M3 11l9-8 9 8" />
						<path d="M5 10v10h5v-6h4v6h5V10" />
					</svg>
				</button>
			</div>
		</div>

		<div class="pb-chips">
			@foreach (var c in _productCategories)
			{
				<button type="button" class="pb-chip @(c.Id == _selectedCategory?.Id ? "is-active" : "")"
						@onclick="@(() => SelectCategory(c))">
					@c.Name
				</button>
			}
		</div>

		<div class="pb-scroll">
			<div class="pb-grid">
				<div class="pb-grid__toolbar">
					<div class="pb-grid__search">
						<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="7" />
							<path d="M20 20l-3.5-3.5" />
						</svg>
						<input placeholder="Search products…" value="@_query"
							   @oninput="@(e => OnQueryChange(e.Value?.ToString()))" />
						@if (!string.IsNullOrWhiteSpace(_query))
						{
							<button type="button" class="pb-grid__search-clear" @onclick="() => OnQueryChange(null)" aria-label="Clear search">
								<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
							</button>
						}
					</div>
				</div>

				<div class="pb-grid__head">
					<span class="pb-grid__head--product">Product</span>
					<span class="pb-grid__head--qty">Quantity</span>
				</div>

				@if (paged.Count == 0)
				{
					<div class="pb-grid__empty">
						@if (!string.IsNullOrWhiteSpace(_query))
						{
							<text>No products match &ldquo;@_query&rdquo;.</text>
						}
						else
						{
							<text>No products available.</text>
						}
					</div>
				}
				else
				{
					@foreach (var item in paged)
					{
						<div class="pb-grid__row" @key="item.ItemId">
							<div class="pb-grid__row-info">
								<p class="pb-product__name">@item.ItemName</p>
								@{
									var catName = _productCategories.FirstOrDefault(c => c.Id == item.ItemCategoryId)?.Name;
								}
								@if (!string.IsNullOrWhiteSpace(catName))
								{
									<div class="pb-product__meta">@catName</div>
								}
							</div>
							<div class="pb-grid__row-actions">
								@if (item.Quantity == 0)
								{
									<button type="button" class="pb-add-btn" @onclick="@(() => AddToCart(item))">
										<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14" /></svg>
										Add
									</button>
								}
								else
								{
									<div class="pb-qty">
										<button type="button" class="pb-qty__btn" disabled="@(item.Quantity <= 0)"
												@onclick="@(() => UpdateQuantity(item, item.Quantity - 1))" aria-label="Decrease">
											<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /></svg>
										</button>
										<input type="tel" inputmode="numeric" pattern="[0-9]*" class="pb-qty__input"
											   value="@((int)item.Quantity)"
											   @onchange="@(e => OnQuantityInput(item, e.Value?.ToString()))" />
										<button type="button" class="pb-qty__btn"
												@onclick="@(() => UpdateQuantity(item, item.Quantity + 1))" aria-label="Increase">
											<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14" /></svg>
										</button>
									</div>
								}
							</div>
						</div>
					}
				}

				<div class="pb-grid__pager">
					<div class="pb-grid__pager-nav">
						<button type="button" class="pb-pgbtn" disabled="@(safePage == 0)"
								@onclick="() => _page = Math.Max(0, _page - 1)" aria-label="Previous">
							<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
						</button>
						<span class="pb-grid__pager-count">
							@(safePage + 1) <span class="pb-grid__pager-of">of @pageCount</span>
						</span>
						<button type="button" class="pb-pgbtn" disabled="@(safePage >= pageCount - 1)"
								@onclick="() => _page++" aria-label="Next">
							<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
						</button>
					</div>
					<div class="pb-grid__pager-total">@visibleProducts.Count @(visibleProducts.Count == 1 ? "item" : "items")</div>
				</div>
			</div>
			<div class="pb-scroll__bottom-pad"></div>
		</div>

		@if (totalQty > 0)
		{
			<div class="pb-cta-bar">
				<button type="button" class="pb-cta" @onclick="GoToCart">
					<span class="pb-cta__side">
						View cart
					</span>
					<span class="pb-cta__side">
						<span class="pb-cta__meta">@totalQty.ToString("N0") units</span>
						<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
							<path d="M5 12h14" />
							<path d="M13 5l7 7-7 7" />
						</svg>
					</span>
				</button>
			</div>
		}
	</div>
}

<style>
	/* ─── Prime Bakes editorial bakery POS — design tokens ─── */
	.pb-screen {
		--bg-app: #f7f2ea;
		--surface: #ffffff;
		--surface-2: #faf5ec;
		--surface-3: #f1ebdf;
		--ink-1: #1d1813;
		--ink-2: #5a5147;
		--ink-3: #9a8f7f;
		--line-1: #ece4d3;
		--line-2: #ddd2bd;
		--rouge: #b13a5e;
		--rouge-dark: #8a2748;
		--rouge-soft: #f7e4ec;
		--rouge-tint: #fdf6f8;
		--moss: #4f7a5a;
		--moss-soft: #e3ecdd;
		--r-sm: 12px;
		--r-md: 16px;
		--r-lg: 22px;
		--r-pill: 999px;
		--ff-sans: "Plus Jakarta Sans", -apple-system, system-ui, sans-serif;
		--ff-mono: "JetBrains Mono", ui-monospace, monospace;
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		background: var(--bg-app);
		color: var(--ink-1);
		font-family: var(--ff-sans);
		font-size: 15px;
		line-height: 1.4;
		letter-spacing: -0.005em;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
		z-index: 1;
	}

		.pb-screen *,
		.pb-screen *::before,
		.pb-screen *::after {
			box-sizing: border-box;
		}

	/* Header */
	.pb-header {
		padding: 14px 22px 14px;
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 12px;
		flex-shrink: 0;
		padding-top: max(14px, env(safe-area-inset-top));
	}

	.pb-header__main {
		min-width: 0;
	}

	.pb-header__sub {
		font-size: 12.5px;
		color: var(--ink-3);
		margin-bottom: 6px;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		font-weight: 500;
	}

	.pb-header__title {
		font-family: var(--ff-sans);
		font-weight: 700;
		font-size: 26px;
		letter-spacing: -0.025em;
		line-height: 1.15;
		margin: 0;
		color: var(--ink-1);
	}

	.pb-header__actions {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.pb-icon-btn {
		width: 38px;
		height: 38px;
		border-radius: var(--r-pill);
		background: var(--surface);
		border: 1px solid var(--line-1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-2);
		cursor: pointer;
		flex-shrink: 0;
		padding: 0;
	}

		.pb-icon-btn:active {
			transform: scale(0.96);
		}

	/* Chips */
	.pb-chips {
		display: flex;
		gap: 8px;
		overflow-x: auto;
		overflow-y: hidden;
		padding: 4px 18px 14px;
		scrollbar-width: none;
		flex-shrink: 0;
	}

		.pb-chips::-webkit-scrollbar {
			display: none;
		}

	.pb-chip {
		flex-shrink: 0;
		padding: 8px 14px;
		border-radius: var(--r-pill);
		font-size: 13.5px;
		font-weight: 500;
		letter-spacing: -0.005em;
		background: var(--surface);
		color: var(--ink-2);
		border: 1px solid var(--line-1);
		white-space: nowrap;
		cursor: pointer;
		font-family: var(--ff-sans);
		line-height: 1.2;
	}

		.pb-chip.is-active {
			background: var(--ink-1);
			color: #fff;
			border-color: var(--ink-1);
		}

	/* Scroll */
	.pb-scroll {
		flex: 1;
		overflow-y: auto;
		overflow-x: hidden;
		scrollbar-width: none;
		-webkit-overflow-scrolling: touch;
	}

		.pb-scroll::-webkit-scrollbar {
			display: none;
		}

	.pb-scroll__bottom-pad {
		height: 8px;
	}

	/* Grid card */
	.pb-grid {
		margin: 0 18px 14px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		border-radius: var(--r-lg);
		overflow: hidden;
	}

	.pb-grid__toolbar {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 10px 14px;
		background: var(--surface);
		border-bottom: 1px solid var(--line-1);
	}

	.pb-grid__search {
		flex: 1;
		display: flex;
		align-items: center;
		gap: 8px;
		background: var(--surface-2);
		border: 1px solid var(--line-1);
		border-radius: 10px;
		padding: 9px 12px;
		color: var(--ink-3);
	}

		.pb-grid__search input {
			flex: 1;
			border: 0;
			background: transparent;
			outline: none;
			font: 500 14px var(--ff-sans);
			color: var(--ink-1);
			padding: 0;
			min-width: 0;
		}

			.pb-grid__search input::placeholder {
				color: var(--ink-3);
				font-weight: 400;
			}

	.pb-grid__search-clear {
		background: transparent;
		border: 0;
		color: var(--ink-3);
		cursor: pointer;
		padding: 2px;
		display: inline-flex;
	}

	.pb-grid__head {
		display: flex;
		align-items: center;
		padding: 8px 18px;
		background: var(--surface-3);
		border-bottom: 1px solid var(--line-1);
		font-size: 10.5px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.09em;
		color: var(--ink-3);
	}

	.pb-grid__head--product {
		flex: 1;
	}

	.pb-grid__head--qty {
		width: 130px;
		text-align: right;
	}

	.pb-grid__row {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 12px 18px;
		border-bottom: 1px solid var(--line-1);
		min-height: 56px;
	}

		.pb-grid__row:last-of-type {
			border-bottom: 0;
		}

	.pb-grid__row-info {
		flex: 1;
		min-width: 0;
		align-self: center;
	}

	.pb-product__name {
		font-size: 14.5px;
		font-weight: 500;
		letter-spacing: -0.01em;
		margin: 0;
		color: var(--ink-1);
		white-space: normal;
		word-break: break-word;
		overflow-wrap: anywhere;
		line-height: 1.35;
	}

	.pb-product__meta {
		font-size: 12px;
		color: var(--ink-3);
		margin-top: 1px;
		letter-spacing: 0.01em;
	}

	.pb-grid__row-actions {
		width: 130px;
		display: flex;
		justify-content: flex-end;
		align-items: center;
	}

	.pb-grid__empty {
		padding: 36px 18px;
		text-align: center;
		color: var(--ink-3);
		font-size: 13.5px;
	}

	/* Qty control */
	.pb-qty {
		display: inline-flex;
		align-items: stretch;
		background: var(--surface);
		border: 1px solid var(--line-2);
		border-radius: 12px;
		overflow: hidden;
		height: 36px;
	}

	.pb-qty__btn {
		width: 34px;
		background: var(--surface-2);
		border: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-1);
		cursor: pointer;
		font-size: 16px;
		transition: background 0.12s ease;
		padding: 0;
	}

		.pb-qty__btn:active {
			background: var(--surface-3);
		}

		.pb-qty__btn:disabled {
			color: var(--ink-3);
			cursor: not-allowed;
			opacity: 0.5;
		}

	.pb-qty__input {
		width: 52px;
		border: 0;
		border-left: 1px solid var(--line-1);
		border-right: 1px solid var(--line-1);
		background: var(--surface);
		font-family: var(--ff-sans);
		font-size: 14.5px;
		font-weight: 700;
		color: var(--ink-1);
		text-align: center;
		font-variant-numeric: tabular-nums;
		padding: 0 4px;
		outline: none;
		-moz-appearance: textfield;
		appearance: textfield;
	}

		.pb-qty__input::-webkit-outer-spin-button,
		.pb-qty__input::-webkit-inner-spin-button {
			-webkit-appearance: none;
			margin: 0;
		}

		.pb-qty__input:focus {
			background: var(--rouge-tint);
			color: var(--rouge-dark);
		}

	/* Add button */
	.pb-add-btn {
		background: var(--ink-1);
		color: #fff;
		border: 0;
		border-radius: 12px;
		padding: 0 18px;
		height: 36px;
		font-family: var(--ff-sans);
		font-size: 13.5px;
		font-weight: 600;
		letter-spacing: -0.005em;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

		.pb-add-btn:active {
			transform: scale(0.97);
		}

	/* Pager */
	.pb-grid__pager {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 10px 14px;
		background: var(--surface-2);
		border-top: 1px solid var(--line-1);
		font-size: 12.5px;
		color: var(--ink-3);
	}

	.pb-grid__pager-nav {
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.pb-grid__pager-count {
		padding: 0 8px;
		color: var(--ink-2);
		font-weight: 600;
		font-variant-numeric: tabular-nums;
	}

	.pb-grid__pager-of {
		color: var(--ink-3);
		font-weight: 400;
	}

	.pb-grid__pager-total {
		font-variant-numeric: tabular-nums;
	}

	.pb-pgbtn {
		width: 32px;
		height: 32px;
		border-radius: 10px;
		background: var(--surface);
		border: 1px solid var(--line-1);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--ink-1);
		cursor: pointer;
		padding: 0;
	}

		.pb-pgbtn:disabled {
			color: var(--ink-3);
			opacity: 0.4;
			cursor: not-allowed;
		}

	/* CTA */
	.pb-cta-bar {
		flex-shrink: 0;
		padding: 12px 18px 14px;
		padding-bottom: max(14px, env(safe-area-inset-bottom));
		background: linear-gradient(to top, var(--bg-app) 60%, rgba(247, 242, 234, 0));
		position: relative;
	}

	.pb-cta {
		width: 100%;
		background: var(--ink-1);
		color: #fff;
		border: 0;
		border-radius: 18px;
		padding: 16px 20px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		font-size: 15px;
		font-weight: 500;
		cursor: pointer;
		letter-spacing: -0.005em;
		font-family: var(--ff-sans);
	}

		.pb-cta:active {
			transform: scale(0.99);
		}

	.pb-cta__side {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.pb-cta__badge {
		width: 28px;
		height: 28px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.15);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 13px;
		font-weight: 700;
		font-variant-numeric: tabular-nums;
	}

	.pb-cta__meta {
		font-size: 13px;
		opacity: 0.85;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		font-weight: 600;
	}
</style>
