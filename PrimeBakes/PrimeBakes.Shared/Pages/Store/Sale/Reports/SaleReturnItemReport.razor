@using PrimeBakes.Library.Accounts.Masters.Models
@using PrimeBakes.Library.Operations.Location
@using PrimeBakes.Library.Store.Product.Models
@using PrimeBakes.Library.Store.Sale.Models

@attribute [Route(StoreRouteNames.SaleReturnItemReport)]

<PageTitle>Sale Return Item Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturn, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyW KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleSummary" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyO KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="ViewSelectedTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedTransaction" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Sale Return Item Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturn, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadTransactionOverviews" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudMenuItem Label="@(_showSummary ? "Hide Summary (Ctrl + W)" : "Show Summary (Ctrl + W)")" OnClick="ToggleSummary" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="ToggleDetailsView" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Sale Return (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturn, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Return Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Return Item Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.Sale, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Item Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransfer, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransferReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer Item Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransferItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing || _showSummary">
					<MudBlazor.MudMenuItem Label="View (Alt + O)" OnClick="ViewSelectedTransaction" />
					<MudBlazor.MudMenuItem Label="View Accounting Posting" OnClick="ViewFinancialAccountingPosting" />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedTransaction" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<!-- Date Range -->
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<!-- Item -->
						<div class="form-field">
							<CustomAutoComplete T="ProductModel"
												Value="_selectedProduct"
												DataSource="@_products"
												Placeholder="All Items"
												Label="Item" Required="false"
												ValueChanged="OnProductChanged"
												FieldValue="@nameof(ProductModel.Name)"
												AddNewRoute="@StoreRouteNames.Product" />
						</div>

						<!-- Item Category -->
						<div class="form-field">
							<CustomAutoComplete T="ProductCategoryModel"
												Value="_selectedProductCategory"
												DataSource="@_productCategories"
												Placeholder="All Categories"
												Label="Category" Required="false"
												ValueChanged="OnProductCategoryChanged"
												FieldValue="@nameof(ProductCategoryModel.Name)"
												AddNewRoute="@StoreRouteNames.ProductCategory" />
						</div>

						@if (_user.LocationId == 1)
						{
							<!-- Company -->
							<div class="form-field">
								<CustomAutoComplete T="CompanyModel"
													Value="_selectedCompany"
													DataSource="@_companies"
													Placeholder="All Companies"
													Label="Company" Required="false"
													ValueChanged="OnCompanyChanged"
													FieldValue="@nameof(CompanyModel.Name)"
													AddNewRoute="@AccountsRouteNames.CompanyMaster" />
							</div>

							<!-- Location -->
							<div class="form-field">
								<CustomAutoComplete T="LocationModel"
													Value="_selectedLocation"
													DataSource="@_locations"
													Placeholder="All Locations"
													Label="Location" Required="false"
													ValueChanged="OnLocationChanged"
													FieldValue="@nameof(LocationModel.Name)"
													AddNewRoute="@OperationRouteNames.Location" />
							</div>

							<!-- Party -->
							<div class="form-field">
								<CustomAutoComplete T="LedgerModel"
													Value="_selectedParty"
													DataSource="@_parties"
													Placeholder="All Parties"
													Label="Party" Required="false"
													ValueChanged="OnPartyChanged"
													FieldValue="@nameof(LedgerModel.Name)"
													AddNewRoute="@AccountsRouteNames.LedgerMaster" />
							</div>
						}
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<SfGrid @ref="_sfGrid" TValue="SaleReturnItemOverviewModel" DataSource="_transactionOverviews"
						AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="SaleReturnItemOverviewModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.ItemName)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.Quantity)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.ItemBaseTotal)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.DiscountAmount)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.AfterDiscount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.SGSTAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.CGSTAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.IGSTAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.TotalTaxAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.Total)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemOverviewModel.NetTotal)" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.ItemName)" HeaderText="Item" Visible="@(_showAllColumns || _selectedProduct is null || _selectedProduct.Id <= 0)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.ItemCode)" HeaderText="Code" Visible="@_showAllColumns" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.ItemCategoryName)" HeaderText="Category" Visible="@(_selectedProductCategory is null || _selectedProductCategory.Id <= 0)" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.Quantity)" HeaderText="Qty" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.Rate)" HeaderText="Rate" Visible="@(!_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.ItemBaseTotal)" HeaderText="Base Total" Visible="@_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.DiscountPercent)" HeaderText="Disc %" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.DiscountAmount)" HeaderText="Disc" Visible="@_showAllColumns" CustomColor="grid-debit" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.AfterDiscount)" HeaderText="After Disc" Visible="@_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.SGSTPercent)" HeaderText="SGST %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.SGSTAmount)" HeaderText="SGST" Visible="@_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.CGSTPercent)" HeaderText="CGST %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.CGSTAmount)" HeaderText="CGST" Visible="@_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.IGSTPercent)" HeaderText="IGST %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.IGSTAmount)" HeaderText="IGST" Visible="@_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalTaxAmount)" HeaderText="Tax Amt" Visible="@_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.InclusiveTax)" HeaderText="Tax Incl." TextAlign="TextAlign.Center" Visible="@(_showAllColumns && !_showSummary)" DisplayAsCheckBox="true" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.Total)" HeaderText="Total" Visible="@_showAllColumns" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.NetRate)" HeaderText="Net Rate" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.NetTotal)" HeaderText="Net Total" TotalColumn="true" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.ItemRemarks)" HeaderText="Item Remarks" Visible="@(_showAllColumns && !_showSummary)" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TransactionNo)" HeaderText="Transaction No" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TransactionDateTime)" HeaderText="Date" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.LocationName)" HeaderText="Location" Visible="@(_selectedLocation is null || _selectedLocation.Id <= 0)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.CompanyName)" HeaderText="Company" Visible="@(_showAllColumns && !_showSummary && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.PartyName)" HeaderText="Party" Visible="@(_user.LocationId == 1 && !_showSummary && (_selectedParty is null || _selectedParty.Id <= 0))" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.CustomerName)" HeaderText="Customer" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.FinancialYear)" HeaderText="Financial Year" Visible="@(_showAllColumns && !_showSummary)" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalItems)" HeaderText="Items" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalQuantity)" HeaderText="Qty" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.BaseTotal)" HeaderText="Base Total" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.ItemDiscountAmount)" HeaderText="Item Disc" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalAfterItemDiscount)" HeaderText="After Disc" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalInclusiveTaxAmount)" HeaderText="Incl Tax" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalExtraTaxAmount)" HeaderText="Extra Tax" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalAfterTax)" HeaderText="Sub Total" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.OtherChargesPercent)" HeaderText="Other Charge %" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.OtherChargesAmount)" HeaderText="Other Charge" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.SaleReturnDiscountPercent)" HeaderText="Sale Return Disc %" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.SaleReturnDiscountAmount)" HeaderText="Sale Return Disc" Visible="@(_showAllColumns && !_showSummary)" CustomColor="grid-debit" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.RoundOffAmount)" HeaderText="Round Off" Visible="@(_showAllColumns && !_showSummary)" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.TotalAmount)" HeaderText="Total" Visible="@(!_showSummary)" TotalColumn="true" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.PaymentModes)" HeaderText="Payment Modes" Visible="@(!_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.Cash)" HeaderText="Cash" Visible="@(_showAllColumns && !_showSummary)" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.UPI)" HeaderText="UPI" Visible="@(_showAllColumns && !_showSummary)" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.Card)" HeaderText="Card" Visible="@(_showAllColumns && !_showSummary)" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.Credit)" HeaderText="Credit" Visible="@(_showAllColumns && !_showSummary)" TotalColumn="true" />

						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.Remarks)" HeaderText="Remarks" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.FinancialAccountingTransactionNo)" HeaderText="Accounting Transaction No" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.CreatedByName)" HeaderText="Created By" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.CreatedAt)" HeaderText="Created At" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.CreatedFromPlatform)" HeaderText="Created Platform" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.LastModifiedByUserName)" HeaderText="Modified By" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.LastModifiedAt)" HeaderText="Modified At" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.LastModifiedFromPlatform)" HeaderText="Modified Platform" Visible="@(_showAllColumns && !_showSummary)" />
						<CustomGridColumn Field="@nameof(SaleReturnItemOverviewModel.MasterStatus)" Visible="@(_showDeleted && !_showSummary)" StatusColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
