                        </GridAggregates>

                        <GridColumns>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TransactionNo)" HeaderText="Trans No"
                                        Width="170" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TransactionDateTime)" HeaderText="Date"
                                        Width="150" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.CompanyName)" HeaderText="Company"
                                        Width="180"
                                        Visible="@(_showAllColumns && !_showSummary && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.LocationName)" HeaderText="Location"
                                        Width="180"
                                        Visible="@(_showAllColumns && !_showSummary && (_selectedLocation is null || _selectedLocation.Id <= 0))" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.PartyName)" HeaderText="Party" Width="200"
                                        Visible="@(_user.LocationId == 1 && (_selectedParty is null || _selectedParty.Id <= 0))" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.CustomerName)" HeaderText="Customer"
                                        Width="200" Visible="@(_user.LocationId == 1 && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.FinancialYear)" HeaderText="Financial Year"
                                        Width="150" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TotalItems)" HeaderText="Items" Width="100"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TotalQuantity)" HeaderText="Qty" Width="120"
                                        Format="N2" TextAlign="TextAlign.Right" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.BaseTotal)" HeaderText="Base Total"
                                        Width="130" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.ItemDiscountAmount)" HeaderText="Item Disc"
                                        Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="grid-discount">@item.DiscountAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TotalAfterItemDiscount)"
                                        HeaderText="After Disc" Width="140" Format="N2" TextAlign="TextAlign.Right"
                                        Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TotalInclusiveTaxAmount)"
                                        HeaderText="Incl Tax" Width="120" Format="N2" TextAlign="TextAlign.Right"
                                        Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TotalExtraTaxAmount)" HeaderText="Extra Tax"
                                        Width="120" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TotalAfterTax)" HeaderText="Sub Total"
                                        Width="130" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.OtherChargesPercent)"
                                        HeaderText="Other Charges %" Width="150" Format="N2" TextAlign="TextAlign.Center"
                                        Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.OtherChargesAmount)"
                                        HeaderText="Other Charges" Width="140" Format="N2" TextAlign="TextAlign.Right"
                                        Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.DiscountPercent)" HeaderText="Disc %"
                                        Width="130" Format="N2" TextAlign="TextAlign.Center" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.DiscountAmount)" HeaderText="Disc"
                                        Width="130" TextAlign="TextAlign.Right">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="grid-discount">@item.DiscountAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.RoundOffAmount)" HeaderText="Round Off"
                                        Width="120" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.TotalAmount)" HeaderText="Total" Width="150"
                                        TextAlign="TextAlign.Right">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="grid-total">@item.TotalAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.Cash)" HeaderText="Cash" Width="150"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="grid-total">@item.Cash.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.UPI)" HeaderText="UPI" Width="150"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="grid-total">@item.UPI.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.Card)" HeaderText="Card" Width="150"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="grid-total">@item.Card.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.Credit)" HeaderText="Credit" Width="150"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="grid-total">@item.Credit.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.Status)" HeaderText="Status" Width="110"
                                        Visible="@(_showDeleted && !_showSummary)" TextAlign="TextAlign.Center">
                                <Template>
                                    @{
                                        var item = (context as SaleReturnOverviewModel);
                                        <span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.PaymentModes)" HeaderText="Payment Modes"
                                        Width="180" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.Remarks)" HeaderText="Remarks" Width="200"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.CreatedByName)" HeaderText="Created By"
                                        Width="150" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.CreatedAt)" HeaderText="Created At"
                                        Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.CreatedFromPlatform)"
                                        HeaderText="Created Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.LastModifiedByUserName)"
                                        HeaderText="Modified By" Width="150" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.LastModifiedAt)" HeaderText="Modified At"
                                        Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(SaleReturnOverviewModel.LastModifiedFromPlatform)"
                                        HeaderText="Modified Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>

        <Footer />
    </div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Sale Return Transaction"
                          IdentifierLabel="Transaction No" IdentifierValue="@_deleteTransactionNo" 
                          Disabled="@_isProcessing" OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Sale Return Transaction"
                           IdentifierLabel="Transaction No" IdentifierValue="@_recoverTransactionNo" Disabled="@_isProcessing"
                           OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
