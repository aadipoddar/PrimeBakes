                                            }
                                        </GroupCaptionTemplate>
                                    </GridAggregateColumn>
                                    <GridAggregateColumn Field="@nameof(SaleReturnOverviewModel.BaseTotal)"
                                                         Type="AggregateType.Sum" Format="N2">
