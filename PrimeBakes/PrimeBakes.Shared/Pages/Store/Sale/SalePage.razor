@using PrimeBakesLibrary.Accounts.Masters.Models
@using PrimeBakesLibrary.Operations.Location
@using PrimeBakesLibrary.Store.Order.Models
@using PrimeBakesLibrary.Store.PaymentMode
@using PrimeBakesLibrary.Store.Product.Models
@using PrimeBakesLibrary.Store.Sale.Models

@attribute [Route(StoreRouteNames.Sale)]
@attribute [Route(StoreRouteNames.Sale + "/{Id:int}")]

<PageTitle>Sale - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _itemAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _otherChargesPercent.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _paymentModeAutoComplete.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyT KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveThermal: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyT KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => PrintThermalInvoice()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyI KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleItemReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_sale.Id > 0 ? $"Edit Sale {_sale.TransactionNo}" : "Create Sale")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & Thermal (Ctrl + T)" OnClick="() => SaveTransaction(saveThermal: true)" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Thermal (Alt + T)" OnClick="() => PrintThermalInvoice()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Sale (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.Sale, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Item Report (Ctrl + I)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Return" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturn, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Return Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Return Item Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransfer, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransferReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer Item Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransferItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Top Section: Transaction Summary, Financial Summary and Payments Side by Side -->
			<div class="three-column-layout">
				<!-- Transaction Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="16" y1="13" x2="8" y2="13" />
								<line x1="16" y1="17" x2="8" y2="17" />
								<polyline points="10 9 9 9 8 9" />
							</svg>
							<h2 class="section-title">Transaction Summary</h2>
						</div>
					</div>
					<div class="section-body">
						<div class="form-grid">

							@if (_user.LocationId == 1)
							{
								<!-- Company -->
								<div class="form-field">
									<CustomAutoComplete @ref="_firstFocus" T="CompanyModel"
														Value="_selectedCompany"
														DataSource="@_companies"
														Placeholder="Select a Company"
														Label="Company (Ctrl + F)"
														ValueChanged="OnCompanyChanged"
														FieldValue="@nameof(CompanyModel.Name)"
														AddNewRoute="@AccountsRouteNames.CompanyMaster" />
								</div>

								<!-- Location -->
								<div class="form-field">
									<CustomAutoComplete T="LocationModel"
														Value="_selectedLocation"
														DataSource="@_locations"
														Placeholder="Select a Location"
														Label="Location"
														ValueChanged="OnLocationChanged"
														FieldValue="@nameof(LocationModel.Name)"
														AddNewRoute="@OperationRouteNames.Location" />
								</div>

								<!-- Transaction Date -->
								<div class="form-field">
									<CustomDatePicker Value="_sale.TransactionDateTime"
													  FinancialYear="@_selectedFinancialYear"
													  ValueChanged="OnTransactionDateChanged" />
								</div>
							}

							@if (_selectedLocation.Id == 1)
							{
								<!-- Party -->
								<div class="form-field">
									<CustomAutoComplete T="LedgerModel"
														Value="_selectedParty"
														DataSource="@_parties"
														Placeholder="Select a Party"
														Label="Party"
														Required="false"
														ValueChanged="OnPartyChanged"
														FieldValue="@nameof(LedgerModel.Name)"
														AddNewRoute="@AccountsRouteNames.LedgerMaster" />
								</div>

								<!-- Order -->
								<div class="form-field">
									<div class="reference-wrapper">
										<CustomAutoComplete T="OrderModel"
															Value="_selectedOrder"
															DataSource="@_orders"
															Label="Order"
															Placeholder="Select an Order"
															Required="false"
															ValueChanged="OnOrderChanged"
															FieldValue="@nameof(OrderModel.TransactionNo)"
															AddNewRoute="@StoreRouteNames.Order" />
										@if (_sale.OrderId is not null && _sale.OrderId > 0 && _selectedOrder is not null && _selectedOrder.Id > 0)
										{
											<div class="reference-actions">
												<IconButton Icon="IconType.View" Variant="ButtonVariant.View" Size="ButtonSize.Small"
															Title="View Order" OnClick="ViewSelectedOrder" />
											</div>
										}
									</div>
								</div>
							}

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_sale.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							<!-- Customer Number -->
							<div class="form-field">
								<CustomTextField Value="@_selectedCustomer.Number"
												 ValueChanged="OnCustomerNumberChanged"
												 Label="Customer Number"
												 Placeholder="Customer Mobile No"
												 Required="false"
												 InputType="MudBlazor.InputType.Telephone" />
							</div>

							<!-- Customer Name -->
							<div class="form-field">
								<CustomTextField @bind-Value="_selectedCustomer.Name"
												 Label="Customer Name"
												 Placeholder="Customer Name"
												 Required="false" />
							</div>

							<!-- Remarks -->
							<div class="form-field form-field-full">
								<CustomTextField @bind-Value="_sale.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>
						</div>
					</div>
				</div>

				<!-- Financial Summary Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23" />
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
							</svg>
							<h2 class="section-title">Financial Summary</h2>
						</div>
					</div>
					<div class="section-body">
						<div class="form-grid">

							<!-- Sub Total -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_sale.TotalAfterTax"
													Label="Sub Total"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							@if (_user.ChangeProductFinancial)
							{
								<!-- Other Charges -->
								<div class="form-field">
									<div class="date-year-wrapper">
										<CustomNumericField @ref="_otherChargesPercent" T="decimal"
															Value="_sale.OtherChargesPercent"
															ValueChanged="OnOtherChargesPercentChanged"
															Label="Other Charges % (Ctrl + Shift + F)"
															Placeholder="0.00"
															Required="false"
															ReadOnly="@(!_user.ChangeProductFinancial)"
															Min="0"
															Max="100" />

										<CustomNumericField T="decimal"
															Value="_sale.OtherChargesAmount"
															Label="Other Charges Amt"
															Placeholder="0.00"
															ReadOnly="true"
															Required="false"
															TabIndex="-1" />
									</div>
								</div>

								<!-- Discount -->
								<div class="form-field">
									<div class="date-year-wrapper">
										<CustomNumericField T="decimal"
															Value="_sale.DiscountPercent"
															ValueChanged="OnDiscountPercentChanged"
															Label="Discount %"
															Placeholder="0.00"
															Required="false"
															ReadOnly="@(!_user.ChangeProductFinancial)"
															Min="0"
															Max="100" />

										<CustomNumericField T="decimal"
															Value="_sale.DiscountAmount"
															Label="Discount Amt"
															Placeholder="0.00"
															ReadOnly="true"
															Required="false"
															TabIndex="-1" />
									</div>
								</div>
							}

							<!-- Round Off -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_sale.RoundOffAmount"
													ValueChanged="OnRoundOffAmountChanged"
													Label="Round Off"
													Placeholder="0.00"
													ReadOnly="@(!_user.ChangeProductFinancial)"
													Required="false" />
							</div>

							<hr class="form-divider" />

							<!-- Total Amount -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_sale.TotalAmount"
													Label="Total Amount"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>
						</div>
					</div>
				</div>

				<!-- Payments Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
								 stroke-linecap="round" stroke-linejoin="round">
								<rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
								<line x1="1" y1="10" x2="23" y2="10" />
							</svg>
							<h2 class="section-title">Payments</h2>
						</div>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<!-- Payment Mode -->
							<div class="cart-field cart-field-wide">
								<CustomAutoComplete T="PaymentModeModel"
													@ref="_paymentModeAutoComplete"
													FieldValue="@nameof(PaymentModeModel.Name)" Value="_selectedPaymentMethod"
													DataSource="@_paymentMethods" Placeholder="Select Payment Mode"
													ValueChanged="OnPaymentMethodChanged" OpenOnFocus="false"
													Label="Payment Mode (Ctrl + Shift + G)" />
							</div>

							<!-- Amount -->
							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal"
													@bind-Value="_selectedPaymentCart.Amount"
													Min="0"
													Label="Amount"
													Placeholder="0.00" />
							</div>

							<!-- Add Button -->
							<div class="cart-field cart-field-wide">
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add Payment" OnClick="AddPaymentToCart" />
							</div>
						</div>

						<SfGrid @ref="_sfPaymentsCartGrid" DataSource="_paymentsCart"
								AllowTextWrap="true" AllowPaging="false" AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" GridLines="GridLine.Horizontal" CssClass="professional-grid"
								ContextMenuItems="@_paymentsCartGridContextMenuItems">

							<GridEvents TValue="PaymentItem" ContextMenuItemClicked="OnPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridAggregateColumn Field="@nameof(PaymentItem.Method)" Type="AggregateType.Count">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
												}
												<div class="aggregate-label">
													<strong>Total Payment Modes: @aggregate.Count</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
										<GridAggregateColumn Field="@nameof(PaymentItem.Amount)" Type="AggregateType.Sum">
											<FooterTemplate>
												@{
													var aggregate = (context as AggregateTemplateContext);
													var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
												}
												<div class="aggregate-value aggregate-total">
													<strong>@sum.ToString("N2")</strong>
												</div>
											</FooterTemplate>
										</GridAggregateColumn>
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<GridColumn Field="@nameof(PaymentItem.Method)" HeaderText="Payment Mode" Width="200" />
								<GridColumn Field="@nameof(PaymentItem.Amount)" HeaderText="Amount" Width="130" TextAlign="TextAlign.Right" Format="N2">
									<Template>
										@{
											var item = (context as dynamic);
											<span class="grid-total">@item.Amount.ToString("N2")</span>
										}
									</Template>
								</GridColumn>
							</GridColumns>

						</SfGrid>
					</div>
				</div>
			</div>

			<!-- Add to Cart Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Add Item to Cart</h2>
					</div>
				</div>
				<div class="section-body">
					<!-- First Row: Item Selection and Tax Info -->
					<div class="cart-input-row">

						<!-- Item -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="ProductLocationOverviewModel"
												@ref="_itemAutoComplete"
												Value="_selectedProduct"
												DataSource="@_products"
												Placeholder="Select a Product"
												Label="Product (Ctrl + G)"
												ValueChanged="OnItemChanged"
												FieldValue="@nameof(ProductLocationOverviewModel.Name)"
												AddNewRoute="@StoreRouteNames.Product"
												OpenOnFocus="false" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Quantity"
												ValueChanged="OnItemQuantityChanged"
												Label="Qty"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Rate"
												ValueChanged="OnItemRateChanged"
												Label="Rate"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountPercent"
												ValueChanged="OnItemDiscountPercentChanged"
												Label="Disc %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTPercent"
												ValueChanged="OnItemCGSTPercentChanged"
												Label="CGST %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTPercent"
												ValueChanged="OnItemSGSTPercentChanged"
												Label="SGST %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTPercent"
												ValueChanged="OnItemIGSTPercentChanged"
												Label="IGST %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox Value="_selectedCart.InclusiveTax"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												ValueChanged="OnItemInclusiveTaxChanged"
												Label="Tax Incl." />
							</div>
						</div>

						<div class="cart-field" />
					</div>

					<!-- Second Row: Readonly Amounts -->
					<div class="cart-input-row">
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<div class="cart-field" />

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.BaseTotal"
												Label="Base"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountAmount"
												Label="Disc Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTAmount"
												Label="CGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTAmount"
												Label="SGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTAmount"
												Label="IGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Total"
												Label="Total"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field cart-field-action">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Cart Items Grid Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 3h7a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3H3V3z" />
							<path d="M14 3h7v17h-7V3z" />
						</svg>
						<h2 class="section-title">Sale Items</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfCartGrid" DataSource="_cart" AllowTextWrap="true" AllowPaging="false"
							AllowSorting="true" AllowResizing="true" AllowFiltering="true" GridLines="GridLine.Horizontal"
							CssClass="professional-grid" ContextMenuItems="@_cartGridContextMenuItems"
							Toolbar="@(new List<string>() { "Search" })">

						<GridEvents TValue="SaleItemCartModel" ContextMenuItemClicked="OnCartGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridAggregates>
							<GridAggregate>
								<GridAggregateColumns>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.ItemName)" Type="AggregateType.Count">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
											}
											<div class="aggregate-label">
												<strong>Total Items: @aggregate.Count</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.Quantity)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.BaseTotal)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.DiscountAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-debit">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.AfterDiscount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.CGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.SGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.IGSTAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.TotalTaxAmount)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
									<GridAggregateColumn Field="@nameof(SaleItemCartModel.Total)" Type="AggregateType.Sum">
										<FooterTemplate>
											@{
												var aggregate = (context as AggregateTemplateContext);
												var sum = aggregate.Sum != null ? Convert.ToDecimal(aggregate.Sum) : 0m;
											}
											<div class="aggregate-value aggregate-total">
												<strong>@sum.ToString("N2")</strong>
											</div>
										</FooterTemplate>
									</GridAggregateColumn>
								</GridAggregateColumns>
							</GridAggregate>
						</GridAggregates>

						<GridColumns>
							<GridColumn Field="@nameof(SaleItemCartModel.ItemName)" HeaderText="Item Name" Width="200" />
							<GridColumn Field="@nameof(SaleItemCartModel.Quantity)" HeaderText="Qty" Width="100" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.Rate)" HeaderText="Rate" Width="110" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.BaseTotal)" HeaderText="Base Total" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.DiscountPercent)" HeaderText="Disc %" Width="120" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.DiscountAmount)" HeaderText="Disc Amt" Width="140" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-discount">@item.DiscountAmount.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(SaleItemCartModel.AfterDiscount)" HeaderText="After Disc" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.CGSTPercent)" HeaderText="CGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.CGSTAmount)" HeaderText="CGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.SGSTPercent)" HeaderText="SGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.SGSTAmount)" HeaderText="SGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.IGSTPercent)" HeaderText="IGST %" Width="140" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.IGSTAmount)" HeaderText="IGST Amt" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.TotalTaxAmount)" HeaderText="Tax Total" Width="150" TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn Field="@nameof(SaleItemCartModel.InclusiveTax)" HeaderText="Tax Incl." Width="100" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(SaleItemCartModel.Total)" HeaderText="Total" Width="130" TextAlign="TextAlign.Right" Format="N2">
								<Template>
									@{
										var item = (context as dynamic);
										<span class="grid-total">@item.Total.ToString("N2")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(SaleItemCartModel.Remarks)" HeaderText="Remarks" Width="150" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
