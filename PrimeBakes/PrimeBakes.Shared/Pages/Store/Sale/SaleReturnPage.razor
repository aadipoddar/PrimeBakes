@using PrimeBakes.Library.Accounts.Masters.Models
@using PrimeBakes.Library.Operations.Location
@using PrimeBakes.Library.Store.PaymentMode
@using PrimeBakes.Library.Store.Product.Models
@using PrimeBakes.Library.Store.Sale.Models

@attribute [Route(StoreRouteNames.SaleReturn)]
@attribute [Route(StoreRouteNames.SaleReturn + "/{Id:int}")]

<PageTitle>Sale Return - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _itemAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _otherChargesPercentField?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyG KeyModifiers="[JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft]" OnHotkeyPressed="() => _paymentModeAutoComplete?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Enter KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="AddItemToCart" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(savePDF: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => SaveTransaction(saveExcel: true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.AltLeft] OnHotkeyPressed="() => ExportSelectedTransaction(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyH KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyI KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnItemReport, FormFactor, JSRuntime, NavigationManager)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="RemoveSelectedCartItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedCartItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="@(_saleReturn.Id > 0 ? $"Edit Sale Return {_saleReturn.TransactionNo}" : "Create Sale Return")">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New Transaction (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="() => SaveTransaction()" />
					<MudBlazor.MudMenuItem Label="Save & PDF (Ctrl + P)" OnClick="() => SaveTransaction(savePDF: true)" />
					<MudBlazor.MudMenuItem Label="Save & Excel (Ctrl + E)" OnClick="() => SaveTransaction(saveExcel: true)" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Alt + P)" OnClick="() => ExportSelectedTransaction()" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
					<MudBlazor.MudMenuItem Label="Export Excel (Alt + E)" OnClick="() => ExportSelectedTransaction(true)" Disabled="@(_isProcessing || !Id.HasValue || Id.Value <= 0)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Open" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Sale Return (Ctrl + N)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturn, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Return Report (Ctrl + H)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Return Item Report (Ctrl + I)" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReturnItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.Sale, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Sale Item Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.SaleItemReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransfer, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransferReport, FormFactor, JSRuntime, NavigationManager)" />
					<MudBlazor.MudMenuItem Label="Stock Transfer Item Report" OnClick="() => AuthenticationService.NavigateToRoute(StoreRouteNames.StockTransferItemReport, FormFactor, JSRuntime, NavigationManager)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="three-column-layout">

				<!-- Transaction -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Transaction</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							@if (_user.LocationId == 1)
							{
								<!-- Company -->
								<div class="form-field">
									<CustomAutoComplete @ref="_firstFocus" T="CompanyModel"
														Value="_selectedCompany"
														DataSource="@_companies"
														Placeholder="Select a Company"
														Label="Company (Ctrl + F)"
														ValueChanged="OnCompanyChanged"
														FieldValue="@nameof(CompanyModel.Name)"
														AddNewRoute="@AccountsRouteNames.CompanyMaster" />
								</div>

								<!-- Location -->
								<div class="form-field">
									<CustomAutoComplete T="LocationModel"
														Value="_selectedLocation"
														DataSource="@_locations"
														Placeholder="Select a Location"
														Label="Location"
														ValueChanged="OnLocationChanged"
														FieldValue="@nameof(LocationModel.Name)"
														AddNewRoute="@OperationRouteNames.Location" />
								</div>

								<!-- Transaction Date -->
								<div class="form-field">
									<CustomDatePicker Value="_saleReturn.TransactionDateTime"
													  ValueChanged="OnTransactionDateChanged"
													  FinancialYear="@_selectedFinancialYear" />
								</div>
							}

							<!-- Transaction No -->
							<div class="form-field">
								<CustomTextField @bind-Value="_saleReturn.TransactionNo"
												 Label="Transaction No"
												 Placeholder="Transaction No"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							@if (_selectedLocation.Id == 1)
							{
								<!-- Party -->
								<div class="form-field">
									<CustomAutoComplete T="LedgerModel"
														Value="_selectedParty"
														DataSource="@_parties"
														Placeholder="Select a Party"
														Label="Party"
														Required="false"
														ValueChanged="OnPartyChanged"
														FieldValue="@nameof(LedgerModel.Name)"
														AddNewRoute="@AccountsRouteNames.LedgerMaster" />
								</div>
							}

							<!-- Customer Number -->
							<div class="form-field">
								<CustomTextField Value="@_selectedCustomer.Number"
												 ValueChanged="OnCustomerNumberChanged"
												 Label="Customer Number"
												 Placeholder="Customer Mobile No"
												 Required="false"
												 AddNewRoute="@StoreRouteNames.Customer"
												 InputType="MudBlazor.InputType.Telephone" />
							</div>

							<!-- Customer Name -->
							<div class="form-field">
								<CustomTextField @bind-Value="_selectedCustomer.Name"
												 Label="Customer Name"
												 Placeholder="Customer Name"
												 AddNewRoute="@StoreRouteNames.Customer"
												 Required="false" />
							</div>

							<!-- Remarks -->
							<div class="form-field form-field-full">
								<CustomTextField @bind-Value="_saleReturn.Remarks"
												 Label="Remarks / Narration"
												 Placeholder="Enter remarks..."
												 Required="false"
												 Lines="2" />
							</div>
						</div>
					</div>
				</div>

				<!-- Financial -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Financial</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">

							<!-- Sub Total -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_saleReturn.TotalAfterTax"
													Label="Sub Total"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>

							@if (_user.ChangeProductFinancial)
							{
								<!-- Other Charges -->
								<div class="form-field">
									<div class="date-year-wrapper">
										<CustomNumericField @ref="_otherChargesPercentField" T="decimal"
															Value="_saleReturn.OtherChargesPercent"
															ValueChanged="OnOtherChargesPercentChanged"
															Label="Other Charges % (Ctrl + Shift + F)"
															Placeholder="0.00"
															Required="false"
															ReadOnly="@(!_user.ChangeProductFinancial)"
															Min="0"
															Max="100" />

										<CustomNumericField T="decimal"
															Value="_saleReturn.OtherChargesAmount"
															Label="Other Charges Amt"
															Placeholder="0.00"
															ReadOnly="true"
															Required="false"
															TabIndex="-1" />
									</div>
								</div>

								<!-- Discount -->
								<div class="form-field">
									<div class="date-year-wrapper">
										<CustomNumericField T="decimal"
															Value="_saleReturn.DiscountPercent"
															ValueChanged="OnDiscountPercentChanged"
															Label="Discount %"
															Placeholder="0.00"
															Required="false"
															ReadOnly="@(!_user.ChangeProductFinancial)"
															Min="0"
															Max="100" />

										<CustomNumericField T="decimal"
															Value="_saleReturn.DiscountAmount"
															Label="Discount Amt"
															Placeholder="0.00"
															ReadOnly="true"
															Required="false"
															TabIndex="-1" />
									</div>
								</div>
							}

							<!-- Round Off -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_saleReturn.RoundOffAmount"
													ValueChanged="OnRoundOffAmountChanged"
													Label="Round Off"
													Placeholder="0.00"
													ReadOnly="@(!_user.ChangeProductFinancial)"
													Required="false" />
							</div>

							<hr class="form-divider" />

							<!-- Total Amount -->
							<div class="form-field">
								<CustomNumericField T="decimal"
													Value="_saleReturn.TotalAmount"
													Label="Total Amount"
													Placeholder="0.00"
													ReadOnly="true"
													Required="false"
													TabIndex="-1" />
							</div>
						</div>
					</div>
				</div>

				<!-- Payment -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Payment</h2>
					</div>

					<div class="section-body">
						<div class="cart-input-row">
							<!-- Payment Mode -->
							<div class="cart-field cart-field-wide">
								<CustomAutoComplete T="PaymentModeModel"
													@ref="_paymentModeAutoComplete"
													FieldValue="@nameof(PaymentModeModel.Name)" Value="_selectedPaymentMethod"
													DataSource="@_paymentMethods" Placeholder="Select Payment Mode"
													ValueChanged="OnPaymentMethodChanged" OpenOnFocus="false"
													Label="Payment Mode (Ctrl + Shift + G)" />
							</div>

							<!-- Amount -->
							<div class="cart-field cart-field-wide">
								<CustomNumericField T="decimal"
													@bind-Value="_selectedPaymentCart.Amount"
													Min="0"
													Label="Amount"
													Placeholder="0.00" />
							</div>

							<!-- Add Button -->
							<div class="cart-field cart-field-wide">
								<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add"
											Title="Add Payment" OnClick="AddPaymentToCart" />
							</div>
						</div>

						<SfGrid @ref="_sfPaymentsCartGrid" DataSource="_paymentsCart"
								AllowSorting="true" AllowResizing="true"
								AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
								GridLines="GridLine.Horizontal" ContextMenuItems="@_paymentsCartGridContextMenuItems">

							<GridEvents TValue="PaymentItem" ContextMenuItemClicked="OnPaymentsCartGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

							<GridAggregates>
								<GridAggregate>
									<GridAggregateColumns>
										<GridColumnAggregate Field="@nameof(PaymentItem.Method)" Type="AggregateType.Count" Format="N0" />
										<GridColumnAggregate Field="@nameof(PaymentItem.Amount)" CustomColor="grid-total" />
									</GridAggregateColumns>
								</GridAggregate>
							</GridAggregates>

							<GridColumns>
								<CustomGridColumn Field="@nameof(PaymentItem.Method)" HeaderText="Payment Mode" />
								<CustomGridColumn Field="@nameof(PaymentItem.Amount)" HeaderText="Amount" TotalColumn="true" />
							</GridColumns>
						</SfGrid>
					</div>
				</div>
			</div>

			<!-- Add to Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Add Items to Cart</h2>
				</div>

				<div class="section-body">
					<!-- First Row: Item Selection and Tax Info -->
					<div class="cart-input-row">

						<!-- Item -->
						<div class="cart-field cart-field-wide">
							<CustomAutoComplete T="ProductLocationOverviewModel"
												@ref="_itemAutoComplete"
												Value="_selectedProduct"
												DataSource="@_products"
												Placeholder="Select a Product"
												Label="Product (Ctrl + G)"
												ValueChanged="OnItemChanged"
												FieldValue="@nameof(ProductLocationOverviewModel.Name)"
												AddNewRoute="@StoreRouteNames.Product"
												OpenOnFocus="false" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Quantity"
												ValueChanged="OnItemQuantityChanged"
												Label="Qty"
												Placeholder="0.00"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Rate"
												ValueChanged="OnItemRateChanged"
												Label="Rate"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Min="0" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountPercent"
												ValueChanged="OnItemDiscountPercentChanged"
												Label="Disc %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTPercent"
												ValueChanged="OnItemCGSTPercentChanged"
												Label="CGST %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTPercent"
												ValueChanged="OnItemSGSTPercentChanged"
												Label="SGST %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTPercent"
												ValueChanged="OnItemIGSTPercentChanged"
												Label="IGST %"
												Placeholder="0.00"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												Required="false"
												Min="0"
												Max="100" />
						</div>

						<div class="cart-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox Value="_selectedCart.InclusiveTax"
												ReadOnly="@(!_user.ChangeProductFinancial)"
												ValueChanged="OnItemInclusiveTaxChanged"
												Label="Tax Incl." />
							</div>
						</div>

						<div class="cart-field" />
					</div>

					<!-- Second Row: Readonly Amounts -->
					<div class="cart-input-row">
						<div class="cart-field cart-field-wide">
							<CustomTextField @bind-Value="_selectedCart.Remarks"
											 Label="Remarks"
											 Placeholder="Item Narration..."
											 Required="false" />
						</div>

						<div class="cart-field" />

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.BaseTotal"
												Label="Base"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.DiscountAmount"
												Label="Disc Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.CGSTAmount"
												Label="CGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.SGSTAmount"
												Label="SGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.IGSTAmount"
												Label="IGST Amt"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field">
							<CustomNumericField T="decimal"
												Value="_selectedCart.Total"
												Label="Total"
												ReadOnly="true"
												Required="false"
												TabIndex="-1" />
						</div>

						<div class="cart-field cart-field-action">
							<IconButton Icon="IconType.Add" Variant="ButtonVariant.Add" Text="Add" Title="Add to Cart" OnClick="AddItemToCart" />
						</div>
					</div>
				</div>
			</div>

			<!-- Cart -->
			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Cart</h2>
				</div>

				<SfGrid @ref="_sfCartGrid" DataSource="_cart"
						AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_cartGridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="SaleReturnItemCartModel" ContextMenuItemClicked="OnCartGridContextMenuItemClicked" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.ItemName)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.Quantity)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.BaseTotal)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.DiscountAmount)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.AfterDiscount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.CGSTAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.SGSTAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.IGSTAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.TotalTaxAmount)" />
								<GridColumnAggregate Field="@nameof(SaleReturnItemCartModel.Total)" CustomColor="grid-total" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.ItemName)" HeaderText="Item Name" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.Quantity)" HeaderText="Qty" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.Rate)" HeaderText="Rate" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.BaseTotal)" HeaderText="Base Total" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.DiscountPercent)" HeaderText="Disc %" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.DiscountAmount)" HeaderText="Disc Amt" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.AfterDiscount)" HeaderText="After Disc" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.CGSTPercent)" HeaderText="CGST %" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.CGSTAmount)" HeaderText="CGST Amt" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.SGSTPercent)" HeaderText="SGST %" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.SGSTAmount)" HeaderText="SGST Amt" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.IGSTPercent)" HeaderText="IGST %" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.IGSTAmount)" HeaderText="IGST Amt" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.TotalTaxAmount)" HeaderText="Tax Total" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.InclusiveTax)" HeaderText="Tax Incl." TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.Total)" HeaderText="Total" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(SaleReturnItemCartModel.Remarks)" HeaderText="Remarks" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
