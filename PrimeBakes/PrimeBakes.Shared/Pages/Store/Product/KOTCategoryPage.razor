@attribute [Route(PageRouteNames.KOTCategory)]

@using PrimeBakesLibrary.Models.Store.Product

<PageTitle>KOT Category Management - Prime Bakes</PageTitle>

@if (_isLoading)
{
	<AnimatedLoader Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="KOT Category Management">
			<LeftContent>
				<IconButton Icon="IconType.Excel" Variant="ButtonVariant.Excel" Title="Export to Excel (Ctrl + E)" Disabled="_isProcessing" OnClick="ExportExcel" />
				<IconButton Icon="IconType.Pdf" Variant="ButtonVariant.Pdf" Title="Export to PDF (Ctrl + P)" Disabled="_isProcessing" OnClick="ExportPdf" />
				<IconButton Icon="IconType.Save" Variant="ButtonVariant.Save" Title="Save KOT Category (Ctrl + S)" Disabled="_isProcessing" OnClick="SaveKOTCategory" />
				<IconButton Icon="IconType.New" Title="New KOT Category (Ctrl + N)" Disabled="_isProcessing" OnClick="ResetPage" />
			</LeftContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- KOT Category Entry Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
							 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">KOT Category Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- KOT Category Name -->
						<div class="form-field">
							<label class="field-label">
								KOT Category Name <span class="required">*</span>
							</label>
							<SfTextBox @bind-Value="_kotCategory.Name" Placeholder="Enter KOT category name"
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>

						<!-- Remarks -->
						<div class="form-field">
							<label class="field-label">Remarks</label>
							<SfTextBox @bind-Value="_kotCategory.Remarks" Placeholder="Enter remarks (optional)" Multiline="true"
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>
					</div>
				</div>
			</div>

			<!-- KOT Categories List Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
							 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">KOT Categories List</h2>
					</div>
					<div class="header-actions">
						<ToggleButton Disabled="@_isProcessing" IsActive="@_showDeleted"
									  Variant="ToggleButton.ToggleVariant.Deleted" OnToggle="ToggleDeleted" />
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_kotCategories" AllowPaging="true" AllowSorting="true" AllowFiltering="true"
							AllowResizing="true" CssClass="professional-grid" Toolbar="@(new List<string>() { "Search" })">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn HeaderText="Actions" Width="120" TextAlign="TextAlign.Center" AllowFiltering="false">
								<Template>
									@{
										var kotCategory = (context as KOTCategoryModel);

										<div class="grid-actions">
											@if (kotCategory.Status)
											{
												<IconButton Icon="IconType.Edit" Variant="ButtonVariant.Edit" Size="ButtonSize.Grid" Title="Edit (Insert)" OnClick="@(() => OnEditKOTCategory(kotCategory))" />
												<IconButton Icon="IconType.Delete" Variant="ButtonVariant.Delete" Size="ButtonSize.Grid" Title="Delete (Delete)" OnClick="@(() => ShowDeleteConfirmation(kotCategory.Id, kotCategory.Name))" />
											}
											else
											{
												<IconButton Icon="IconType.Recover" Variant="ButtonVariant.Recover" Size="ButtonSize.Grid" Title="Recover (Delete)" OnClick="@(() => ShowRecoverConfirmation(kotCategory.Id, kotCategory.Name))" />
											}
										</div>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(KOTCategoryModel.Id)" HeaderText="ID" Width="80"
										TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(KOTCategoryModel.Name)" HeaderText="Category Name" Width="300" />
							<GridColumn Field="@nameof(KOTCategoryModel.Remarks)" HeaderText="Remarks" Width="400" />
							<GridColumn Field="@nameof(KOTCategoryModel.Status)" HeaderText="Status" Width="100"
										TextAlign="TextAlign.Center">
								<Template>
									@{
										var kotCategory = (context as KOTCategoryModel);
										<div class="grid-checkbox"
											 style="@(kotCategory.Status ? "color: #10b981; background: #d1fae5;" : "color: #dc2626; background: #fee2e2;")">
											@(kotCategory.Status ? "✓" : "✗")
										</div>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog"
						  EntityName="KOT Category"
						  IdentifierLabel="Name"
						  IdentifierValue="@_deleteKOTCategoryName"
						  
						  Disabled="@_isProcessing"
						  OnConfirm="ConfirmDelete"
						  OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog"
						   EntityName="KOT Category"
						   IdentifierLabel="Name"
						   IdentifierValue="@_recoverKOTCategoryName"
						   Disabled="@_isProcessing"
						   OnConfirm="ConfirmRecover"
						   OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
