@attribute [Route(PageRouteNames.ProductLocation)]

@using PrimeBakesLibrary.Models.Operations
@using PrimeBakesLibrary.Models.Store.Product


<PageTitle>Product Location Management - Prime Bakes</PageTitle>

@if (_isLoading)
{
	<AnimatedLoader Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="Product Location Management">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
										   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewProductLocation"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveProductLocation"
										  Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelected"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Delete (Del)" IconCss="e-icons e-trash" Id="DeleteSelected"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Product Location Entry Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">Product Location Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- Location -->
						<div class="form-field">
							<label class="field-label">Location <span class="required">*</span></label>
							<SfAutoComplete @bind-Value="_selectedLocationName" TValue="string" TItem="LocationModel"
											Placeholder="Select location" DataSource="@_locations" PopupHeight="300px"
											CssClass="custom-autocomplete" AllowFiltering="true"
											FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains">
								<AutoCompleteFieldSettings Value="Name"></AutoCompleteFieldSettings>
								<AutoCompleteEvents TValue="string" TItem="LocationModel" ValueChange="OnLocationChange">
								</AutoCompleteEvents>
							</SfAutoComplete>
						</div>

						<!-- Product -->
						<div class="form-field">
							<label class="field-label">Product <span class="required">*</span></label>
							<SfAutoComplete @bind-Value="_selectedProductName" TValue="string" TItem="ProductModel"
											Placeholder="Select product" DataSource="@_products" PopupHeight="300px"
											CssClass="custom-autocomplete" AllowFiltering="true"
											FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains">
								<AutoCompleteFieldSettings Value="Name"></AutoCompleteFieldSettings>
								<AutoCompleteEvents TValue="string" TItem="ProductModel" ValueChange="OnProductChange">
								</AutoCompleteEvents>
							</SfAutoComplete>
						</div>

						<!-- Rate -->
						<div class="form-field">
							<label class="field-label">Rate <span class="required">*</span></label>
							<SfNumericTextBox @bind-Value="_productLocation.Rate" TValue="decimal" Placeholder="0.00"
											  CssClass="custom-textbox" Format="N2" Decimals="2" Min="0" ShowSpinButton="false">
							</SfNumericTextBox>
						</div>
					</div>
				</div>
			</div>

			<!-- Product Location List Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Product Location List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_productLocationOverviews" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_productLocationGridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="ProductLocationOverviewModel" ContextMenuItemClicked="OnProductLocationGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(ProductLocationOverviewModel.Id)" HeaderText="ID" Width="80"
										TextAlign="TextAlign.Center" />
							<GridColumn HeaderText="Location" Width="150">
								<Template>
									@{
										var productLocation = (context as ProductLocationOverviewModel);
										var location = _locations.FirstOrDefault(l => l.Id == productLocation.LocationId);
										<span>@(location?.Name ?? "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(ProductLocationOverviewModel.Code)" HeaderText="Product Code"
										Width="150" />
							<GridColumn Field="@nameof(ProductLocationOverviewModel.Name)" HeaderText="Product Name"
										Width="200" />
							<GridColumn Field="@nameof(ProductLocationOverviewModel.Rate)" HeaderText="Rate" Width="120"
										TextAlign="TextAlign.Right" Format="N2" />
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Product Location" IdentifierLabel="Name"
						  IdentifierValue="@_deleteProductLocationName" IsPermanentDelete="true" Disabled="@_isProcessing"
						  OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<ToastNotification @ref="_toastNotification" />
