@using PrimeBakes.Library.Operations.Location
@using PrimeBakes.Library.Store.Product.Models

@attribute [Route(StoreRouteNames.Product)]

<PageTitle>Product Management - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Product Management">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedItem" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Location" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Show All Locations" OnClick="LoadLocations" />
					<MudBlazor.MudMenuItem Label="Clear All Locations" OnClick="ClearAllLocations" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="two-column-layout">

				<!-- Products -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Master Details</h2>
					</div>

					<div class="section-body">
						<div class="form-grid">
							<div class="form-field">
								<CustomTextField @ref="_firstFocus"
												 @bind-Value="_product.Name"
												 Label="Name (Ctrl + F)"
												 Placeholder="Enter product name" />
							</div>

							<div class="form-field">
								<CustomTextField @bind-Value="_product.Code"
												 Label="Code" Placeholder="Auto-generated"
												 Required="false"
												 ReadOnly="true"
												 TabIndex="-1" />
							</div>

							<div class="form-field">
								<CustomAutoComplete T="ProductCategoryModel"
													@bind-Value="_selectedCategory"
													DataSource="@_categories"
													Placeholder="Select category"
													Label="Category"
													FieldValue="@nameof(ProductCategoryModel.Name)"
													AddNewRoute="@StoreRouteNames.ProductCategory" />
							</div>

							<div class="form-field">
								<CustomAutoComplete T="KOTCategoryModel"
													@bind-Value="_selectedKOTCategory"
													DataSource="@_kotCategories"
													Placeholder="Select KOT category"
													Label="KOT Category"
													FieldValue="@nameof(KOTCategoryModel.Name)"
													AddNewRoute="@StoreRouteNames.KOTCategory" />
							</div>

							<div class="form-field">
								<CustomNumericField T="decimal"
													@bind-Value="_product.Rate"
													Label="Rate"
													Placeholder="Enter rate"
													Format="N2"
													Min="0" />
							</div>

							<div class="form-field">
								<CustomAutoComplete T="TaxModel"
													@bind-Value="_selectedTax"
													DataSource="@_taxes"
													Placeholder="Select tax"
													Label="Tax"
													FieldValue="@nameof(TaxModel.Code)"
													AddNewRoute="@StoreRouteNames.Tax" />
							</div>

							<div class="form-field">
								<CustomAutoComplete T="string"
													@bind-Value="_product.FoodType"
													DataSource="@FoodTypeOptions.FoodTypes"
													Placeholder="Select food type"
													Label="Food Type" />
							</div>

							<div class="form-field">
								<div class="checkbox-wrapper">
									<CustomCheckBox @bind-Value="_product.ShowInMenu"
													Label="Show in Customer Menu" />
								</div>
							</div>

							<div class="form-field">
								<CustomTextField @bind-Value="_product.Remarks"
												 Label="Remarks"
												 Placeholder="Enter remarks (optional)"
												 Required="false"
												 Lines="2" />
							</div>

							<div class="form-field">
								<CustomDatePicker @bind-Value="_effectiveDate"
												  Label="Effective Date"
												  ShowFinancialYear="false"
												  AddNewRoute="@null" />
							</div>
						</div>
					</div>
				</div>

				<!-- Locations -->
				<div class="section-card">
					<div class="section-header">
						<h2 class="section-title">Location List</h2>
					</div>

					<SfGrid @ref="_sfLocationGrid" DataSource="@_locations"
							AllowPaging="true" AllowSorting="true" AllowResizing="true"
							AllowFiltering="true" AllowReordering="true" ShowColumnChooser="true"
							GridLines="GridLine.Horizontal" ContextMenuItems="@_locationGridContextMenuItems"
							Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

						<GridPageSettings PageSize="10" PageSizes="@(new string[] { "10", "20", "50", "All" })" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

						<GridColumns>
							<CustomGridColumn>
								<CustomTemplate>
									<GridColumn HeaderText="Actions" TextAlign="TextAlign.Center" AllowFiltering="false" Width="50">
										<Template>
											@{
												var location = (context as dynamic);
												<IconButton Icon="IconType.Delete" Variant="ButtonVariant.Delete" Size="ButtonSize.Grid" Title="Remove Location" Disabled="_isProcessing" OnClick="@(() => RemoveLocation(location))" />
											}
										</Template>
									</GridColumn>
								</CustomTemplate>
							</CustomGridColumn>

							<CustomGridColumn Field="@nameof(LocationModel.Name)" HeaderText="Location Name" />
						</GridColumns>
					</SfGrid>
				</div>

			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Master List</h2>
				</div>

				<SfGrid @ref="_sfGrid" DataSource="@_products"
						AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="ProductModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridColumns>
						<CustomGridColumn Field="@nameof(ProductModel.Id)" HeaderText="ID" Width="100" TextAlign="TextAlign.Center" />
						<CustomGridColumn Field="@nameof(ProductModel.Name)" HeaderText="Name" />
						<CustomGridColumn Field="@nameof(ProductModel.Code)" HeaderText="Code" />

						<CustomGridColumn>
							<CustomTemplate>
								<GridColumn Field="@nameof(ProductModel.ProductCategoryId)" HeaderText="Category" Width="200">
									<Template>
										@{
											var product = (context as ProductModel);
											var category = _categories.FirstOrDefault(c => c.Id == product.ProductCategoryId);
											<span>@(category?.Name ?? "-")</span>
										}
									</Template>
								</GridColumn>
							</CustomTemplate>
						</CustomGridColumn>

						<CustomGridColumn>
							<CustomTemplate>
								<GridColumn Field="@nameof(ProductModel.KOTCategoryId)" HeaderText="KOT Category" Width="200">
									<Template>
										@{
											var product = (context as ProductModel);
											var kotCategory = _kotCategories.FirstOrDefault(c => c.Id == product.KOTCategoryId);
											<span>@(kotCategory?.Name ?? "-")</span>
										}
									</Template>
								</GridColumn>
							</CustomTemplate>
						</CustomGridColumn>

						<CustomGridColumn Field="@nameof(ProductModel.Rate)" HeaderText="Rate" NumericColumn="true" />

						<CustomGridColumn>
							<CustomTemplate>
								<GridColumn Field="@nameof(ProductModel.TaxId)" HeaderText="Tax" Width="200">
									<Template>
										@{
											var product = (context as ProductModel);
											var tax = _taxes.FirstOrDefault(t => t.Id == product.TaxId);
											<span>@(tax?.Code ?? "-")</span>
										}
									</Template>
								</GridColumn>
							</CustomTemplate>
						</CustomGridColumn>

						<CustomGridColumn Field="@nameof(ProductModel.FoodType)" HeaderText="Food Type" />
						<CustomGridColumn Field="@nameof(ProductModel.ShowInMenu)" HeaderText="Show in Menu" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
						<CustomGridColumn Field="@nameof(ProductModel.Remarks)" HeaderText="Remarks" />
						<CustomGridColumn Field="@nameof(ProductModel.Status)" Visible="_showDeleted" StatusColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage" OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
