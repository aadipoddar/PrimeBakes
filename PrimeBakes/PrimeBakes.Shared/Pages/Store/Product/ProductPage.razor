@attribute [Route(PageRouteNames.Product)]

@using PrimeBakesLibrary.Models.Operations
@using PrimeBakesLibrary.Models.Store.Product
@using PrimeBakes.Shared.Components.Button

<PageTitle>Product Management - Prime Bakes</PageTitle>

@if (_isLoading)
{
	<AnimatedLoader Visible="true" />
}
else
{
	<div class="page-shell">
		<Header Title="Product Management">
			<LeftContent>
				<SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
					<MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
										   Easing="ease" />
					<MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
					<MenuItems>
						<MenuItem Text="File" IconCss="e-icons e-folder">
							<MenuItems>
								<MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewProduct"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveProduct"
										  Disabled="@_isProcessing" />
								<MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash"
										  Id="ToggleDeleted" Disabled="@_isProcessing" />
								<MenuItem Separator="true" />
								<MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Transaction" IconCss="e-icons e-chart">
							<MenuItems>
								<MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelected"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelected"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
						<MenuItem Text="Location" IconCss="e-icons e-list-unordered">
							<MenuItems>
								<MenuItem Text="Show All Locations" IconCss="e-icons e-list-unordered" Id="ShowAllLocations"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Clear All Locations" IconCss="e-icons e-close" Id="ClearAllLocations"
										  Disabled="@_isProcessing" />
								<MenuItem Text="Remove Selected Location" IconCss="e-icons e-trash" Id="RemoveSelectedLocation"
										  Disabled="@_isProcessing" />
							</MenuItems>
						</MenuItem>
					</MenuItems>
				</SfMenu>
			</LeftContent>
			<RightContent>
				<IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container">

			<!-- Product Entry Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 15v4c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2v-4M17 9l-5 5-5-5M12 12.8V2.5" />
						</svg>
						<h2 class="section-title">Product Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<!-- Product Name -->
						<div class="form-field">
							<label class="field-label">Name <span class="required">*</span></label>
							<SfTextBox @bind-Value="_product.Name" Placeholder="Enter product name"
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>

						<!-- Product Code -->
						<div class="form-field">
							<label class="field-label">Code <span class="required">*</span></label>
							<SfTextBox @bind-Value="_product.Code" Placeholder="Auto-generated"
									   FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" Readonly="true" />
						</div>

						<!-- Category Autocomplete -->
						<div class="form-field">
							<label class="field-label">Category <span class="required">*</span></label>
							<SfAutoComplete TValue="string" TItem="ProductCategoryModel" @bind-Value="_selectedCategoryName"
											DataSource="@_categories" Placeholder="Select category"
											FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox">
								<AutoCompleteFieldSettings Value="Name" />
								<AutoCompleteEvents TValue="string" TItem="ProductCategoryModel"
													ValueChange="OnCategoryChange" />
							</SfAutoComplete>
						</div>

						<!-- KOT Category Autocomplete -->
						<div class="form-field">
							<label class="field-label">KOT Category <span class="required">*</span></label>
							<SfAutoComplete TValue="string" TItem="KOTCategoryModel" @bind-Value="_selectedKOTCategoryName"
											DataSource="@_kotCategories" Placeholder="Select KOT category"
											FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox">
								<AutoCompleteFieldSettings Value="Name" />
								<AutoCompleteEvents TValue="string" TItem="KOTCategoryModel"
													ValueChange="OnKOTCategoryChange" />
							</SfAutoComplete>
						</div>

						<!-- Rate -->
						<div class="form-field">
							<label class="field-label">Rate <span class="required">*</span></label>
							<SfNumericTextBox @bind-Value="_product.Rate" Placeholder="Enter rate"
											  FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" Format="N2" Decimals="2"
											  Min="0" />
						</div>

						<!-- Tax Autocomplete -->
						<div class="form-field">
							<label class="field-label">Tax <span class="required">*</span></label>
							<SfAutoComplete TValue="string" TItem="TaxModel" @bind-Value="_selectedTaxCode"
											DataSource="@_taxes" Placeholder="Select tax" FloatLabelType="FloatLabelType.Never"
											CssClass="custom-textbox">
								<AutoCompleteFieldSettings Value="Code" />
								<AutoCompleteEvents TValue="string" TItem="TaxModel" ValueChange="OnTaxChange" />
							</SfAutoComplete>
						</div>

						<div class="form-field">
							<label class="field-label">Remarks</label>
							<SfTextBox @bind-Value="_product.Remarks" Placeholder="Enter remarks (optional)"
									   Multiline="true" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
						</div>
					</div>
				</div>
			</div>

			@if (!string.IsNullOrWhiteSpace(_product.Name))
			{
				<!-- Location List Section -->
				<div class="section-card">
					<div class="section-header">
						<div class="section-title-wrapper">
							<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
								 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
								 stroke-linejoin="round">
								<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 1 1 16 0Z" />
								<circle cx="12" cy="10" r="3" />
							</svg>
							<h2 class="section-title">Location List</h2>
						</div>
					</div>
					<div class="section-body grid-body">
						<SfGrid @ref="_sfLocationGrid" DataSource="@_locations" AllowPaging="true" AllowSorting="true"
								AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
								Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_locationGridContextMenuItems">
							<GridPageSettings PageSize="10" PageSizes="@(new string[] { "10", "20", "50", "All" })" />
							<GridEvents TValue="LocationModel" ContextMenuItemClicked="OnLocationGridContextMenuItemClicked" />
							<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
							<GridColumns>
								<GridColumn Field="Id" HeaderText="ID" Width="90" TextAlign="TextAlign.Center" />
								<GridColumn Field="Name" HeaderText="Location Name" />
							</GridColumns>
						</SfGrid>
					</div>
				</div>
			}

			<!-- Product List Section -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M9 11l3 3L22 4" />
							<path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
						</svg>
						<h2 class="section-title">Product List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_products" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_productGridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="ProductModel" ContextMenuItemClicked="OnProductGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(ProductModel.Id)" HeaderText="ID" Width="80"
										TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(ProductModel.Name)" HeaderText="Name" Width="200" />
							<GridColumn Field="@nameof(ProductModel.Code)" HeaderText="Code" Width="120" />
							<GridColumn HeaderText="Category" Width="150">
								<Template>
									@{
										var product = (context as ProductModel);
										var category = _categories.FirstOrDefault(c => c.Id == product.ProductCategoryId);
										<span>@(category?.Name ?? "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn HeaderText="KOT Category" Width="150">
								<Template>
									@{
										var product = (context as ProductModel);
										var kotCategory = _kotCategories.FirstOrDefault(c => c.Id == product.KOTCategoryId);
										<span>@(kotCategory?.Name ?? "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(ProductModel.Rate)" HeaderText="Rate" Width="120"
										TextAlign="TextAlign.Right" Format="N2" />
							<GridColumn HeaderText="Tax" Width="120">
								<Template>
									@{
										var product = (context as ProductModel);
										var tax = _taxes.FirstOrDefault(t => t.Id == product.TaxId);
										<span>@(tax?.Code ?? "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(ProductModel.Remarks)" HeaderText="Remarks" Width="250" />
							<GridColumn Field="@nameof(ProductModel.Status)" HeaderText="Status" Width="110"
										TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var product = (context as ProductModel);
										<span class="@(product.Status ? string.Empty : "grid-debit")">@(product.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Product" IdentifierLabel="Name"
						  IdentifierValue="@_deleteProductName" Disabled="@_isProcessing" OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Product" IdentifierLabel="Name"
						   IdentifierValue="@_recoverProductName" Disabled="@_isProcessing" OnConfirm="ConfirmRecover"
						   OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
