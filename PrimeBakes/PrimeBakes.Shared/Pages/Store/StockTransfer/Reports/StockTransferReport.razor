                                                <div><strong>@aggregate.Sum</strong></div>
                                            }
                                        </GroupCaptionTemplate>
                                    </GridAggregateColumn>
                                    <GridAggregateColumn Field="@nameof(StockTransferOverviewModel.OtherChargesAmount)"
                                                         Type="AggregateType.Sum" Format="N2">
