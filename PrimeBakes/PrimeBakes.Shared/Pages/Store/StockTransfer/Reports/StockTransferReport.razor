                        <GridColumns>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TransactionNo)" HeaderText="Trans No"
                                        Width="170" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TransactionDateTime)" HeaderText="Date"
                                        Width="150" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.LocationName)" HeaderText="From Location"
                                        Width="160"
                                        Visible="@(!_showSummary && (_selectedLocation is null || _selectedLocation.Id <= 0))" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.ToLocationName)" HeaderText="To Location"
                                        Width="160" Visible="@(_selectedToLocation is null || _selectedToLocation.Id <= 0)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.CompanyName)" HeaderText="Company"
                                        Width="180"
                                        Visible="@(_showAllColumns && !_showSummary && (_selectedCompany is null || _selectedCompany.Id <= 0))" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.FinancialYear)"
                                        HeaderText="Financial Year" Width="150" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TotalItems)" HeaderText="Items"
                                        Width="100" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TotalQuantity)" HeaderText="Qty"
                                        Width="120" Format="N2" TextAlign="TextAlign.Right" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.BaseTotal)" HeaderText="Base Total"
                                        Width="130" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.ItemDiscountAmount)" HeaderText="Disc"
                                        Width="130" TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="grid-discount">@item.ItemDiscountAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TotalAfterItemDiscount)"
                                        HeaderText="After Disc" Width="140" Format="N2" TextAlign="TextAlign.Right"
                                        Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TotalInclusiveTaxAmount)"
                                        HeaderText="Incl Tax" Width="120" Format="N2" TextAlign="TextAlign.Right"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TotalExtraTaxAmount)"
                                        HeaderText="Extra Tax" Width="120" Format="N2" TextAlign="TextAlign.Right"
                                        Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TotalAfterTax)" HeaderText="Sub Total"
                                        Width="130" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.OtherChargesPercent)"
                                        HeaderText="Other Charges %" Width="150" Format="N2" TextAlign="TextAlign.Center"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.OtherChargesAmount)"
                                        HeaderText="Other Charges" Width="140" Format="N2" TextAlign="TextAlign.Right"
                                        Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.DiscountPercent)" HeaderText="Disc %"
                                        Width="130" Format="N2" TextAlign="TextAlign.Center" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.DiscountAmount)" HeaderText="Disc"
                                        Width="130" TextAlign="TextAlign.Right">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="grid-discount">@item.DiscountAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.RoundOffAmount)" HeaderText="Round Off"
                                        Width="120" Format="N2" TextAlign="TextAlign.Right" Visible="_showAllColumns" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.TotalAmount)" HeaderText="Total"
                                        Width="150" TextAlign="TextAlign.Right">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="grid-total">@item.TotalAmount.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.Cash)" HeaderText="Cash" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="grid-total">@item.Cash.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.Card)" HeaderText="Card" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="grid-total">@item.Card.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.UPI)" HeaderText="UPI" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="grid-total">@item.UPI.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.Credit)" HeaderText="Credit" Width="120"
                                        TextAlign="TextAlign.Right" Visible="_showAllColumns">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="grid-total">@item.Credit.ToString("N2")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.Status)" HeaderText="Status" Width="110"
                                        Visible="@(_showDeleted && !_showSummary)" TextAlign="TextAlign.Center">
                                <Template>
                                    @{
                                        var item = (context as StockTransferOverviewModel);
                                        <span class="@(item.Status ? string.Empty : "grid-debit")">@(item.Status ? "Active" : "Deleted")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(StockTransferOverviewModel.PaymentModes)" HeaderText="Payment Modes"
                                        Width="180" Visible="@(!_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.Remarks)" HeaderText="Remarks" Width="200"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.CreatedByName)" HeaderText="Created By"
                                        Width="150" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.CreatedAt)" HeaderText="Created At"
                                        Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.CreatedFromPlatform)"
                                        HeaderText="Created Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.LastModifiedByUserName)"
                                        HeaderText="Modified By" Width="150" Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.LastModifiedAt)" HeaderText="Modified At"
                                        Width="160" Format="dd/MM/yy hh:mm tt" Type="ColumnType.DateTime"
                                        Visible="@(_showAllColumns && !_showSummary)" />
                            <GridColumn Field="@nameof(StockTransferOverviewModel.LastModifiedFromPlatform)"
                                        HeaderText="Modified Platform" Width="200" Visible="@(_showAllColumns && !_showSummary)" />
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>

        <Footer />
    </div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog" EntityName="Stock Transfer Transaction"
                          IdentifierLabel="Transaction No" IdentifierValue="@_deleteTransactionNo" 
                          Disabled="@_isProcessing" OnConfirm="ConfirmDelete" OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog" EntityName="Stock Transfer Transaction"
                           IdentifierLabel="Transaction No" IdentifierValue="@_recoverTransactionNo" Disabled="@_isProcessing"
                           OnConfirm="ConfirmRecover" OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
