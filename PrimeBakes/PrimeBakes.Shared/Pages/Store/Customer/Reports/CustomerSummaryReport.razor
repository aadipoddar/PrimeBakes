@using PrimeBakes.Library.Accounts.Masters.Models
@using PrimeBakes.Library.Operations.Location
@using PrimeBakes.Library.Store.Customer.Models

@attribute [Route(StoreRouteNames.CustomerSummaryReport)]

<PageTitle>Customer Summary Report - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus?.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.F5 OnHotkeyPressed="LoadTransactionOverviews" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyQ KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDetailsView" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportReport(true)" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Customer Summary Report">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Refresh Data (Ctrl + R / F5)" OnClick="LoadTransactionOverviews" />
					<MudBlazor.MudMenuItem Label="@(_showAllColumns ? "Hide Details (Ctrl + Q)" : "Show Details (Ctrl + Q)")" OnClick="ToggleDetailsView" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportReport()" />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportReport(true)" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Periods" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Today" OnClick="() => HandleDatesChanged(DateRangeType.Today)" />
					<MudBlazor.MudMenuItem Label="Previous Day" OnClick="() => HandleDatesChanged(DateRangeType.Yesterday)" />
					<MudBlazor.MudMenuItem Label="Next Day" OnClick="() => HandleDatesChanged(DateRangeType.NextDay)" />
					<MudBlazor.MudMenuItem Label="Current Month" OnClick="() => HandleDatesChanged(DateRangeType.CurrentMonth)" />
					<MudBlazor.MudMenuItem Label="Previous Month" OnClick="() => HandleDatesChanged(DateRangeType.PreviousMonth)" />
					<MudBlazor.MudMenuItem Label="Next Month" OnClick="() => HandleDatesChanged(DateRangeType.NextMonth)" />
					<MudBlazor.MudMenuItem Label="Current FY" OnClick="() => HandleDatesChanged(DateRangeType.CurrentFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Previous FY" OnClick="() => HandleDatesChanged(DateRangeType.PreviousFinancialYear)" />
					<MudBlazor.MudMenuItem Label="Next FY" OnClick="() => HandleDatesChanged(DateRangeType.NextFinancialYear)" />
					<MudBlazor.MudMenuItem Label="All Time" OnClick="() => HandleDatesChanged(DateRangeType.AllTime)" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Filters</h2>
				</div>

				<div class="section-body">
					<div class="filters-grid">
						<!-- Date Range -->
						<div class="form-field">
							<CustomDateRangePicker @ref="_firstFocus" Value="@(new MudBlazor.DateRange(_fromDate, _toDate))"
												   ValueChanged="OnDateRangeChanged"
												   Label="Date Range (Ctrl + F)"
												   Required="false" />
						</div>

						<!-- Company -->
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="All Companies"
												Label="Company" Required="false"
												ValueChanged="OnCompanyChanged"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@AccountsRouteNames.CompanyMaster" />
						</div>

						<!-- Location -->
						<div class="form-field">
							<CustomAutoComplete T="LocationModel"
												Value="_selectedLocation"
												DataSource="@_locations"
												Placeholder="All Outlets"
												Label="Outlet" Required="false"
												ValueChanged="OnLocationChanged"
												FieldValue="@nameof(LocationModel.Name)" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<h2 class="section-title">Records</h2>
				</div>

				<SfMediaQuery @bind-ActiveBreakpoint="activeBreakpoint" />
				<SfGrid @ref="_sfGrid" TValue="CustomerSummaryModel" DataSource="_customerSummaries"
						AllowTextWrap="true" AllowPaging="true" AllowSorting="true" AllowResizing="true"
						AllowFiltering="true" AllowReordering="true" AllowGrouping="true" ShowColumnChooser="true"
						EnableAdaptiveUI="true" AdaptiveUIMode="AdaptiveMode.Mobile"
						RowRenderingMode="@(activeBreakpoint == "Small" ? RowDirection.Vertical : RowDirection.Horizontal)"
						GridLines="GridLine.Horizontal" ContextMenuItems="@_gridContextMenuItems"
						Toolbar="@(new List<string>() { "ColumnChooser", "Search" })">

					<GridEvents TValue="CustomerSummaryModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
					<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
					<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />

					<GridAggregates>
						<GridAggregate>
							<GridAggregateColumns>
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.Name)" Type="AggregateType.Count" Format="N0" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.TotalTransactions)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.SaleCount)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.BillCount)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.ReturnCount)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.SaleAmount)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.BillAmount)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.ReturnAmount)" CustomColor="grid-debit" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.NetBusiness)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.TotalQuantity)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.AverageOrderValue)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.ReturnPercent)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.ContributionPercent)" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.Cash)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.Card)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.UPI)" CustomColor="grid-total" />
								<GridColumnAggregate Field="@nameof(CustomerSummaryModel.Credit)" CustomColor="grid-total" />
							</GridAggregateColumns>
						</GridAggregate>
					</GridAggregates>

					<GridColumns>
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.Name)" HeaderText="Customer" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.Number)" HeaderText="Number" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.TotalTransactions)" HeaderText="Transactions" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.SaleCount)" HeaderText="Sale Count" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.BillCount)" HeaderText="Bill Count" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.ReturnCount)" HeaderText="Return Count" Visible="_showAllColumns" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.SaleAmount)" HeaderText="Sales" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.BillAmount)" HeaderText="Bills" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.ReturnAmount)" HeaderText="Returns" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.NetBusiness)" HeaderText="Net Business" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.TotalQuantity)" HeaderText="Quantity" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.AverageOrderValue)" HeaderText="Avg Order Value" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.ReturnPercent)" HeaderText="Return %" Visible="_showAllColumns" CustomColor="grid-debit" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.ContributionPercent)" HeaderText="Contribution %" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.FirstPurchase)" HeaderText="First Visit" Format="dd/MM/yy" Type="ColumnType.DateTime" TextAlign="TextAlign.Center" Visible="_showAllColumns" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.LastPurchase)" HeaderText="Last Visit" Format="dd/MM/yy" Type="ColumnType.DateTime" TextAlign="TextAlign.Center" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.DaysSinceLastVisit)" HeaderText="Days Since Visit" Visible="_showAllColumns" NumericColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.Cash)" HeaderText="Cash" Visible="_showAllColumns" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.Card)" HeaderText="Card" Visible="_showAllColumns" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.UPI)" HeaderText="UPI" Visible="_showAllColumns" TotalColumn="true" />
						<CustomGridColumn Field="@nameof(CustomerSummaryModel.Credit)" HeaderText="Credit" Visible="_showAllColumns" TotalColumn="true" />
					</GridColumns>
				</SfGrid>
			</div>
		</div>

		<Footer />
	</div>
}

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
