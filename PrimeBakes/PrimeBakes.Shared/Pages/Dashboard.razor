@attribute [Route(OperationRouteNames.Dashboard)]

<PageTitle>Dashboard - Prime Bakes</PageTitle>

@if (!_isUpdating && (_isLoading || _user == null))
{
	<LoadingScreen />
}
else if (_isUpdating)
{
	<!-- Update Progress Overlay -->
	<div class="update-overlay">
		<div class="update-container">
			<div class="update-header">
				<svg class="update-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
					 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2" />
				</svg>
				<h2 class="update-title">Updating Prime Bakes</h2>
				<p class="update-subtitle">Please wait while we update your app</p>
			</div>

			<div class="update-progress-section">
				<div class="progress-info">
					<span class="progress-label">Progress</span>
					<span class="progress-percentage">@_updateProgress%</span>
				</div>
				<div class="progress-bar-container">
					<div class="progress-bar-fill" style="width: @(_updateProgress)%"></div>
				</div>
				<div class="time-remaining">
					@if (_timeRemaining > 0)
					{
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
							 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10" />
							<polyline points="12 6 12 12 16 14" />
						</svg>
						<span>Estimated time: @_timeRemaining seconds</span>
					}
					else
					{
						<span>Calculating...</span>
					}
				</div>
			</div>

			<div class="update-status">
				<div class="status-dot"></div>
				<span>@_updateStatus</span>
			</div>
		</div>
	</div>
}
else
{
	<div class="page-shell">
		<Header Title="Dashboard">
			<RightContent>
				<IconButton Icon="IconType.Refresh" Title="Force Update" Disabled="@(_isLoading || _isUpdating)" OnClick="ForceUpdate" />
			</RightContent>
		</Header>

		<!-- Main Content Container -->
		<div class="page-container launchpad">

			<MudBlazor.MudTabs Rounded="true"
							   Color="MudBlazor.Color.Transparent"
							   SliderColor="MudBlazor.Color.Primary"
							   MinimumTabWidth="120px"
							   ApplyEffectsToContainer="false"
							   TabHeaderClass="launchpad-tab-header"
							   TabPanelsClass="launchpad-tab-panels">

				<!-- Mobile -->
				<MudBlazor.MudTabPanel Text="Mobile" Visible="@(Factor != "Desktop")">

					<!-- Store Operations -->
					@if (_user.Store)
					{
						<div class="launchpad-section">
							<h2 class="launchpad-section-title">Store Operations</h2>
							<div class="dashboard-grid">
								<FioriTile Title="Order" Subtitle="Take a customer order on mobile" OnClick="() => NavigationManager.NavigateTo(StoreRouteNames.OrderMobile)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
											<rect x="8" y="2" width="8" height="4" rx="1" ry="1" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Sale" Subtitle="Bill a sale quickly on mobile" OnClick="() => NavigationManager.NavigateTo(StoreRouteNames.SaleMobile)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<circle cx="9" cy="21" r="1" />
											<circle cx="20" cy="21" r="1" />
											<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
										</svg>
									</IconContent>
								</FioriTile>
							</div>
						</div>
					}

					<!-- Dining & Billing -->
					@if (_user.Restaurant)
					{
						<div class="launchpad-section">
							<h2 class="launchpad-section-title">Dining & Billing</h2>
							<div class="dashboard-grid">
								<FioriTile Title="Dining Mobile Dashboard" Subtitle="Manage tables and running bills on mobile" OnClick="() => NavigationManager.NavigateTo(RestaurantRouteNames.DiningMobileDashboard)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<rect x="3" y="3" width="8" height="8" rx="1" />
											<rect x="13" y="3" width="8" height="8" rx="1" />
											<rect x="3" y="13" width="8" height="8" rx="1" />
											<rect x="13" y="13" width="8" height="8" rx="1" />
										</svg>
									</IconContent>
								</FioriTile>
							</div>
						</div>
					}

					<!-- Device -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Device</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Local Settings" Subtitle="Pair and test the Bluetooth printer for this device" OnClick="() => NavigationManager.NavigateTo(OperationRouteNames.LocalSettings)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="6.5 6.5 17.5 17.5 12 23 12 1 17.5 6.5 6.5 17.5" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

				</MudBlazor.MudTabPanel>

				<!-- ACCOUNTS -->
				<MudBlazor.MudTabPanel Text="Accounts" Visible="_user.Accounts && !IsMobile">

					<!-- Entry Pages -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Entry Pages</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Financial Accounting" Subtitle="Record journal entries and transactions" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.FinancialAccounting)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<line x1="12" y1="1" x2="12" y2="23" />
										<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

					<!-- Financial Reports -->
					@if (_user.Reports)
					{
						<div class="launchpad-section">
							<h2 class="launchpad-section-title">Financial Reports</h2>
							<div class="dashboard-grid">
								<FioriTile Title="Financial Accounting Report" Subtitle="View accounting transaction history" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.FinancialAccountingReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Ledger Report" Subtitle="View detailed ledger transactions" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.AccountingLedgerReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
											<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Bank Reconciliation" Subtitle="Reconcile bank ledgers & clearing dates" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.BankReconciliation)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<line x1="3" y1="21" x2="21" y2="21" />
											<line x1="3" y1="10" x2="21" y2="10" />
											<polyline points="5 6 12 3 19 6" />
											<line x1="4" y1="10" x2="4" y2="21" />
											<line x1="20" y1="10" x2="20" y2="21" />
											<line x1="8" y1="14" x2="8" y2="17" />
											<line x1="16" y1="14" x2="16" y2="17" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Trial Balance" Subtitle="View trial balance summary" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.TrialBalanceReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
											<line x1="8" y1="21" x2="16" y2="21" />
											<line x1="12" y1="17" x2="12" y2="21" />
											<line x1="7" y1="7" x2="7" y2="11" />
											<line x1="12" y1="7" x2="12" y2="11" />
											<line x1="17" y1="7" x2="17" y2="11" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Profit & Loss" Subtitle="View income and expense summary" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.ProfitAndLossReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<line x1="12" y1="1" x2="12" y2="23" />
											<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Balance Sheet" Subtitle="View assets, liabilities & equity" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.BalanceSheetReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<line x1="12" y1="3" x2="12" y2="21" />
											<line x1="3" y1="6" x2="21" y2="6" />
											<path d="M5 6L3 12h4L5 6" />
											<path d="M19 6l-2 6h4l-2-6" />
											<line x1="7" y1="21" x2="17" y2="21" />
										</svg>
									</IconContent>
								</FioriTile>
							</div>
						</div>
					}

					<!-- Master Data -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Master Data</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Ledgers" Subtitle="Manage ledger accounts" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.LedgerMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
										<polyline points="14 2 14 8 20 8" />
										<line x1="16" y1="13" x2="8" y2="13" />
										<line x1="16" y1="17" x2="8" y2="17" />
										<line x1="10" y1="9" x2="8" y2="9" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Group" Subtitle="Manage account groups" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.GroupMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
										<circle cx="9" cy="7" r="4" />
										<path d="M23 21v-2a4 4 0 0 0-3-3.87" />
										<path d="M16 3.13a4 4 0 0 1 0 7.75" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Account Type" Subtitle="Manage account types" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.AccountTypeMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
										<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Voucher" Subtitle="Manage voucher types" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.VoucherMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
										<polyline points="14 2 14 8 20 8" />
										<line x1="12" y1="18" x2="12" y2="12" />
										<line x1="9" y1="15" x2="15" y2="15" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Financial Years" Subtitle="Manage financial year periods" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.FinancialYearMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
										<line x1="16" y1="2" x2="16" y2="6" />
										<line x1="8" y1="2" x2="8" y2="6" />
										<line x1="3" y1="10" x2="21" y2="10" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="States" Subtitle="Manage state/UT information" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.StateUTMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="12" cy="12" r="10" />
										<line x1="2" y1="12" x2="22" y2="12" />
										<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Company" Subtitle="Manage company settings" OnClick="() => NavigationManager.NavigateTo(AccountsRouteNames.CompanyMaster)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
										<polyline points="9 22 9 12 15 12 15 22" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

				</MudBlazor.MudTabPanel>

				<!-- INVENTORY -->
				<MudBlazor.MudTabPanel Text="Inventory" Visible="_user.Inventory && !IsMobile">

					<!-- Procurement -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Procurement</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Purchase" Subtitle="Record stock purchased from suppliers" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.Purchase)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="9" cy="21" r="1" />
										<circle cx="20" cy="21" r="1" />
										<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Purchase Return" Subtitle="Return purchased stock back to suppliers" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.PurchaseReturn)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polyline points="9 14 4 9 9 4" />
										<path d="M20 20v-7a4 4 0 0 0-4-4H4" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

					<!-- Kitchen Operations -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Kitchen Operations</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Kitchen Issue" Subtitle="Issue raw materials to the kitchen" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.KitchenIssue)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<line x1="12" y1="19" x2="12" y2="5" />
										<polyline points="5 12 12 5 19 12" />
										<rect x="3" y="20" width="18" height="3" rx="1" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Kitchen Production" Subtitle="Record finished goods produced in the kitchen" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.KitchenProduction)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M2 12h20" />
										<path d="M5 12v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6" />
										<path d="m4 8 16-4" />
										<path d="m8.9 6.8-.5-1.8a2 2 0 0 1 1.5-2.4l1.9-.5a2 2 0 0 1 2.4 1.5l.5 1.8" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

					<!-- Stock Adjustments -->
					<div class="launchpad-section">
						<h2 class="launchpad-section-title">Stock Adjustments</h2>
						<div class="dashboard-grid">
							<FioriTile Title="Raw Material Adjustment" Subtitle="Correct raw material stock to actual counts" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.RawMaterialStockAdjustment)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M10 2v7.31" />
										<path d="M14 9.3V2" />
										<path d="M8.5 2h7" />
										<path d="M14 9.3a6.5 6.5 0 1 1-4 0" />
										<path d="M5.58 16.5h12.85" />
									</svg>
								</IconContent>
							</FioriTile>

							<FioriTile Title="Finished Product Adjustment" Subtitle="Correct finished product stock to actual counts" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.ProductStockAdjustment)">
								<IconContent>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polygon points="12 2 2 7 12 12 22 7 12 2" />
										<polyline points="2 17 12 22 22 17" />
										<polyline points="2 12 12 17 22 12" />
									</svg>
								</IconContent>
							</FioriTile>
						</div>
					</div>

					@if (_user.Reports)
					{
						<!-- Purchase Reports -->
						<div class="launchpad-section">
							<h2 class="launchpad-section-title">Purchase Reports</h2>
							<div class="dashboard-grid">
								<FioriTile Title="Purchase Report" Subtitle="Purchase transactions by date and supplier" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.PurchaseReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<line x1="18" y1="20" x2="18" y2="10" />
											<line x1="12" y1="20" x2="12" y2="4" />
											<line x1="6" y1="20" x2="6" y2="14" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Purchase Item Report" Subtitle="Item-wise breakdown of purchases" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.PurchaseItemReport)">
									<IconContent>
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<line x1="8" y1="6" x2="21" y2="6" />
											<line x1="8" y1="12" x2="21" y2="12" />
											<line x1="8" y1="18" x2="21" y2="18" />
											<line x1="3" y1="6" x2="3.01" y2="6" />
											<line x1="3" y1="12" x2="3.01" y2="12" />
											<line x1="3" y1="18" x2="3.01" y2="18" />
										</svg>
									</IconContent>
								</FioriTile>

								<FioriTile Title="Purchase Return Report" Subtitle="Returns raised against suppliers" OnClick="() => NavigationManager.NavigateTo(InventoryRouteNames.PurchaseReturnReport)">
									<IconContent>
