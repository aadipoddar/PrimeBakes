@using PrimeBakesLibrary.Operations.Location
@using PrimeBakesLibrary.Operations.User

@attribute [Route(OperationRouteNames.User)]

<PageTitle>User Management - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="User Management">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
							 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
							<circle cx="12" cy="7" r="4" />
						</svg>
						<h2 class="section-title">User Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @ref="_firstFocus"
											 @bind-Value="_userModel.Name"
											 Label="Name (Ctrl + F)"
											 Placeholder="Enter user name" />
						</div>

						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_userModel.Passcode"
												Label="Passcode"
												Placeholder="Enter 4-digit passcode"
												Format="0000"
												Min="0"
												Max="9999" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="LocationModel"
												@bind-Value="_selectedLocation"
												DataSource="@_locations"
												Placeholder="Select location"
												Label="Location"
												FieldValue="@nameof(LocationModel.Name)"
												AddNewRoute="@OperationRouteNames.Location" />
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_userModel.Accounts" Label="Accounts" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_userModel.Inventory" Label="Inventory" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_userModel.Store" Label="Store" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_userModel.Restaurant" Label="Restaurant" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_userModel.Reports" Label="Reports" />
							</div>
						</div>

						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_userModel.Admin" Label="Admin" />
							</div>
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_userModel.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
							 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
							<circle cx="9" cy="7" r="4" />
							<path d="M23 21v-2a4 4 0 0 0-3-3.87" />
							<path d="M16 3.13a4 4 0 0 1 0 7.75" />
						</svg>
						<h2 class="section-title">Users List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_users" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="UserModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(UserModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(UserModel.Name)" HeaderText="User Name" Width="200" />
							<GridColumn Field="@nameof(UserModel.Passcode)" HeaderText="Passcode" Width="120" Format="0000" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(UserModel.LocationId)" HeaderText="Location" Width="150">
								<Template>
									@{
										var user = (context as UserModel);
										var location = _locations.FirstOrDefault(l => l.Id == user.LocationId);
										<span>@(location?.Name ?? "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(UserModel.Accounts)" HeaderText="Accounts" Width="100" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(UserModel.Inventory)" HeaderText="Inventory" Width="100" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(UserModel.Store)" HeaderText="Store" Width="100" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(UserModel.Restaurant)" HeaderText="Restaurant" Width="100" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(UserModel.Reports)" HeaderText="Reports" Width="100" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(UserModel.Admin)" HeaderText="Admin" Width="100" TextAlign="TextAlign.Center" DisplayAsCheckBox="true" />
							<GridColumn Field="@nameof(UserModel.Remarks)" HeaderText="Remarks" Width="250" />
							<GridColumn Field="@nameof(UserModel.Status)" HeaderText="Status" Width="110" TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var user = (context as UserModel);
										<span class="@(user.Status ? string.Empty : "grid-debit")">@(user.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />