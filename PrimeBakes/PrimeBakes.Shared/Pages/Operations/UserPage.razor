@attribute [Route(PageRouteNames.User)]

@using PrimeBakesLibrary.Models.Operations

<PageTitle>User Management - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" />
<MudBlazor.MudHotkey Key=JsKey.KeyB KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="NavigateBack" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveUser" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportExcel" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ExportPdf" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteSelectedItem" />

@if (_isLoading || _user is null)
{
    <AnimatedLoader Visible="true" />
}
else
{
    <div class="page-shell">
        <Header Title="User Management">
            <LeftContent>
                <SfMenu TValue="Syncfusion.Blazor.Navigations.MenuItem">
                    <MenuAnimationSettings Effect="Syncfusion.Blazor.Navigations.MenuEffect.SlideDown" Duration="300"
                                           Easing="ease" />
                    <MenuEvents TValue="Syncfusion.Blazor.Navigations.MenuItem" ItemSelected="OnMenuSelected" />
                    <MenuItems>
                        <MenuItem Text="File" IconCss="e-icons e-folder">
                            <MenuItems>
                                <MenuItem Text="New (Ctrl + N)" IconCss="e-icons e-plus" Id="NewUser"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Save (Ctrl + S)" IconCss="e-icons e-save" Id="SaveUser"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" IconCss="e-icons e-trash"
                                          Id="ToggleDeleted" Disabled="@_isProcessing" />
                                <MenuItem Separator="true" />
                                <MenuItem Text="Export Excel (Ctrl + E)" IconCss="e-icons e-export-excel" Id="ExportExcel"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Export PDF (Ctrl + P)" IconCss="e-icons e-export-pdf" Id="ExportPdf"
                                          Disabled="@_isProcessing" />
                            </MenuItems>
                        </MenuItem>
                        <MenuItem Text="Transaction" IconCss="e-icons e-chart">
                            <MenuItems>
                                <MenuItem Text="Edit (Insert)" IconCss="e-icons e-edit" Id="EditSelected"
                                          Disabled="@_isProcessing" />
                                <MenuItem Text="Delete / Recover (Del)" IconCss="e-icons e-trash" Id="DeleteRecoverSelected"
                                          Disabled="@_isProcessing" />
                            </MenuItems>
                        </MenuItem>
                    </MenuItems>
                </SfMenu>
            </LeftContent>
            <RightContent>
                <IconButton Icon="IconType.Back" Title="Back (Ctrl + B)" OnClick="NavigateBack" />
            </RightContent>
        </Header>

        <!-- Main Content Container -->
        <div class="page-container">

            <!-- User Entry Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        <h2 class="section-title">User Details</h2>
                    </div>
                </div>
                <div class="section-body">
                    <div class="form-grid">
                        <!-- User Name -->
                        <div class="form-field">
                            <label class="field-label">
                                User Name <span class="required">*</span>
                            </label>
                            <SfTextBox @bind-Value="_user.Name" Placeholder="Enter user name"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Passcode -->
                        <div class="form-field">
                            <label class="field-label">
                                Passcode <span class="required">*</span>
                            </label>
                            <SfNumericTextBox @bind-Value="_user.Passcode" TValue="int" Format="0000" Min="0" Max="9999"
                                              Placeholder="Enter 4-digit passcode" FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>

                        <!-- Location -->
                        <div class="form-field">
                            <label class="field-label">
                                Location <span class="required">*</span>
                            </label>
                            <SfAutoComplete @bind-Value="_location" TValue="LocationModel" TItem="LocationModel"
                                            DataSource="@_locations" Placeholder="Select location"
                                            FloatLabelType="FloatLabelType.Never" AllowFiltering="true"
                                            FilterType="Syncfusion.Blazor.DropDowns.FilterType.Contains" CssClass="custom-dropdown">
                                <AutoCompleteFieldSettings Value="Name" />
                            </SfAutoComplete>
                        </div>

                        <!-- Permissions -->
                        <div class="form-field">
                            <label class="field-label">Accounts</label>
                            <div class="checkbox-wrapper">
                                <SfCheckBox @bind-Checked="_user.Accounts" Label="Accounts" CssClass="custom-checkbox" />
                            </div>
                        </div>

                        <div class="form-field">
                            <label class="field-label">Inventory</label>
                            <div class="checkbox-wrapper">
                                <SfCheckBox @bind-Checked="_user.Inventory" Label="Inventory" CssClass="custom-checkbox" />
                            </div>
                        </div>

                        <div class="form-field">
                            <label class="field-label">Store</label>
                            <div class="checkbox-wrapper">
                                <SfCheckBox @bind-Checked="_user.Store" Label="Store" CssClass="custom-checkbox" />
                            </div>
                        </div>

                        <div class="form-field">
                            <label class="field-label">Restaurant</label>
                            <div class="checkbox-wrapper">
                                <SfCheckBox @bind-Checked="_user.Restaurant" Label="Restaurant" CssClass="custom-checkbox" />
                            </div>
                        </div>

                        <div class="form-field">
                            <label class="field-label">Reports</label>
                            <div class="checkbox-wrapper">
                                <SfCheckBox @bind-Checked="_user.Reports" Label="Reports" CssClass="custom-checkbox" />
                            </div>
                        </div>

                        <div class="form-field">
                            <label class="field-label">Admin</label>
                            <div class="checkbox-wrapper">
                                <SfCheckBox @bind-Checked="_user.Admin" Label="Admin" CssClass="custom-checkbox" />
                            </div>
                        </div>

                        <!-- Remarks -->
                        <div class="form-field">
                            <label class="field-label">Remarks</label>
                            <SfTextBox @bind-Value="_user.Remarks" Placeholder="Enter remarks (optional)" Multiline="true"
                                       FloatLabelType="FloatLabelType.Never" CssClass="custom-textbox" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Users List Section -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-title-wrapper">
                        <svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                        <h2 class="section-title">Users List</h2>
                    </div>
                </div>
                <div class="section-body grid-body">
                    <SfGrid @ref="_sfGrid" DataSource="@_users" AllowPaging="true" AllowSorting="true" AllowFiltering="true"
                            AllowResizing="true" CssClass="professional-grid" Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_userGridContextMenuItems">
                        <GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
                        <GridEvents TValue="UserModel" ContextMenuItemClicked="OnUserGridContextMenuItemClicked" />
                        <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                        <GridColumns>
                            <GridColumn Field="@nameof(UserModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
                            <GridColumn Field="@nameof(UserModel.Name)" HeaderText="User Name" Width="200" />
                            <GridColumn Field="@nameof(UserModel.Passcode)" HeaderText="Passcode" Width="120" Format="0000" TextAlign="TextAlign.Center" />
                            <GridColumn Field="@nameof(UserModel.LocationId)" HeaderText="Location" Width="150">
                                <Template>
                                    @{
                                        var user = (context as UserModel);
                                        var location = _locations.FirstOrDefault(l => l.Id == user.LocationId);
                                        <span>@(location?.Name ?? "N/A")</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn HeaderText="Permissions" Width="250" AllowFiltering="false">
                                <Template>
                                    @{
                                        var user = (context as UserModel);
                                        var permissions = new List<string>();
                                        if (user.Accounts) permissions.Add("Accounts");
                                        if (user.Inventory) permissions.Add("Inventory");
                                        if (user.Store) permissions.Add("Store");
                                        if (user.Restaurant) permissions.Add("Restaurant");
                                        if (user.Reports) permissions.Add("Reports");
                                        if (user.Admin) permissions.Add("Admin");
                                        <span>@string.Join(", ", permissions)</span>
                                    }
                                </Template>
                            </GridColumn>
                            <GridColumn Field="@nameof(UserModel.Remarks)" HeaderText="Remarks" Width="250" />
                            <GridColumn Field="@nameof(UserModel.Status)" HeaderText="Status" Width="110"
                                        TextAlign="TextAlign.Center" Visible="_showDeleted">
                                <Template>
                                    @{
                                        var user = (context as UserModel);
                                        <span class="@(user.Status ? string.Empty : "grid-debit")">@(user.Status ? "Active" : "Deleted")</span>
                                    }
                                </Template>
                            </GridColumn>
                        </GridColumns>
                    </SfGrid>
                </div>
            </div>
        </div>

        <Footer />
    </div>
}

<DeleteConfirmationDialog @ref="_deleteConfirmationDialog"
                          EntityName="User"
                          IdentifierLabel="User Name"
                          IdentifierValue="@_deleteUserName"
                          
                          Disabled="@_isProcessing"
                          OnConfirm="ConfirmDelete"
                          OnCancel="CancelDelete" />

<RecoverConfirmationDialog @ref="_recoverConfirmationDialog"
                           EntityName="User"
                           IdentifierLabel="User Name"
                           IdentifierValue="@_recoverUserName"
                           Disabled="@_isProcessing"
                           OnConfirm="ConfirmRecover"
                           OnCancel="CancelRecover" />

<ToastNotification @ref="_toastNotification" />
