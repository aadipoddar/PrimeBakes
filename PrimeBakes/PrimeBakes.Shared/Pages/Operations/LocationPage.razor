@using PrimeBakesLibrary.Accounts.Masters.Models
@using PrimeBakesLibrary.Operations.Location

@attribute [Route(OperationRouteNames.Location)]

<PageTitle>Location Management - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyN KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ResetPage" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyF KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => _firstFocus.FocusAsync()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveTransaction" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyE KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster(true)" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyP KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="() => ExportMaster()" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ToggleDeleted" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Insert OnHotkeyPressed="EditSelectedItem" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.Delete OnHotkeyPressed="DeleteRecoverSelectedItem" Disabled="@_isProcessing" />

@if (_isLoading || _user is null)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="Location Management">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="New (Ctrl + N)" OnClick="ResetPage" />
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveTransaction" />
					<MudBlazor.MudMenuItem Label="@(_showDeleted ? "Hide Deleted (Ctrl + Delete)" : "Show Deleted (Ctrl + Delete)")" OnClick="ToggleDeleted" />
					<MudBlazor.MudDivider />
					<MudBlazor.MudMenuItem Label="Export Excel (Ctrl + E)" OnClick="() => ExportMaster(true)" />
					<MudBlazor.MudMenuItem Label="Export PDF (Ctrl + P)" OnClick="() => ExportMaster()" />
				</MudBlazor.MudMenu>

				<MudBlazor.MudMenu Label="Transaction" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Edit (Insert)" OnClick="EditSelectedItem" />
					<MudBlazor.MudMenuItem Label="Delete / Recover (Del)" OnClick="DeleteRecoverSelectedItem" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
							<circle cx="12" cy="10" r="3" />
						</svg>
						<h2 class="section-title">Location Details</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @ref="_firstFocus"
											 @bind-Value="_location.Name"
											 Label="Location Name (Ctrl + F)"
											 Placeholder="Enter location name" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_location.Code"
											 Label="Code"
											 Placeholder="Enter prefix code" />
						</div>

						<div class="form-field">
							<CustomNumericField T="decimal"
												@bind-Value="_location.Discount"
												Label="Discount (%)"
												Placeholder="Enter discount percentage"
												Format="N2"
												Min="0"
												Max="100"
												Step="0.01m"
												AdornmentText="%"
												Required="false" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="LedgerModel"
												@bind-Value="_selectedLedger"
												DataSource="@_ledgers"
												Placeholder="Select ledger"
												Label="Ledger"
												FieldValue="@nameof(LedgerModel.Name)"
												AddNewRoute="@AccountsRouteNames.LedgerMaster" />
						</div>

						<div class="form-field">
							<CustomAutoComplete T="LocationModel"
												@bind-Value="_copyLocation"
												DataSource="@_locations"
												Placeholder="Select location to copy products (optional)"
												Label="Copy Products From Location"
												FieldValue="@nameof(LocationModel.Name)"
												Required="false" />
						</div>

						<div class="form-field">
							<CustomTextField @bind-Value="_location.Remarks"
											 Label="Remarks"
											 Placeholder="Enter remarks (optional)"
											 Required="false"
											 Lines="2" />
						</div>
					</div>
				</div>
			</div>

			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20"
							 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
							 stroke-linejoin="round">
							<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
							<polyline points="9 22 9 12 15 12 15 22" />
						</svg>
						<h2 class="section-title">Locations List</h2>
					</div>
				</div>
				<div class="section-body grid-body">
					<SfGrid @ref="_sfGrid" DataSource="@_locations" AllowPaging="true" AllowSorting="true"
							AllowFiltering="true" AllowResizing="true" CssClass="professional-grid"
							Toolbar="@(new List<string>() { "Search" })" ContextMenuItems="@_gridContextMenuItems">
						<GridPageSettings PageSize="20" PageSizes="@(new string[] { "20", "50", "100", "200", "All" })" />
						<GridEvents TValue="LocationModel" ContextMenuItemClicked="OnGridContextMenuItemClicked" />
						<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
						<GridColumns>
							<GridColumn Field="@nameof(LocationModel.Id)" HeaderText="ID" Width="80" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(LocationModel.Name)" HeaderText="Location Name" Width="200" />
							<GridColumn Field="@nameof(LocationModel.Code)" HeaderText="Code" Width="150" TextAlign="TextAlign.Center" />
							<GridColumn Field="@nameof(LocationModel.Discount)" HeaderText="Discount (%)" Width="120" Format="N2" TextAlign="TextAlign.Right" />
							<GridColumn Field="@nameof(LocationModel.LedgerId)" HeaderText="Ledger" Width="200">
								<Template>
									@{
										var location = (context as LocationModel);
										var ledger = _ledgers.FirstOrDefault(l => l.Id == location.LedgerId);
										<span>@(ledger?.Name ?? "N/A")</span>
									}
								</Template>
							</GridColumn>
							<GridColumn Field="@nameof(LocationModel.Remarks)" HeaderText="Remarks" Width="250" />
							<GridColumn Field="@nameof(LocationModel.Status)" HeaderText="Status" Width="110"
										TextAlign="TextAlign.Center" Visible="_showDeleted">
								<Template>
									@{
										var location = (context as LocationModel);
										<span class="@(location.Status ? string.Empty : "grid-debit")">@(location.Status ? "Active" : "Deleted")</span>
									}
								</Template>
							</GridColumn>
						</GridColumns>
					</SfGrid>
				</div>
			</div>
		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
