@using PrimeBakesLibrary.Accounts.Masters.Models

@attribute [Route(OperationRouteNames.Settings)]

<PageTitle>Settings - Prime Bakes</PageTitle>

<MudBlazor.MudHotkey Key=JsKey.KeyS KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="SaveSettings" Disabled="@_isProcessing" />
<MudBlazor.MudHotkey Key=JsKey.KeyR KeyModifiers=[JsKeyModifier.ControlLeft] OnHotkeyPressed="ShowResetConfirmation" Disabled="@_isProcessing" />

@if (_isLoading)
{
	<LoadingScreen />
}
else
{
	<div class="page-shell">
		<Header Title="System Settings">
			<LeftContent>
				<MudBlazor.MudMenu Label="File" Dense="true" Disabled="_isProcessing">
					<MudBlazor.MudMenuItem Label="Save (Ctrl + S)" OnClick="SaveSettings" />
					<MudBlazor.MudMenuItem Label="Reset to Defaults (Ctrl + R)" OnClick="ShowResetConfirmation" />
				</MudBlazor.MudMenu>
			</LeftContent>
		</Header>

		<div class="page-container">

			<!-- Primary Configuration -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="3" />
							<path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h.09a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.09a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.09a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
						</svg>
						<h2 class="section-title">Primary Configuration</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="CompanyModel"
												Value="_selectedCompany"
												DataSource="@_companies"
												Placeholder="Select primary company"
												Label="Primary Company"
												ValueChanged="OnCompanyChange"
												FieldValue="@nameof(CompanyModel.Name)"
												AddNewRoute="@AccountsRouteNames.CompanyMaster" />
						</div>
					</div>
				</div>
			</div>

			<!-- Master Data Code Prefixes -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="16 18 22 12 16 6" />
							<polyline points="8 6 2 12 8 18" />
						</svg>
						<h2 class="section-title">Master Data Code Prefixes</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @bind-Value="_rawMaterialCodePrefix" Label="Raw Material Code Prefix" Placeholder="e.g., RM" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_finishedProductCodePrefix" Label="Finished Product Code Prefix" Placeholder="e.g., FP" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_ledgerCodePrefix" Label="Ledger Code Prefix" Placeholder="e.g., LD" Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Transaction Prefixes -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="12" y1="1" x2="12" y2="23" />
							<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
						</svg>
						<h2 class="section-title">Transaction Prefixes</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @bind-Value="_accountingTransactionPrefix" Label="Accounting Transaction Prefix" Placeholder="e.g., ACC" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_purchaseTransactionPrefix" Label="Purchase Transaction Prefix" Placeholder="e.g., PUR" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_purchaseReturnTransactionPrefix" Label="Purchase Return Transaction Prefix" Placeholder="e.g., PURR" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_kitchenIssueTransactionPrefix" Label="Kitchen Issue Transaction Prefix" Placeholder="e.g., KI" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_kitchenProductionTransactionPrefix" Label="Kitchen Production Transaction Prefix" Placeholder="e.g., KP" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_rawMaterialStockAdjustmentTransactionPrefix" Label="Raw Material Stock Adjustment Prefix" Placeholder="e.g., RMSA" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_productStockAdjustmentTransactionPrefix" Label="Product Stock Adjustment Prefix" Placeholder="e.g., PSA" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_saleTransactionPrefix" Label="Sale Transaction Prefix" Placeholder="e.g., SAL" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_saleReturnTransactionPrefix" Label="Sale Return Transaction Prefix" Placeholder="e.g., SALR" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_stockTransferTransactionPrefix" Label="Stock Transfer Transaction Prefix" Placeholder="e.g., STK" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_orderTransactionPrefix" Label="Order Transaction Prefix" Placeholder="e.g., ORD" Required="false" />
						</div>
						<div class="form-field">
							<CustomTextField @bind-Value="_billTransactionPrefix" Label="Bill Transaction Prefix" Placeholder="e.g., BIL" Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Voucher Linking -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="12" y1="18" x2="12" y2="12" />
							<line x1="9" y1="15" x2="15" y2="15" />
						</svg>
						<h2 class="section-title">Voucher Linking</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedPurchaseVoucher" DataSource="@_vouchers" Placeholder="Select purchase voucher" Label="Purchase Voucher" ValueChanged="OnPurchaseVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedPurchaseReturnVoucher" DataSource="@_vouchers" Placeholder="Select purchase return voucher" Label="Purchase Return Voucher" ValueChanged="OnPurchaseReturnVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedSaleVoucher" DataSource="@_vouchers" Placeholder="Select sale voucher" Label="Sale Voucher" ValueChanged="OnSaleVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedSaleReturnVoucher" DataSource="@_vouchers" Placeholder="Select sale return voucher" Label="Sale Return Voucher" ValueChanged="OnSaleReturnVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedStockTransferVoucher" DataSource="@_vouchers" Placeholder="Select stock transfer voucher" Label="Stock Transfer Voucher" ValueChanged="OnStockTransferVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedBillVoucher" DataSource="@_vouchers" Placeholder="Select bill voucher" Label="Bill Voucher" ValueChanged="OnBillVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedBillDayCloseVoucher" DataSource="@_vouchers" Placeholder="Select bill day close voucher" Label="Bill Day Close Voucher" ValueChanged="OnBillDayCloseVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedSaleDayCloseVoucher" DataSource="@_vouchers" Placeholder="Select sale day close voucher" Label="Sale Day Close Voucher" ValueChanged="OnSaleDayCloseVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Ledger Linking -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
							<polyline points="14 2 14 8 20 8" />
							<line x1="16" y1="13" x2="8" y2="13" />
							<line x1="16" y1="17" x2="8" y2="17" />
							<line x1="10" y1="9" x2="8" y2="9" />
						</svg>
						<h2 class="section-title">Ledger Linking</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel" Value="_selectedPurchaseLedger" DataSource="@_ledgers" Placeholder="Select purchase ledger" Label="Purchase Ledger" ValueChanged="OnPurchaseLedgerChange" FieldValue="@nameof(LedgerModel.Name)" AddNewRoute="@AccountsRouteNames.LedgerMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel" Value="_selectedSaleLedger" DataSource="@_ledgers" Placeholder="Select sale ledger" Label="Sale Ledger" ValueChanged="OnSaleLedgerChange" FieldValue="@nameof(LedgerModel.Name)" AddNewRoute="@AccountsRouteNames.LedgerMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel" Value="_selectedStockTransferLedger" DataSource="@_ledgers" Placeholder="Select stock transfer ledger" Label="Stock Transfer Ledger" ValueChanged="OnStockTransferLedgerChange" FieldValue="@nameof(LedgerModel.Name)" AddNewRoute="@AccountsRouteNames.LedgerMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel" Value="_selectedBillLedger" DataSource="@_ledgers" Placeholder="Select bill ledger" Label="Bill Ledger" ValueChanged="OnBillLedgerChange" FieldValue="@nameof(LedgerModel.Name)" AddNewRoute="@AccountsRouteNames.LedgerMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel" Value="_selectedCashLedger" DataSource="@_ledgers" Placeholder="Select cash ledger" Label="Cash Ledger" ValueChanged="OnCashLedgerChange" FieldValue="@nameof(LedgerModel.Name)" AddNewRoute="@AccountsRouteNames.LedgerMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel" Value="_selectedCashSalesLedger" DataSource="@_ledgers" Placeholder="Select cash sales ledger" Label="Cash Sales Ledger" ValueChanged="OnCashSalesLedgerChange" FieldValue="@nameof(LedgerModel.Name)" AddNewRoute="@AccountsRouteNames.LedgerMaster" Required="false" />
						</div>
						<div class="form-field">
							<CustomAutoComplete T="LedgerModel" Value="_selectedGSTLedger" DataSource="@_ledgers" Placeholder="Select GST ledger" Label="GST Ledger" ValueChanged="OnGSTLedgerChange" FieldValue="@nameof(LedgerModel.Name)" AddNewRoute="@AccountsRouteNames.LedgerMaster" Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Bank Reconciliation -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="3" y1="21" x2="21" y2="21" />
							<line x1="3" y1="10" x2="21" y2="10" />
							<polyline points="5 6 12 3 19 6" />
							<line x1="4" y1="10" x2="4" y2="21" />
							<line x1="20" y1="10" x2="20" y2="21" />
							<line x1="8" y1="14" x2="8" y2="17" />
							<line x1="12" y1="14" x2="12" y2="17" />
							<line x1="16" y1="14" x2="16" y2="17" />
						</svg>
						<h2 class="section-title">Bank Reconciliation</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="AccountTypeModel" Value="_selectedBankAccountType" DataSource="@_accountTypes" Placeholder="Select bank account type" Label="Bank Account Type" ValueChanged="OnBankAccountTypeChange" FieldValue="@nameof(AccountTypeModel.Name)" AddNewRoute="@AccountsRouteNames.AccountTypeMaster" Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Default Values -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="4" width="18" height="16" rx="2" />
							<line x1="8" y1="9" x2="16" y2="9" />
							<line x1="8" y1="13" x2="13" y2="13" />
							<line x1="8" y1="17" x2="11" y2="17" />
						</svg>
						<h2 class="section-title">Default Values</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomAutoComplete T="VoucherModel" Value="_selectedDefaultVoucher" DataSource="@_vouchers" Placeholder="Select default accounting voucher" Label="Default Voucher for Accounting Transactions" ValueChanged="OnDefaultVoucherChange" FieldValue="@nameof(VoucherModel.Name)" AddNewRoute="@AccountsRouteNames.VoucherMaster" Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Purchase Behavior -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="9" cy="21" r="1" />
							<circle cx="20" cy="21" r="1" />
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
						</svg>
						<h2 class="section-title">Purchase Behavior</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_updateItemMasterRateOnPurchase" Label="Update Raw Material Rate on Purchase" />
							</div>
						</div>
						<div class="form-field">
							<div class="checkbox-wrapper">
								<CustomCheckBox @bind-Value="_updateItemMasterUOMOnPurchase" Label="Update Raw Material UOM on Purchase" />
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Report Settings -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10" />
							<polyline points="12 6 12 12 16 14" />
						</svg>
						<h2 class="section-title">Report Settings</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_autoRefreshReportTimer"
												Label="Auto Refresh Timer (Minutes)"
												Placeholder="e.g., 5"
												Format="N0"
												Min="1"
												Max="60"
												Required="false" />
						</div>
						<div class="form-field">
							<CustomNumericField T="int"
												@bind-Value="_reportWarningDays"
												Label="Report Warning (Days)"
												Placeholder="e.g., 30"
												Format="N0"
												Min="1"
												Max="365"
												Required="false" />
						</div>
					</div>
				</div>
			</div>

			<!-- Notification Settings -->
			<div class="section-card">
				<div class="section-header">
					<div class="section-title-wrapper">
						<svg class="section-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
							<polyline points="22,6 12,13 2,6" />
						</svg>
						<h2 class="section-title">Notification Settings</h2>
					</div>
				</div>
				<div class="section-body">
					<div class="form-grid">
						<div class="form-field">
							<CustomTextField @bind-Value="_notificationEmail" Label="Notification Email" Placeholder="Leave blank to disable email notifications" Required="false" />
						</div>
					</div>
				</div>
			</div>

		</div>

		<Footer />
	</div>
}

<ConfirmationDialog @ref="_confirmationDialog" Title="@_confirmTitle" Message="@_confirmMessage"
					OnConfirm="OnConfirmed" OnCancel="OnCancelled" />

<ToastNotification @ref="_toastNotification" />

<CloseGuard Block="_isProcessing" />
